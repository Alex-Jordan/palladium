      <exercisegroup cols="2">
        <title>Solving for a Variable Comparisons</title>
        <introduction>
          <p>
            Solve the equation for the indicated variable.
          </p>
        </introduction>
        <exercise label="compare-xplusbequalsc">
          <webwork xml:id="webwork-compare-xplusbequalsc">
            <pg-macros>
              <macro-file>parserLinearRelation.pl</macro-file>
            </pg-macros>
            <pg-code>
              @x = random_subset(3, ('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z'));
              @a = random_subset(2, 1..9);
              Context("Numeric")->variables->are($x[0] => 'Real');
              $left[0] = Formula("$x[0] + $a[0]")->reduce;
              $right[0] = Formula("$a[1]")->reduce;
              Context("Numeric")->variables->are(map {$_ => 'Real'} (@x));
              $left[1] = Formula("$x[0] + $x[1]")->reduce;
              $right[1] = Formula("$x[2]")->reduce;
              Context("FiniteSolutionSets")->variables->are($x[0] => 'Real');
              $sol = $a[1] - $a[0];
              $ans[0] = Formula("{$sol}");
              Context("LinearRelation")->variables->are(map {$_ => 'Real'} (@x));
              $ans[1] = LinearRelation("$x[0] = $x[2] - $x[1]");
            </pg-code>
            <task>
              <statement>
                <p>
                  <m><var name="$left[0]"/>=<var name="$right[0]"/></m> for <m><var name="$x[0]"/></m>.
                </p>
                <p>
                  <var name="$ans[0]" width="16"/>
                </p>
              </statement>
            </task>
            <task>
              <statement>
                <p>
                  <m><var name="$left[1]"/>=<var name="$right[1]"/></m> for <m><var name="$x[0]"/></m>.
                </p>
                <p>
                  <var name="$ans[1]" width="16"/>
                </p>
              </statement>
            </task>
          </webwork>
        </exercise>
        <exercise label="compare-xplusbequalsc-copy">
          <webwork copy="webwork-compare-xplusbequalsc"/>
        </exercise>
        <exercise label="compare-xminusbequalsc">
          <webwork xml:id="webwork-compare-xminusbequalsc">
            <pg-macros>
              <macro-file>parserLinearRelation.pl</macro-file>
            </pg-macros>
            <pg-code>
              @x = random_subset(3, ('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z'));
              @a = random_subset(2, 1..9);
              Context("Numeric")->variables->are($x[0] => 'Real');
              $left[0] = Formula("$x[0] - $a[0]")->reduce;
              $right[0] = Formula("$a[1]")->reduce;
              Context("Numeric")->variables->are(map {$_ => 'Real'} (@x));
              $left[1] = Formula("$x[0] - $x[1]")->reduce;
              $right[1] = Formula("$x[2]")->reduce;
              Context("FiniteSolutionSets")->variables->are($x[0] => 'Real');
              $sol = $a[1] + $a[0];
              $ans[0] = Formula("{$sol}");
              Context("LinearRelation")->variables->are(map {$_ => 'Real'} (@x));
              $ans[1] = LinearRelation("$x[0] = $x[2] + $x[1]");
            </pg-code>
            <task>
              <statement>
                <p>
                  <m><var name="$left[0]"/>=<var name="$right[0]"/></m> for <m><var name="$x[0]"/></m>.
                </p>
