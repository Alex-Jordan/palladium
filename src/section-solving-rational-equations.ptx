        <exercise label="solve-mxequalsmxplusb-inequality">
          <webwork xml:id="webwork-solve-mxequalsmxplusb-inequality">
            <pg-code>
              $m = random(2,9);
              $b = non_zero_random(-9,9);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              $left = Formula("$m $x");
              $right = Formula("$m $x + $b")->reduce;
              $symbol = list_random('\lt', '\gt', '\leq', '\geq');
              sub weigh {
                my ($a, $b, $s) = @_;
                if ($s eq '\lt') {return ($a &lt; $b)}
                elsif ($s eq '\gt') {return ($a > $b)}
                elsif ($s eq '\leq') {return ($a &lt;= $b)}
                elsif ($s eq '\geq') {return ($a >= $b)}
              }
              Context("FiniteSolutionSets");
              $solution = (weigh($left->eval($x => 0), $right->eval($x => 0), $symbol))
                ? OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"))
                : String("no real solutions")->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/><var name="$symbol"/><var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
