              $x[0] = 'x';
              $x[3] = 'y';
              Context()->variables->are(map {$_ => 'Real'} (@x));
              $right = Formula("$x[1] $x[0] + $x[2]")->reduce;
              $left = Formula("$x[3]")->reduce;
              parser::Assignment->Allow;
              $ans = Assignment("$x[0] = ($x[3] - $x[2])/$x[1]");
            </pg-code>
            <statement>
              <p>
                <m><var name="$x[0]"/></m> in <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
