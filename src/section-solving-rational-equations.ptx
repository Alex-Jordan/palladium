      </exercisegroup>
      <exercisegroup cols="2">
        <title>Isolate the Variable</title>
        <introduction>
          <p>
            Isolate the indicated variable.
          </p>
        </introduction>
        <exercise label="isolate-xplusaequalsb">
          <webwork xml:id="webwork-isolate-xplusaequalsb">
            <pg-code>
              @x = random_subset(3, ('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z'));
              Context()->variables->are(map {$_ => 'Real'} (@x));
              $left = Formula("$x[0] + $x[1]")->reduce;
              $right = Formula("$x[2]")->reduce;
              parser::Assignment->Allow;
              $ans = Assignment("$x[0] = $x[2] - $x[1]");
            </pg-code>
            <statement>
              <p>
                <m><var name="$x[0]"/></m> in <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="isolate-xplusaequalsb-copy">
          <webwork copy="webwork-isolate-xplusaequalsb"/>
        </exercise>
        <exercise label="isolate-axplusbequalsc">
          <webwork xml:id="webwork-isolate-axplusbequalsc">
            <pg-code>
              @x = random_subset(4, ('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z'));
              Context()->variables->are(map {$_ => 'Real'} (@x));
              $left = Formula("$x[1] $x[0] + $x[2]")->reduce;
              $right = Formula("$x[3]")->reduce;
              parser::Assignment->Allow;
              $ans = Assignment("$x[0] = ($x[3] - $x[2])/$x[1]");
              $leftsol[0] = Formula("$x[1] $x[0] + $x[2] - $x[2]")->reduce;
              $rightsol[0] = Formula("$x[3] - $x[2]")->reduce;
              $leftsol[1] = Formula("$x[1] $x[0]")->reduce;
              $rightsol[1] = Formula("$x[3] - $x[2]")->reduce;
              $leftsol[2] = Formula("$x[0]")->reduce;
              $rightsol[2] = Formula("($x[3] - $x[2])/$x[1]")->reduce;
            </pg-code>
            <statement>
              <p>
                <m><var name="$x[0]"/></m> in <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                We need to keep our focus on <m><var name="$x[0]"/></m> and take algebra steps that
                bring us closer to isolating <m><var name="$x[0]"/></m>.
                <md>
                  <mrow><var name="$left"/> \amp= <var name="$right"/></mrow>
                  <mrow><var name="$leftsol[0]"/> \amp= <var name="$rightsol[0]"/></mrow>
                  <mrow><var name="$leftsol[1]"/> \amp= <var name="$rightsol[1]"/></mrow>
                  <mrow><var name="$leftsol[2]"/> \amp= <var name="$rightsol[2]"/></mrow>
                </md>
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="isolate-axplusbequalsc-copy">
          <webwork copy="webwork-isolate-axplusbequalsc"/>
        </exercise>
