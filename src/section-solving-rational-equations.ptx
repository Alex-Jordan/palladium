            <pg-code>
              @x = random_subset(4, ('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z'));
              @a = random_subset(3, 2..9);
              Context("Fraction")->variables->are($x[0] => 'Real');
              $left[0] = Formula("$a[0] $x[0] + $a[1]")->reduce;
              $right[0] = Formula("$a[2]")->reduce;
              $sol = Fraction("($a[2] - $a[1])/$a[0]");
              Context("Fraction")->variables->are(map {$_ => 'Real'} (@x));
              $left[1] = Formula("$x[1] $x[0] + $x[2]")->reduce;
              $right[1] = Formula("$x[3]")->reduce;
              Context("FiniteSolutionSets")->variables->are($x[0] => 'Real');
              $ans[0] = Formula("{$sol}");
              Context("Numeric")->variables->are(map {$_ => 'Real'} (@x));
              parser::Assignment->Allow;
              $ans[1] = Assignment("$x[0] = ($x[3] - $x[2])/$x[1]");
            </pg-code>
            <task>
              <statement>
                <p>
                  <m><var name="$left[0]"/>=<var name="$right[0]"/></m> for <m><var name="$x[0]"/></m>.
                </p>
