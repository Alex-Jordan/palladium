      </exercisegroup>
      <exercisegroup cols="2">
        <title>Equations with Special Solution Sets</title>
        <introduction>
          <p>
            Solve the equation for its variable.
          </p>
        </introduction>
        <exercise label="solve-mxequalsmxplusb">
          <webwork xml:id="webwork-solve-mxequalsmxplusb">
            <pg-code>
              $m = random(2,9);
              $b = non_zero_random(-9,9);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              $left = Formula("$m $x");
              $right = Formula("$m $x + $b")->reduce;
              Context("FiniteSolutionSets");
              $solution = String("no real solutions")->cmp(typeMatch => Formula("{1}"));
              #$solution = OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="solve-mxequalsmxplusb-copy">
          <webwork copy="webwork-solve-mxequalsmxplusb"/>
        </exercise>
        <exercise label="solve-mxplusbequalsmxplusb">
          <webwork xml:id="webwork-solve-mxplusbequalsmxplusb">
            <pg-code>
              $m = random(2,9);
              $b = non_zero_random(-9,9);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              $left = Formula("$m $x + $b")->reduce;
              $right = Formula("$m $x + $b")->reduce;
              Context("FiniteSolutionSets");
              #$solution = String("no real solutions")->cmp(typeMatch => Formula("{1}"));
              $solution = OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="solve-mxplusbequalsmxplusb-copy">
          <webwork copy="webwork-solve-mxplusbequalsmxplusb"/>
        </exercise>
        <exercise label="solve-special-with-like-terms">
          <webwork xml:id="webwork-solve-special-with-like-terms">
            <pg-code>
              do {
                ($m, $n, $b, $c) = random_subset(4,-9..-1,1..9);
                $p = $m + $n;
                $d = $b + $c;
              } until ($p != 0 &amp;&amp; $d != 0);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              Context()->noreduce('(-x)+y', '(-x)-y');
              $left = Formula("$m $x + $d + $n $x")->reduce;
              $right = Formula("$b + $p $x + $c")->reduce;
              Context("FiniteSolutionSets")->variables->are($x => 'Real');
              #$solution = String("no real solutions")->cmp(typeMatch => Formula("{1}"));
              $solution = OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"));
              $leftsol[0] = Formula("($m+$n) $x + $d")->reduce;
              $rightsol[0] = Formula("$p $x + ($b + $c)")->reduce;
              $leftsol[1] = Formula("$d")->reduce;
              $rightsol[1] = Formula("($b + $c)")->reduce;
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                We try to use the standard steps for solving an equation:
                <md>
                  <mrow><var name="$left"/> \amp= <var name="$right"/></mrow>
                  <mrow><var name="$leftsol[0]"/> \amp= <var name="$rightsol[0]"/></mrow>
                  <mrow><var name="$leftsol[1]"/> \amp= <var name="$rightsol[1]"/></mrow>
                </md>
                This is an outright true equation, so all real numbers are solutions. The solution
                set is <m>(-\infty,\infty)</m>, which we can write as <m>\mathbb{R}</m>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="solve-special-with-like-terms-copy">
          <webwork copy="webwork-solve-special-with-like-terms"/>
        </exercise>
        <exercise label="solve-special-with-like-terms2">
          <webwork xml:id="webwork-solve-special-with-like-terms2">
            <pg-code>
              do {
                ($m, $n, $b, $c, $d) = random_subset(5,-9..-1,1..9);
                $p = $m + $n;
              } until ($p != 0 &amp;&amp; $b + $c != $d);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              Context()->noreduce('(-x)+y', '(-x)-y');
              $left = Formula("$m $x + $d + $n $x")->reduce;
              $right = Formula("$b + $p $x + $c")->reduce;
              Context("FiniteSolutionSets");
              $solution = String("no real solutions")->cmp(typeMatch => Formula("{1}"));
              #$solution = OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="solve-special-with-like-terms2-copy">
          <webwork copy="webwork-solve-special-with-like-terms2"/>
        </exercise>
        <exercise label="solve-special-with-distribution">
          <webwork xml:id="webwork-solve-special-with-distribution">
            <pg-code>
              ($m, $b, $c) = random_subset(3,-9..-1,1..9);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              Context()->noreduce('(-x)+y', '(-x)-y');
              $left = Formula("$m ($x + $b)")->reduce;
              $right = Formula("$m ($x + $c)")->reduce;
              Context("FiniteSolutionSets");
              $solution = String("no real solutions")->cmp(typeMatch => Formula("{1}"));
              #$solution = OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="solve-special-with-distribution-copy">
          <webwork copy="webwork-solve-special-with-distribution"/>
        </exercise>
        <exercise label="solve-special-with-simplification">
          <webwork xml:id="webwork-solve-special-with-simplification">
            <pg-code>
              do {
                ($m, $p, $q) = random_subset(3,-5..-2,2..5);
                $n = $m - $p*$q;
                ($b, $c, $e) = random_subset(3,-8..-1,1..8);
                $d = $m*$b - $c - $p*$e + list_random(-3..3,(0)x5);
              } until ($n != 0 &amp;&amp; $d != 0);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              Context()->noreduce('(-x)+y', '(-x)-y');
              $left = Formula("$m($x + $b) - ($n $x + $c)")->reduce;
              $right = Formula("$d + $p($e + $q $x)")->reduce;
              Context("FiniteSolutionSets");
              $solution = ($d == $m*$b - $c - $p*$e)
                ? OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"))
                : String("no real solutions")->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="solve-special-with-simplification-copy">
          <webwork copy="webwork-solve-special-with-simplification"/>
        </exercise>
        <exercise label="solve-special-with-simplification2">
          <webwork xml:id="webwork-solve-special-with-simplification2">
            <pg-code>
              do {
                ($m, $n, $q) = random_subset(3,-5..-2,2..5);
                $p = $m*$n + $q;
                ($c, $d) = random_subset(2,1..9);
                $b = -$d - $m*$c + list_random(-3..3,(0)x5);
              } until ($p != 0 &amp;&amp; $d != 0);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              Context()->noreduce('(-x)+y', '(-x)-y');
              $left = Formula("$b + $m($c + $n $x)")->reduce;
              $right = Formula("$p $x - ($d + $q $x)")->reduce;
              Context("FiniteSolutionSets");
              $solution = ($b == -$d - $m*$c)
                ? OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"))
                : String("no real solutions")->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="solve-special-with-simplification2-copy">
          <webwork copy="webwork-solve-special-with-simplification2"/>
        </exercise>
        <exercise label="solve-mxequalsmxplusb-fraction">
          <webwork xml:id="webwork-solve-mxequalsmxplusb-fraction">
            <pg-code>
              Context("Fraction");
              $m = Fraction(random_coprime([1..9], [2..9]));
              $b = non_zero_random(-9,9);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              $left = Formula("$m $x");
              $right = Formula("$m $x + $b")->reduce;
              Context("FiniteSolutionSets");
              $solution = String("no real solutions")->cmp(typeMatch => Formula("{1}"));
              #$solution = OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                We try to use the standard steps for solving an equation:
                <md>
                  <mrow><var name="$left"/> \amp= <var name="$right"/></mrow>
                  <mrow>0 \amp= <var name="$b"/></mrow>
                </md>
                This is an outright false equation, so there are no solutions. We could write the
                solution set as <m>\{\}</m> or <m>\emptyset</m>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="solve-mxequalsmxplusb-fraction-copy">
          <webwork copy="webwork-solve-mxequalsmxplusb-fraction"/>
        </exercise>
        <exercise label="solve-special-with-like-terms-fraction">
          <webwork xml:id="webwork-solve-special-with-like-terms-fraction">
            <pg-code>
              @den = random_coprime([2..9],[2..9]);
              Context("Fraction");
              $m = Fraction(random_coprime([1..9], [$den[0]]));
              $n = Fraction(random_coprime([1..9], [$den[1]]));
              $p = $m + $n;
              do {
                ($b, $c) = random_subset(2,-9..-1,1..9);
                $d = $b + $c;
              } until ($d != 0);
              $x = list_random('a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context()->variables->are($x => 'Real');
              Context()->noreduce('(-x)+y', '(-x)-y');
              $left = Formula("$m $x + $d + $n $x")->reduce;
              $right = Formula("$b + $p $x + $c")->reduce;
              Context("FiniteSolutionSets");
              #$solution = String("no real solutions")->cmp(typeMatch => Formula("{1}"));
              $solution = OneOf(Compute("R"), String("infinitely many solutions"))->cmp(typeMatch => Formula("{1}"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solution" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
