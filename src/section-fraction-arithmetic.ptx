      <exercisegroup cols="3">
        <title>Multiplying/Dividing Fractions</title>
        <introduction>
          <p>
            Multiply or divide the fractions.
          </p>
        </introduction>

        <exercise label="multiply-fractions-small-no-reduction">
          <webwork xml:id="webwork-multiply-fractions-small-no-reduction">
            <pg-code>
              ($n[0], $d[0], $n[1], $d[1]) = random_pairwise_coprime([1 .. 9], [2 .. 9], [1 .. 9], [2 .. 9]);
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              @f = map {Fraction($n[$_], $d[$_])} (0, 1);
              $ans = Fraction($n[0]*$n[1], $d[0]*$d[1])->cmp(studentsMustReduceFractions => 1);
            </pg-code>
            <statement>
              <p>
                <m>\displaystyle <var name="$f[0]"/>\cdot <var name="$f[1]"/></m>
              </p>
              <p>
                <var name="$ans" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="multiply-fractions-small-no-reduction-2">
          <webwork copy="webwork-multiply-fractions-small-no-reduction"/>
