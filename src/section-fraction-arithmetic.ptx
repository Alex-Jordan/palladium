              $d = list_random(3 .. 10);
              ($d, $n) = random_coprime([$d], [$d+1, 2*$d - 1]);
              $frac = Fraction($n, $d);
              $xmin = -3/$d;
              $xmax = 2+3/$d;
              $inc = $xmin + 1/$d;
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                      numberline,
                      xmin=$xmin,
                      xmax=$xmax,
                      xtick={0,1,2},
                      minor xtick={$xmin,$inc,...,$xmax},
                    ]
                    \addplot[soliddot] coordinates {($frac, 0)};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$frac" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="identify-fraction-on-numberline-3">
