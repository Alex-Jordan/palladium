              $min = $max - 1;
              ($d, $n) = random_coprime([$d], [($max - 1)*$d + 1, $max*$d - 1]);
              $frac = Fraction(-$n, $d);
              $xmax = -(($max - 1) - 3/$d);
              $xmin = -($max + 3/$d);
              $inc = $xmin + 1/$d;
