                      xmin=$xmin,
                      xmax=$xmax,
                      xtick={-$max,-$min},
                      minor xtick={$xmin,$inc,...,$xmax},
                      after end axis/.code=,
                    ]
                    \addplot[soliddot] coordinates {($frac, 0)};
                    \end{axis}
                  \end{tikzpicture}
