              Parser::Number::NoDecimals;
              $d = list_random(3 .. 6);
              $max = random(6 .. 9);
              $min = $max - 1;
              ($d, $n) = random_coprime([$d], [($max - 1)*$d + 1, $max*$d - 1]);
              $frac = Fraction($n, $d);
              $xmin = ($max - 1) - 3/$d;
              $xmax = $max + 3/$d;
              $inc = $xmin + 1/$d;
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                      numberline,
                      xmin=$xmin,
                      xmax=$xmax,
                      xtick={$min,$max},
                      minor xtick={$xmin,$inc,...,$xmax},
                      after end axis/.code=,
                    ]
                    \addplot[soliddot] coordinates {($frac, 0)};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$frac" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="identify-fraction-on-numberline-4">
