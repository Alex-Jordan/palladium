        <exercise label="multiply-three-fractions-no-reductions">
          <webwork xml:id="webwork-multiply-three-fractions-no-reductions">
            <pg-code>
              ($n[0], $d[0], $n[1], $d[1], $n[2], $d[2]) = random_pairwise_coprime([1 .. 13], [2 .. 13], [1 .. 13], [2 .. 13], [1 .. 13], [2 .. 13]);
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              @f = map {Fraction($n[$_], $d[$_])} (0, 1, 2);
