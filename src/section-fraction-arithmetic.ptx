      <exercisegroup cols="3">
        <title>Adding/Subtracting Fractions</title>
        <introduction>
          <p>
            Add or subtract the fractions.
          </p>
        </introduction>

        <exercise label="add-fractions-same-denom-no-reduction">
          <webwork xml:id="webwork-add-fractions-same-denom-no-reduction">
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              do {
                ($n[0], $d[0]) = random_pairwise_coprime([1 .. 9], [2 .. 9]);
                ($n[1], $d[1]) = random_pairwise_coprime([1 .. 9], [$d[0]]);
              } until (gcd($n[0] + $n[1], $d[0]) == 1);
              @f = map {Fraction($n[$_], $d[$_])} (0, 1);
              $ans = Fraction($f[0] + $f[1])->cmp(studentsMustReduceFractions => 1);
            </pg-code>
            <statement>
              <p>
                <m>\displaystyle <var name="$f[0]"/> + <var name="$f[1]"/></m>
              </p>
              <p>
                <var name="$ans" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

