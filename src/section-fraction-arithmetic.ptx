      <exercisegroup cols="3">
        <title>Reducing Fractions</title>
        <introduction>
          <p>
            Reduce the fraction.
          </p>
        </introduction>

        <exercise label="reduce-small-fraction-small-factor">
          <webwork xml:id="webwork-reduce-small-fraction-small-factor">
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              $f = Fraction(random_coprime([1], [2 .. 9]));
              $k = random(2 .. 5);
              $n = $k*$f->num;
              $d = $k*$f->den;
              $f = $f->cmp(studentsMustReduceFractions => 1);
            </pg-code>
            <statement>
              <p>
                <m>\dfrac{<var name="$n"/>}{<var name="$d"/>}</m>
              </p>
              <p>
                <var name="$f" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

