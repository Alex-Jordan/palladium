        </exercise>

        <exercise label="subtract-add-three-fractions">
          <webwork xml:id="webwork-subtract-add-three-fractions">
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              do {
                ($n[0], $d[0], $n[1], $d[1], $n[2], $d[2]) = random_subset(6, [2 .. 9]);
                @f = map {Fraction($n[$_], $d[$_])} (0, 1, 2);
              } until ($f[0]->den != 1 &amp;&amp; $f[1]->den != 1 &amp;&amp; $f[2]->den != 1);
              $ans = Fraction($f[0] - $f[1] + $f[2])->cmp(studentsMustReduceFractions => 1);
            </pg-code>
            <statement>
              <p>
                <m>\displaystyle <var name="$f[0]"/> - <var name="$f[1]"/> + <var name="$f[2]"/></m>
              </p>
              <p>
                <var name="$ans" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="subtract-add-three-fractions-2">
          <webwork copy="webwork-subtract-add-three-fractions"/>
        </exercise>

        <exercise label="add-subtract-three-fractions">
          <webwork xml:id="webwork-add-subtract-three-fractions">
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              do {
                ($n[0], $d[0], $n[1], $d[1], $n[2], $d[2]) = random_subset(6, [2 .. 9]);
                @f = map {Fraction($n[$_], $d[$_])} (0, 1, 2);
              } until ($f[0]->den != 1 &amp;&amp; $f[1]->den != 1 &amp;&amp; $f[2]->den != 1);
              $ans = Fraction($f[0] - $f[1] + $f[2])->cmp(studentsMustReduceFractions => 1);
            </pg-code>
            <statement>
              <p>
                <m>\displaystyle <var name="$f[0]"/> - <var name="$f[1]"/> + <var name="$f[2]"/></m>
              </p>
              <p>
                <var name="$ans" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="add-subtract-three-fractions-2">
          <webwork copy="webwork-add-subtract-three-fractions"/>
        </exercise>
      </exercisegroup>

      <exercisegroup cols="3">
        <introduction>
          <p>
            Convert the mixed number to an improper fraction
          </p>
        </introduction>
      
        <exercise label="convert-mixed-numer-small">
          <webwork xml:id="webwork-convert-mixed-numer-small">
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              ($n[0], $d[0]) = random_pairwise_coprime([1 .. 9], [2 .. 9]);
              $n = list_random(1 .. 9);
              @f = map {Fraction($n[$_], $d[$_])} (0);
              $ans = Fraction($n + $f[0])->cmp(studentsMustReduceFractions => 1);
            </pg-code>
            <statement>
              <p>
                <m>\displaystyle <var name="$n"/>\,<var name="$f[0]"/></m>
              </p>
              <p>
                <var name="$ans" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="convert-mixed-numer-small-2">
          <webwork copy="webwork-convert-mixed-numer-small"/>
        </exercise>
      
        <exercise label="convert-mixed-numer-medium">
          <webwork xml:id="webwork-convert-mixed-numer-medium">
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              ($n[0], $d[0]) = random_pairwise_coprime([1 .. 9], [11 .. 19]);
              $n = list_random(1 .. 9);
              @f = map {Fraction($n[$_], $d[$_])} (0);
              $ans = Fraction($n + $f[0])->cmp(studentsMustReduceFractions => 1);
            </pg-code>
            <statement>
              <p>
                <m>\displaystyle <var name="$n"/>\,<var name="$f[0]"/></m>
              </p>
              <p>
                <var name="$ans" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="convert-mixed-numer-medium-2">
          <webwork copy="webwork-convert-mixed-numer-medium"/>
        </exercise>

        <exercise label="convert-mixed-numer-large">
          <webwork xml:id="webwork-convert-mixed-numer-large">
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              ($n[0], $d[0]) = random_pairwise_coprime([1 .. 9], [2 .. 9]);
              $n = list_random(11 .. 19);
              @f = map {Fraction($n[$_], $d[$_])} (0);
              $ans = Fraction($n + $f[0])->cmp(studentsMustReduceFractions => 1);
            </pg-code>
            <statement>
              <p>
                <m>\displaystyle <var name="$n"/>\,<var name="$f[0]"/></m>
              </p>
              <p>
                <var name="$ans" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="convert-mixed-numer-large-2">
          <webwork copy="webwork-convert-mixed-numer-large"/>
        </exercise>
      </exercisegroup>
    </subexercises>

