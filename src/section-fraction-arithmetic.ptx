    <subexercises>
      <title>Challenge</title>
      <exercise>
        <webwork>
          <pg-code>
            Context("Numeric");
            Context()->variables->are(a => 'Real');
            ($p, $q) = random_subset(2, 1 .. 9);
            $numerator = $p + $q;
            $left = Formula("$p/a");
            $right = Formula("$q/a");
            $expression = $left + $right;
            Context("Form")->variables->are(a => 'Real');
            $answer = Formula("$numerator/a");
          </pg-code>
          <statement>
            <p>
              Given that <m>a\neq0</m>, simplify <m>\displaystyle{}<var name="$expression"/></m>.
            </p>
            <p>
              <var name="$answer" width="10" />
            </p>
          </statement>
          <solution>
            <p>
              Since the fractions have the same denominator,
              we can just add numerators and keep that denominator.
              <md>
                <mrow><var name="$expression"/> \amp= \frac{<var name="$p"/>+<var name="$q"/>}{a}</mrow>
                <mrow>\amp = <var name="$answer" /></mrow>
              </md>
            </p>
          </solution>
        </webwork>
      </exercise>

      <exercise>
        <webwork>
          <pg-code>
            Context("Numeric");
            Context()->variables->are(a => 'Real');
            $p = random(1, 9);
            $q = random(1, 9, 2);
            $p2 = 2*$p;
            $num = (2*$p + $q);
            $left = Formula("$p/a");
            $right = Formula("$q/(2a)");
            $expression = $left + $right;
            Context("Form")->variables->are(a => 'Real');
            $answer = Formula("$num/(2a)");
          </pg-code>
          <statement>
            <p>
              Given that <m>a\neq0</m>, simplify <m>\displaystyle{}<var name="$expression"/></m>.
            </p>
            <p>
              <var name="$answer" width="10" />
            </p>
          </statement>
          <solution>
            <p>
              Since the fractions don't have the same denominator,
              we have to make them have like denominators.
              Multiply the first fraction by <m>\frac{2}{2}</m>.
              <md>
                <mrow><var name="$expression"/> \amp = <var name="$left"/>\cdot \frac{2}{2} + <var name="$right"/></mrow>
                <mrow>\amp = \frac{<var name="$p2"/>}{2a} + <var name="$right"/></mrow>
                <mrow>\amp = <var name="$answer" /></mrow>
              </md>
            </p>
          </solution>
        </webwork>
      </exercise>

      <exercise>
        <webwork>
          <pg-code>
            Context("Numeric");
            Context()->variables->are(a => 'Real');
            $p = random(1, 9);
            $q = list_random(1 .. 4, 6 .. 9);
            $numerator = (5*$p-$q);
            $left = Formula("$p/a");
            $right = Formula("$q/(5a)");
            $expression = $left - $right;
            $p5 = 5*$p;
            Context("Form")->variables->are(a => 'Real');
            $answer = Formula("$numerator/(5a)");
          </pg-code>
          <statement>
            <p>
              Given that <m>a\neq0</m>, simplify <m>\displaystyle{}<var name="$expression"/></m>.
            </p>
            <p>
              <var name="$answer" width="10" />
            </p>
          </statement>
          <solution>
            <p>
              Since the fractions don't have the same denominator,
              we have to make them have like denominators.
              Multiply the first fraction by <m>\frac{5}{5}</m>.
              <md>
                <mrow><var name="$expression"/> \amp = <var name="$left"/>\cdot \frac{5}{5} - <var name="$right"/></mrow>
                <mrow>\amp = \frac{<var name="$p5"/>}{5a} - <var name="$right"/></mrow>
                <mrow>\amp = <var name="$answer" /></mrow>
              </md>
            </p>
          </solution>
        </webwork>
      </exercise>
    </subexercises>
  </exercises>
</section>

