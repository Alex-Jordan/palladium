      <exercisegroup cols="2">
        <title>Building Fractions</title>
        <introduction>
          <p>
            Find an equivalent fraction with the given denominator.
          </p>
        </introduction>

        <exercise label="build-small-fraction-small-factor">
          <webwork xml:id="webwork-build-small-fraction-small-factor">
            <pg-code>
              Context("Fraction");
              $f = Fraction(random_coprime([1], [2 .. 9]));
              $k = random(2 .. 5);
              $num = $f->num;
              $den = $f->den;
              $n = $k*$num;
              $d = $k*$den;
              Context("Form");
              $ans = Formula("$n/$d");
            </pg-code>
            <statement>
              <p>
                <m>\dfrac{<var name="$num"/>}{<var name="$den"/>}</m> with denominator <m><var name="$d"/></m>
              </p>
              <p>
                <var name="$ans" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="build-small-fraction-small-factor-2">
          <webwork copy="webwork-build-small-fraction-small-factor"/>
