      <exercisegroup>
        <introduction>
          <p>
            What fraction is represented on the numberline?
          </p>
        </introduction>

        <exercise label="identify-fraction-on-numberline-1">
          <webwork>
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
              Parser::Number::NoDecimals;
              $d = list_random(3 .. 10);
              ($d, $n) = random_coprime([$d], [2, $d - 1]);
              $frac = Fraction($n, $d);
              $xmin = -3/$d;
              $xmax = 1+3/$d;
              $inc = $xmin + 1/$d;
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                      numberline,
                      xmin=$xmin,
                      xmax=$xmax,
                      xtick={0,1},
                      minor xtick={$xmin,$inc,...,$xmax},
                    ]
                    \addplot[soliddot] coordinates {($frac, 0)};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$frac" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>

        <exercise label="identify-fraction-on-numberline-2">
          <webwork>
            <pg-code>
              Context("LimitedFraction")->flags->set(
                  allowMixedNumbers => 0,
                  reduceConstants => 1,
                  showMixedNumbers => 0
              );
