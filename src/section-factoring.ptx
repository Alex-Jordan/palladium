        <exercise label="factor-diff-sq-one-gcfx">
          <webwork xml:id="webwork-factor-diff-sq-one-gcfx">
            <pg-code>
              $r = 1;
              $g = list_random(2..9);
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("$g $var^3 - $g*$r**2 $var")->reduce;
              $answer = Compute("$g $var ($var + $r)($var - $r)");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-diff-sq-one-gcfx-copy">
          <webwork copy="webwork-factor-diff-sq-one-gcfx"/>
        </exercise>
        <exercise label="factor-pst-one-gcf">
          <webwork xml:id="webwork-factor-pst-one-gcf">
            <pg-code>
              $r = 1;
              $g = list_random(2..9);
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("$g$var^2 + 2*$g $var + $g")->reduce;
              $answer = Compute("$g ($var + 1)^2");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-pst-one-gcf-copy">
          <webwork copy="webwork-factor-pst-one-gcf"/>
        </exercise>
        <exercise label="factor-pst-med-gcf">
          <webwork xml:id="webwork-factor-pst-med-gcf">
            <pg-code>
              $r = list_random(2..10);
              $g = list_random(2..9);
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("$g $var^2 + 2*$r*$g $var + $g*$r**2")->reduce;
              $answer = Compute("$g ($var + $r)^2");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-pst-med-gcf-copy">
          <webwork copy="webwork-factor-pst-med-gcf"/>
        </exercise>
        <exercise label="factor-pst-med-lc-neg-gcf">
          <webwork xml:id="webwork-factor-pst-med-lc-neg-gcf">
            <pg-code>
              ($a, $b) = random_coprime([2..9],[2..9]);
              $g = list_random(2..9);
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("$g*$a**2 $var^2 - 2*$a*$b*$g $var + $g*$b**2")->reduce;
              $answer = Compute("$g ($a $var - $b)^2");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-pst-med-lc-neg-gcf-copy">
          <webwork copy="webwork-factor-pst-med-lc-neg-gcf"/>
        </exercise>
      </exercisegroup>
    </subexercises>

    <subexercises>
      <title>Challenge</title>
      <exercise>
        <!-- Kara's challenge problem -->
        <webwork>
          <pg-code>
            $c = list_random(4, 6, 8, 9, 10, 12, 14, 15, 16, 18, 20)*random(-1, 1, 2);
            $absc = abs($c);
            @smalls = ();
            @bigs = ();
            for $i (1 .. floor(sqrt($absc))) {
              if ($absc % $i == 0) {
                push(@smalls, $i);
                push(@smalls, -$i);
                push(@bigs, $c/$i);
                push(@bigs, -$c/$i);
              }
            }
            @b = ();
            $n = scalar(@smalls);
            for $j (1 .. $n) {
              push(@b, $smalls[$j - 1] + $bigs[$j - 1]);
            }
            $answer = List(@b);
            Context()->variables->add(b => 'Real');
            $expression = Formula("x^2 + bx + $c")->reduce;
          </pg-code>
          <statement>
            <p>
              What integers can go in the place of <m>b</m> so that the quadratic expression
              <m><var name="$expression"/></m> is factorable?
            </p>
            <instruction>
              Enter the solutions as a comma-separated list.
            </instruction>
            <p>
              <var name="$answer" width="30"/>
            </p>
          </statement>
          <hint>
            <p>
              There are <var name="$n"/> answers.
            </p>
          </hint>
          <solution>
            <p>
              Think about all of ways to factor <var name="$c"/>. The list of possible
              <m>b</m>-values is <var name="$answer"/>.
            </p>
          </solution>
        </webwork>
      </exercise>
    </subexercises>
  </exercises>
</section>