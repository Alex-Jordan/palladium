        <exercise label="factor-gcf-trinomial-higher">
          <webwork xml:id="webwork-factor-gcf-trinomial-higher">
            <pg-code>
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              do {
                ($a, $b, $c) = random_coprime([1 .. 9], [1 .. 9], [1 .. 9]);
              } until (($a > 1 || $b > 1 || $c > 1) &amp;&amp; sqrt(abs($b**2 - 4*$a*$c)) !~ /\d*/);
              $g = list_random(2 .. 9);
              ($ga, $gb, $gc) = map {$_*$g} ($a, $b, $c);
              $f = Compute("$ga $var^3 + $gb $var^2 + $gc $var");
              $answer = Compute("$g $var($a $var^2 + $b $var + $c)");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m> 
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
