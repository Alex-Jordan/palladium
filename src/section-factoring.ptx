      <exercisegroup cols="2">
        <title>Factoring out the Greatest Common Factor</title>
        <introduction>
          <p>
            Factor the given polynomial.
          </p>
        </introduction>
        <exercise label="factor-mxplusm">
          <webwork xml:id="webwork-factor-mxplusm">
            <pg-code>
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $m = list_random(2 .. 9);
              $f = Compute("$m $var + $m");
              $answer = Compute("$m($var + 1)");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m> 
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
