      <exercisegroup cols="3">
        <title>Factoring Monic Quadratic Trinomials</title>
        <introduction>
          <p>
            Factor the given polynomial.
          </p>
        </introduction>
        <exercise label="factor-mqt-neg-roots">
          <webwork xml:id="webwork-factor-mqt-neg-roots">
            <pg-code>
              @r = random_subset(2, 2..9);
              $b = $r[0] + $r[1];
              $c = $r[0]*$r[1];
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("$var^2 + $b $var + $c")->reduce;
              $answer = Compute("($var + $r[0])($var + $r[1])");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
