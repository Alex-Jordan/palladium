        <exercise label="factor-gcf-trinomial">
          <webwork xml:id="webwork-factor-gcf-trinomial">
            <pg-code>
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              do {
                ($a, $b, $c) = random_coprime([1 .. 9], [1 .. 9], [1 .. 9]);
              } until (($a > 1 || $b > 1 || $c > 1) &amp;&amp; sqrt(abs($b**2 - 4*$a*$c)) !~ /\d*/);
              $g = list_random(2 .. 9);
              ($ga, $gb, $gc) = map {$_*$g} ($a, $b, $c);
              $f = Compute("$ga $var^2 + $gb $var + $gc");
              $answer = Compute("$g($a $var^2 + $b $var + $c)");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m> 
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-gcf-trinomial-copy">
          <webwork copy="webwork-factor-gcf-trinomial"/>
        </exercise>
