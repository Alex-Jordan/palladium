              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              ($m, $b) = random_coprime([2 .. 9], [2, 3, 5, 6, 7, 8]);
              $b *= list_random(-1, 1);
              $f = Compute("$m $var^2 + $b");
              $answer = Compute("$m $var^2 + $b");
            </pg-code>
            <statement>
              <p>
