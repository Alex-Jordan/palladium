              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("-$g $var^2 + $b $var - $c")->reduce;
              $answer = Compute("-$g ($var - $r[0])($var - $r[1])");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-mqt-pos-roots-one-with-neg-gcf-copy">
          <webwork copy="webwork-factor-mqt-pos-roots-one-with-neg-gcf"/>
        </exercise>
        <exercise label="factor-mqt-lg-root-neg-with-neg-gcf">
          <webwork xml:id="webwork-factor-mqt-lg-root-neg-with-neg-gcf">
            <pg-code>
              @r = num_sort(random_subset(2, 2..9));
              $g = list_random(2..9);
              $b = $g*(-$r[0] + $r[1]);
              $c = $g*$r[0]*$r[1];
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("-$g $var^2 - $b $var + $c")->reduce;
              $answer = Compute("-$g ($var - $r[0])($var + $r[1])");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-mqt-lg-root-neg-with-neg-gcf-copy">
          <webwork copy="webwork-factor-mqt-lg-root-neg-with-neg-gcf"/>
        </exercise>
        <exercise label="factor-with-decimals">
          <webwork xml:id="webwork-factor-with-decimals">
            <pg-code>
              @r = random_subset(2, map {$_/10} (1..9));
              $b = -$r[0] - $r[1];
              $c = $r[0]*$r[1];
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              Context()->flags->remove("NumberCheck");
              $f = Compute("$var^2 + $b $var + $c")->reduce;
              $answer = Compute("($var - $r[0])($var - $r[1])");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-with-decimals-copy">
          <webwork copy="webwork-factor-with-decimals"/>
        </exercise>
        <exercise label="factor-with-fractions">
          <webwork xml:id="webwork-factor-with-fractions">
            <pg-code>
              Context("Fraction");
              @r = (1, Fraction(random_coprime([1..9], [2..9])));
              $b = $r[0] + $r[1];
              $c = $r[0]*$r[1];
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("$var^2 + $b $var + $c");
              $answer = Compute("($var + $r[0])($var + $r[1])");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-with-fractions-copy">
          <webwork copy="webwork-factor-with-fractions"/>
        </exercise>
      </exercisegroup>

      <exercisegroup cols="3">
        <title>Factoring Special Patterns</title>
        <introduction>
          <p>
            Factor the polynomial. It is important to try to recognize a special pattern can be
            used. If you factor these using another method, you are missing the opportunity to
            practice learning the special patterns.
          </p>
        </introduction>
        <exercise label="factor-diff-sq-one">
          <webwork xml:id="webwork-factor-diff-sq-one">
            <pg-code>
              $r = 1;
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context("Form")->variables->are($var=>'Real');
              $f = Compute("$var^2 - $r**2")->reduce;
              $answer = Compute("($var + $r)($var - $r)");
            </pg-code>
            <statement>
              <p>
                <m><var name="$f"/></m>
              </p>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="factor-diff-sq-one-copy">
          <webwork copy="webwork-factor-diff-sq-one"/>
        </exercise>
