        <exercise label="find-gcf-nontriv-three-terms-higher">
          <webwork xml:id="webwork-find-gcf-nontriv-three-terms-higher">
            <pg-code>
              @ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
              $var = list_random(@ORCCA_variables);
              Context()->variables->are($var=>'Real');
              ($a, $b, $c) = random_coprime([2 .. 9], [2 .. 9], [2 .. 9]);
              ($m, $n, $k) = random_subset(3, 2 .. 9);
              $min = min($m, $n, $k);
              $g = list_random(2 .. 9);
              $answer = OneOf(Compute("$g $var^$min"), Compute("-$g $var^$min"));
              @terms = random_subset(3, Compute("$a*$g $var^$m"), Compute("$b*$g $var^$n"), Compute("$c*$g $var^$k"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$terms[0]"/>, <var name="$terms[1]"/>, <var name="$terms[2]"/></m> 
              </p>
              <p>
                <var name="$answer" width="6"/>
              </p>
            </statement>
          </webwork>
        </exercise>
