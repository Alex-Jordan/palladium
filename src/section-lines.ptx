      <exercisegroup cols="3">
        <title>Converting Point-Slope to Slope-Intercept</title>
        <introduction>
          <p>
            Change the given point-slope equation to slope-intercept form.
          </p>
        </introduction>
        <exercise label="convert-point-slope-to-slope-intercept-pos-int">
          <webwork xml:id="webwork-convert-point-slope-to-slope-intercept-pos-int">
            <pg-code>
              ($m,$h,$k) = random_subset(3,2..9);
              Context()->noreduce('(-x)-y','(-x)+y');
              $f = Formula("$m(x-$h)+$k")->reduce;
              $b = $f->eval(x => 0);
              Context("Form")->variables->add(y=>'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $si = Formula("y=$m x + $b")->reduce;
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <p>
                <var name="$si" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="convert-point-slope-to-slope-intercept-pos-int-copy">
          <webwork copy="webwork-convert-point-slope-to-slope-intercept-pos-int"/>
        </exercise>
