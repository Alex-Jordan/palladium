      <exercisegroup cols="4">
        <title>Graph Equations</title>
        <introduction>
          <p>
            Graph the equation.
          </p>
        </introduction>
        <exercise label="plot-slope-intercept-pos-int">
          <webwork xml:id="webwork-plot-slope-intercept-pos-int">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              ($m, $b) = random_subset(2, 2..5);
              $b = list_random($b, -$b);
              Context("Numeric")->variables->add(y=>'Real');
              parser::Assignment->Allow;
              $equation = Formula("y = $m x + $b")->reduce;
              $gt = GraphTool("{line, solid, (0, $b), (1, $b+$m)}")->with(
                bBox => [-11, 11, 11, -11],
                availableTools => [ "LineTool" ],
                showInStatic => 0,
              );
            </pg-code>
            <statement>
              <p>
                <m><var name="$equation"/></m>
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="plot-slope-intercept-pos-int-copy">
          <webwork copy="webwork-plot-slope-intercept-pos-int"/>
        </exercise>
        <exercise label="plot-slope-intercept-neg-int">
          <webwork xml:id="webwork-plot-slope-intercept-neg-int">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              ($m, $b) = random_subset(2, 2..5);
              $b = list_random($b, -$b);
              $m = -$m;
              Context("Numeric")->variables->add(y=>'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $equation = Formula("y = $m x + $b")->reduce;
              $gt = GraphTool("{line, solid, (0, $b), (1, $b + $m)}")->with(
                bBox => [-11, 11, 11, -11],
                availableTools => [ "LineTool" ],
                showInStatic => 0,
              );
              @domain = num_sort(-10,10,(10 - $b)/$m,(-10 - $b)/$m);
              ($l,$r) = (@domain)[1,2];
            </pg-code>
            <statement>
              <p>
                <m><var name="$equation"/></m>
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
            <solution>
              <p>
                Start the plot at the <m>y</m>-intercept <m>(0,<var name="$b"/>)</m>. Then use slope
                triangles with slope <m><var name="$m"/></m> to extend a line in two directions.
              </p>
              <image width="47%">
                <shortdescription></shortdescription>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        width=0.47\orccaprintwidth,
                        xmin=-10,
                        xmax=10,
                        ymin=-10,
                        ymax=10,
                        xtick={-10,-5,5,10},
                        ytick={-10,-5,5,10},
                        minor xtick={-10,...,10},
                        minor ytick={-10,...,10},
                      ]
                      \addplot+[domain=$l:$r] {$m*x + $b};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
            </solution>
          </webwork>
        </exercise>
        <exercise label="plot-slope-intercept-neg-int-copy">
          <webwork copy="webwork-plot-slope-intercept-neg-int"/>
        </exercise>
