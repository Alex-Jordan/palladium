      <exercisegroup cols="2">
        <title>Construct Point-Slope Form</title>
        <introduction>
          <p>
            A line passes through the given point with the given slope. Find an equation for the
            line in point-slope form using the given point.
          </p>
        </introduction>
        <exercise label="write-point-slope-pos-int">
          <webwork xml:id="webwork-write-point-slope-pos-int">
            <pg-code>
              ($m,$h,$k) = random_subset(3, 2..9);
              Context("Form")->variables->add(y=>'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $eq = Formula("y=$m(x - $h) + $k")->reduce;
              $p = Point($h,$k);
            </pg-code>
            <statement>
              <p>
                through <m><var name="$p"/></m> with slope <m><var name="$m"/></m>
              </p>
              <p>
                <var name="$eq" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="write-point-slope-pos-int-copy">
          <webwork copy="webwork-write-point-slope-pos-int"/>
        </exercise>
        <exercise label="write-point-slope-neg-int">
          <webwork xml:id="webwork-write-point-slope-neg-int">
            <pg-code>
              ($m,$h,$k) = random_subset(3, 2..9);
              $h = -$h;
              $k = -$k;
              Context("Form")->variables->add(y=>'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $eq = Formula("y=$m(x - $h) + $k")->reduce;
              $p = Point($h,$k);
            </pg-code>
            <statement>
              <p>
                through <m><var name="$p"/></m> with slope <m><var name="$m"/></m>
              </p>
              <p>
                <var name="$eq" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="write-point-slope-neg-int-copy">
          <webwork copy="webwork-write-point-slope-neg-int"/>
        </exercise>
        <exercise label="write-point-slope-mixed-int-decimal-slope">
          <webwork xml:id="webwork-write-point-slope-mixed-int-decimal-slope">
            <pg-code>
              $m = random(-9,9) + random(0.1,0.9,0.1);
              ($h,$k) = random_subset(2, 2..9);
              if (random(0,1)) {
                $h = -$h;
              } else {
                $k = -$k;
              }
              Context("Form")->variables->add(y => 'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              Context()->flags->remove("NumberCheck");
              parser::Assignment->Allow;
              $eq = Formula("y=$m(x - $h) + $k")->reduce;
              $p = Point($h,$k);
            </pg-code>
            <statement>
              <p>
                through <m><var name="$p"/></m> with slope <m><var name="$m"/></m>
              </p>
              <p>
                <var name="$eq" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
