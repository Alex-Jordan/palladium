      <exercisegroup cols="3">
        <title>Point-Slope Form from a Graph</title>
        <introduction>
          <p>
            Determine a point-slope form line equation for the given line.
          </p>
        </introduction>
        <exercise label="determine-point-slope-form-from-graph">
          <webwork xml:id="webwork-determine-point-slope-form-from-graph">
            <pg-code>
              $xmin = -7;
              $xmax = 7;
              $ymin = -7;
              $ymax = 7;
              Context("Fraction");
              do {
                do {
                  ($n,$d) = random_coprime([2..9],[2..9]);
                  $m = Fraction($n/$d);
                  ($h,$k) = random_subset(2,-5..-1,1..5);
                  $f = Formula("$m(x - $h) + $k")->reduce;
                  $b = $f->eval(x => 0);
                } until ($b != 0);
                $xtop = ($ymax - $k)/$m + $h;
                $xbot = ($ymin - $k)/$m + $h;
                ($start, $stop) = (num_sort($xmin,$xmax,$xtop,$xbot))[1,2];
                @x = ();
                @y = ();
                $a = ($start &lt; 0) ? int(Real($start)) : int(Real($start)) + 1;
                $b = ($stop &lt; 0) ? int(Real($stop)) - 1 : int(Real($stop));
                for ($a .. $b) {
                  if ($f->eval(x => $_) == int($f->eval(x => $_))) {
                    push @x, $_;
                    push @y, $f->eval(x => $_);
                  }
                }
              } until (scalar @x >= 2);
              @fs = map {Formula("$m*(x - $x[$_]) + $y[$_]")->reduce} (0..$#x);

              package my::OneOf;
              our @ISA = ('parser::OneOf');
              sub cmp_compare {
                my ($self,$other,$ans) = @_;
                foreach $answer (@{$self->{data}}) {
                  if ($answer->typeMatch($other)) {
                    my $result = $answer->cmp->evaluate($other);
                    if ($result->{score}) {
                      $ans->score($result->{score});
                      $ans->{ans_message} = $result->{ans_message};
                      return $ans->{score};
                    }
                    if ($result->{ans_message}) {
                      $ans->{ans_message} = $result->{ans_message}
                        if !$ans->{ans_message} || length($ans->{ans_message}) > length($result->{ans_message});
                    }
                  }
                }
                return 0;
              }
              package main;
              sub OneOfForm {my::OneOf->new(@_)}

              Context("Form")->variables->add(y=>'Real');
              parser::Assignment->Allow;
              Context()->noreduce('(-x)+y','(-x)-y');
              Context()->flags->set(reduceConstants => 0);
              $eq = OneOfForm(map {Formula("y=$_")} @fs);
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        width=0.33\orccaprintwidth,
                      ]
                      \addplot[firstcurve, domain=$start:$stop]{$f};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$eq" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                The slope is <m><var name="$m"/></m> and the point
                <m>(<var name="$h"/>,<var name="$k"/>)</m> is on the graph of this line, so one
                point-slope form equation for this line is <m>y=<var name="$f"/></m>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="determine-point-slope-form-from-graph-copy">
          <webwork copy="webwork-determine-point-slope-form-from-graph"/>
        </exercise>
        <exercise label="determine-point-slope-form-from-graph-neg">
          <webwork xml:id="webwork-determine-point-slope-form-from-graph-neg">
            <pg-code>
