        <exercise label="determine-point-slope-form-from-graph-q1-large-y">
          <webwork xml:id="webwork-determine-point-slope-form-from-graph-q1-large-y">
            <pg-code>
              $xmin = -1;
              $xmax = 11;
              $ymin = -50;
              $ymax = 600;
              Context("Fraction");
              do {
                do {
                  ($n,$d) = random_coprime([2..6],[2..6]);
                  $n = $n*50;
                  $n = list_random($n,-$n);
                  $m = Fraction($n/$d);
                  ($h,$k) = random_subset(2,1..10);
                  $k = $k*50;
                  $f = Formula("$m(x - $h) + $k")->reduce;
                  $b = $f->eval(x => 0);
                } until ($b != 0);
                $xtop = ($ymax - $k)/$m + $h;
                $xbot = ($ymin - $k)/$m + $h;
                ($start, $stop) = (num_sort($xmin,$xmax,$xtop,$xbot))[1,2];
                @x = ();
                @y = ();
                $a = ($start &lt; 0) ? int(Real($start)) : int(Real($start)) + 1;
                $b = ($stop &lt; 0) ? int(Real($stop)) - 1 : int(Real($stop));
                for ($a .. $b) {
                  if ($f->eval(x => $_) == int($f->eval(x => $_)) &amp;&amp; Real($f->eval(x => $_)) % 50 == 0) {
                    push @x, $_;
                    push @y, $f->eval(x => $_);
                  }
                }
              } until (scalar @x >= 2);
              @fs = map {Formula("$m*(x - $x[$_]) + $y[$_]")->reduce} (0..$#x);

              package my::OneOf;
              our @ISA = ('parser::OneOf');
              sub cmp_compare {
                my ($self,$other,$ans) = @_;
                foreach $answer (@{$self->{data}}) {
                  if ($answer->typeMatch($other)) {
                    my $result = $answer->cmp->evaluate($other);
                    if ($result->{score}) {
                      $ans->score($result->{score});
                      $ans->{ans_message} = $result->{ans_message};
                      return $ans->{score};
                    }
                    if ($result->{ans_message}) {
                      $ans->{ans_message} = $result->{ans_message}
                        if !$ans->{ans_message} || length($ans->{ans_message}) > length($result->{ans_message});
                    }
                  }
                }
                return 0;
              }
              package main;
              sub OneOfForm {my::OneOf->new(@_)}

              Context("Form")->variables->add(y=>'Real');
              parser::Assignment->Allow;
              Context()->noreduce('(-x)+y','(-x)-y');
              Context()->flags->set(reduceConstants => 0);
              $eq = OneOfForm(map {Formula("y=$_")} @fs);
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin = $xmin,
                        xmax = $xmax,
                        ymin = $ymin,
                        ymax = $ymax,
                        xtick = {2,4,...,$xmax},
                        minor xtick = {1,...,$xmax},
                        ytick = {100,200,...,$ymax},
                        minor ytick = {50,100,...,$ymax},
                        width=0.33\orccaprintwidth,
                        clip=false
                      ]
                      \addplot[firstcurve, domain=$start:$stop]{$f};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$eq" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                The slope is <m><var name="$m"/></m> and the point
                <m>(<var name="$h"/>,<var name="$k"/>)</m> is on the graph of this line, so one
                point-slope form equation for this line is <m>y=<var name="$f"/></m>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="determine-point-slope-form-from-graph-q1-large-y-copy">
          <webwork copy="webwork-determine-point-slope-form-from-graph-q1-large-y"/>
        </exercise>
        <exercise label="determine-point-slope-form-from-graph-q1-large-y-precise">
          <webwork xml:id="webwork-determine-point-slope-form-from-graph-q1-large-y-precise">
            <pg-code>
              $xmin = -1;
              $xmax = 11;
              $ymin = -50;
              $ymax = 600;
              Context("Fraction");
              do {
                ($h,$x1) = random_subset(2,1..9);
                ($k,$y1) = random_subset(2,100..599);
                $m = Fraction(($y1 - $k)/($x1 - $h));
                $f = Formula("$m(x - $h) + $k")->reduce;
                $b = $f->eval(x => 0);
              } until ($b != 0 &amp;&amp; abs($h - $x1) >= 3);
              $g = Formula("$m(x - $x1) + $y1")->reduce;
              $xtop = ($ymax - $k)/$m + $h;
              $xbot = ($ymin - $k)/$m + $h;
              ($start, $stop) = (num_sort($xmin,$xmax,$xtop,$xbot))[1,2];

              package my::OneOf;
              our @ISA = ('parser::OneOf');
              sub cmp_compare {
                my ($self,$other,$ans) = @_;
                foreach $answer (@{$self->{data}}) {
                  if ($answer->typeMatch($other)) {
                    my $result = $answer->cmp->evaluate($other);
                    if ($result->{score}) {
                      $ans->score($result->{score});
                      $ans->{ans_message} = $result->{ans_message};
                      return $ans->{score};
                    }
                    if ($result->{ans_message}) {
                      $ans->{ans_message} = $result->{ans_message}
                        if !$ans->{ans_message} || length($ans->{ans_message}) > length($result->{ans_message});
                    }
                  }
                }
                return 0;
              }
              package main;
              sub OneOfForm {my::OneOf->new(@_)}

              Context("Form")->variables->add(y=>'Real');
              parser::Assignment->Allow;
              Context()->noreduce('(-x)+y','(-x)-y');
              Context()->flags->set(reduceConstants => 0);
              $eq = OneOfForm(Formula("y = $f"), Formula("y = $g"));
              $leftright = ($m > 0) ? 'right' : 'left';
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin = $xmin,
                        xmax = $xmax,
                        ymin = $ymin,
                        ymax = $ymax,
                        xtick = {2,4,...,$xmax},
                        minor xtick = {1,...,$xmax},
                        ytick = {100,200,...,$ymax},
                        minor ytick = {50,100,...,$ymax},
                        width=0.33\orccaprintwidth,
                        clip=false
                      ]
                      \addplot[firstcurve, domain=$start:$stop]{$f};
                      \addplot[soliddot] coordinates {($h,$k)} node[below $leftright] {\(($h,$k)\)};
                      \addplot[soliddot] coordinates {($x1,$y1)} node[below $leftright] {\(($x1,$y1)\)};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$eq" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                The slope is <m><var name="$m"/></m> and the point
                <m>(<var name="$h"/>,<var name="$k"/>)</m> is on the graph of this line, so one
                point-slope form equation for this line is <m>y=<var name="$f"/></m>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="determine-point-slope-form-from-graph-q1-large-y-precise-copy">
          <webwork copy="webwork-determine-point-slope-form-from-graph-q1-large-y-precise"/>
        </exercise>
      </exercisegroup>

      <exercisegroup cols="3">
        <title>Make Graphs</title>
        <introduction>
          <p>
            Graph the linear equation by identifying the slope and one point on this line.
          </p>
        </introduction>
        <exercise label="graph-point-slope-pos-int">
          <webwork xml:id="webwork-graph-point-slope-pos-int">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              Context("Fraction");
              Context()->noreduce('(-x)-y','(-x)+y');
              ($h,$k,$m) = random_subset(3, 2..5);
              $f = Formula("$m(x - $h) + $k");
              $x1 = $h + 1;
              $y1 = $k + $m;
              $gt = GraphTool("{line, solid, ($h, $k), ($x1, $y1)}")->with(
                bBox => [-11, 11, 11, -11],
                availableTools => [ "LineTool" ],
                showInStatic => 0,
              );
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="graph-point-slope-pos-int-copy">
          <webwork copy="webwork-graph-point-slope-pos-int"/>
        </exercise>
        <exercise label="graph-point-slope-pos-int-neg-k">
          <webwork xml:id="webwork-graph-point-slope-pos-int-neg-k">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              Context("Fraction");
              Context()->noreduce('(-x)-y','(-x)+y');
              ($h,$k,$m) = random_subset(3, 2..5);
              $k = -$k;
              $f = Formula("$m(x - $h) + $k")->reduce;
              $x1 = $h + 1;
              $y1 = $k + $m;
              $gt = GraphTool("{line, solid, ($h, $k), ($x1, $y1)}")->with(
                bBox => [-11, 11, 11, -11],
                availableTools => [ "LineTool" ],
                showInStatic => 0,
              );
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="graph-point-slope-pos-int-neg-k-copy">
          <webwork copy="webwork-graph-point-slope-pos-int-neg-k"/>
        </exercise>
        <exercise label="graph-point-slope-pos-frac">
          <webwork xml:id="webwork-graph-point-slope-pos-frac">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              Context("Fraction");
              Context()->noreduce('(-x)-y','(-x)+y');
              do {
                ($n,$d) = random_coprime([1..9],[2..9]);
                $m = Fraction($n/$d);
                ($h,$k) = random_subset(2, 2..9);
                if (random(0,1)) {
                  $h = -$h;
                  $k = -$k;
                }
                $f = Formula("$m(x - $h) + $k")->reduce;
                $b = $f->eval(x => 0);
              } until ($b != int(Real($b)));
              $x1 = $h + $d;
              $y1 = $k + $n;
              $gt = GraphTool("{line, solid, ($h, $k), ($x1, $y1)}")->with(
                bBox => [-11, 11, 11, -11],
                availableTools => [ "LineTool" ],
                showInStatic => 0,
              );
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="graph-point-slope-pos-frac-copy">
          <webwork copy="webwork-graph-point-slope-pos-frac"/>
        </exercise>
        <exercise label="graph-point-slope-neg-frac">
          <webwork xml:id="webwork-graph-point-slope-neg-frac">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              Context("Fraction");
              Context()->noreduce('(-x)-y','(-x)+y');
              do {
                ($n,$d) = random_coprime([-9..-1],[2..9]);
                $m = Fraction($n/$d);
                ($h,$k) = random_subset(2, 2..9);
                if (random(0,1)) {
                  $h = -$h;
                } else {
                  $k = -$k;
                }
                $f = Formula("$m(x - $h) + $k")->reduce;
                $b = $f->eval(x => 0);
              } until ($b != int(Real($b)));
              $x1 = $h + $d;
              $y1 = $k + $n;
              $gt = GraphTool("{line, solid, ($h, $k), ($x1, $y1)}")->with(
                bBox => [-11, 11, 11, -11],
                availableTools => [ "LineTool" ],
                showInStatic => 0,
              );
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="graph-point-slope-neg-frac-copy">
          <webwork copy="webwork-graph-point-slope-neg-frac"/>
        </exercise>
        <exercise label="graph-point-slope-decimal">
          <webwork xml:id="webwork-graph-point-slope-decimal">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              Context("Numeric");
              Context()->noreduce('(-x)-y','(-x)+y');
              do {
                $m = non_zero_random(-0.9,0.9,0.1);
                ($h,$k) = random_subset(2, 2..9);
                if ($m > 0) {
                  if (random(0,1)) {
                    $h = -$h;
                    $k = -$k;
                  }
                } else {
                  if (random(0,1)) {
                    $h = -$h;
                  } else {
                    $k = -$k;
                  }
                }
                $f = Formula("$m(x - $h) + $k")->reduce;
                $b = $f->eval(x => 0);
              } until ($b != int(Real($b)));
              $x1 = $h + 10;
              $y1 = Real($k + $m*10);
              $gt = GraphTool("{line, solid, ($h, $k), ($x1, $y1)}")->with(
                bBox => [-11, 11, 11, -11],
                availableTools => [ "LineTool" ],
                showInStatic => 0,
              );
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="graph-point-slope-decimal-copy">
          <webwork copy="webwork-graph-point-slope-decimal"/>
        </exercise>
      </exercisegroup>
