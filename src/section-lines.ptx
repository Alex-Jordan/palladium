      <exercisegroup cols="3">
        <title>Point-Slope Given Two Points</title>
        <introduction>
          <p>
            A line passes through two given points. Find an equation for the line in point-slope
            form using one of the given points.
          </p>
        </introduction>
        <exercise label="find-point-slope-two-points-pos-int">
          <webwork xml:id="webwork-find-point-slope-two-points-pos-int">
            <pg-code>
              package my::OneOf;
              our @ISA = ('parser::OneOf');
              sub cmp_compare {
                my ($self,$other,$ans) = @_;
                foreach $answer (@{$self->{data}}) {
                  if ($answer->typeMatch($other)) {
                    my $result = $answer->cmp->evaluate($other);
                    if ($result->{score}) {
                      $ans->score($result->{score});
                      $ans->{ans_message} = $result->{ans_message};
                      return $ans->{score};
                    }
                    if ($result->{ans_message}) {
                      $ans->{ans_message} = $result->{ans_message}
                        if !$ans->{ans_message} || length($ans->{ans_message}) > length($result->{ans_message});
                    }
                  }
                }
                return 0;
              }
              package main;
              sub OneOfForm {my::OneOf->new(@_)}

              do {
                ($m,$h,$k,$x1) = random_subset(4, 2..9);
                Context()->noreduce('(-x)+y','(-x)-y');
                $f = Formula("$m*(x - $h) + $k")->reduce;
                $y1 = $f->eval(x => $x1);
              } until ($y1 != 0);
              $g = Formula("$m*(x - $x1) + $y1")->reduce;
              Context("Point");
              $p0 = Point("($h,$k)");
              $p1 = Point("($x1,$y1)");

              Context("Form")->variables->add(y=>'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $eq=OneOfForm(Formula("y=$f"), Formula("y=$g"));
            </pg-code>
            <statement>
              <p>
                <m><var name="$p0"/></m> and <m><var name="$p1"/></m>
              </p>
              <p>
                <var name="$eq" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
