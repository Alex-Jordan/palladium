        <exercise label="find-point-slope-two-points-neg-int">
          <webwork xml:id="webwork-find-point-slope-two-points-neg-int">
            <pg-code>
              package my::OneOf;
              our @ISA = ('parser::OneOf');
              sub cmp_compare {
                my ($self,$other,$ans) = @_;
                foreach $answer (@{$self->{data}}) {
                  if ($answer->typeMatch($other)) {
