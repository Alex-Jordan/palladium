          <webwork xml:id="webwork-convert-point-slope-to-slope-intercept-neg-int">
            <pg-code>
              ($m,$h,$k) = random_subset(3,2..9);
              $m = -$m;
              $h = -$h;
              Context()->noreduce('(-x)-y','(-x)+y');
              $f = Formula("$m(x-$h)+$k")->reduce;
              $b = $f->eval(x => 0);
              Context("Form")->variables->add(y=>'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $si = Formula("y=$m x + $b")->reduce;
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <p>
                <var name="$si" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="convert-point-slope-to-slope-intercept-neg-int-copy">
          <webwork copy="webwork-convert-point-slope-to-slope-intercept-neg-int"/>
        </exercise>
        <exercise label="convert-point-slope-to-slope-intercept-pos-frac">
          <webwork xml:id="webwork-convert-point-slope-to-slope-intercept-pos-frac">
            <pg-code>
              ($h,$k) = random_subset(2,2..9);
              ($n,$d) = random_coprime([1..9],[2..9]);
              Context("Fraction");
              $m = Fraction($n/$d);
              Context()->noreduce('(-x)-y','(-x)+y');
              $f = Formula("$m(x-$h)+$k")->reduce;
              $b = $f->eval(x => 0);
              Context("Form")->variables->add(y=>'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              Context()->flags->set(reduceConstants => 0);
              $absb = abs($b);
              $sign = ($b > 0) ? '+' : '-';
              $si = Formula("y = $m x $sign $absb");
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <p>
                <var name="$si" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
