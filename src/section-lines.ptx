              $f = Formula("$m(x-$h)+$k")->reduce;
              Context("Point");
              Context()->parens->set("[" => {type => "Interval", close => "]"});
              Context()->parens->set("{" => {type => "Set", close => "}"});
              Context()->parens->set("&lt;" => {type => "Vector", close => ">"});
              $p = Point("($h,$k)");
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
