      <exercisegroup cols="3">
        <title>Graphs and Slope-Intercept Form</title>
        <introduction>
          <p>
            In the given graph, what is the line's slope-intercept equation?
          </p>
        </introduction>
        <exercise label="slope-intercept-from-graph-pos-int">
          <webwork xml:id="webwork-slope-intercept-from-graph-pos-int">
            <pg-code>
              $b = non_zero_random(-4,4);
              $m = non_zero_random(2,5);
              $x1 = 0;
              $y1 = $b;
              $x2 = 1;
              $y2 = $m*$x2+$b;
              $rise = $y2-$y1;
              $run = $x2-$x1;
              Context("Numeric");
              Context("Numeric")->variables->add(y=>'Real');
              Context()->noreduce('(-x)-y','(-x)+y');
              parser::Assignment->Allow;
              $ansSI = Formula("y = $m*x+$b")->reduce;
              $ymin = -5*(int( abs($y2) /5)+1);
              $ymax = -$ymin;
              ($start,$stop) = (num_sort(-5,5,($ymin-$b)/$m,($ymax-$b)/$m))[1,2];
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin = -5,
                        xmax = 5,
                        ymin = $ymin,
                        ymax = $ymax,
                        xtick =,
                        ytick =,
                        minor xtick = {-5,...,5},
                        minor ytick = {$ymin,...,$ymax},
                        grid = minor,
                        width=0.33\orccaprintwidth
                      ]
                      \addplot+[domain=$start:$stop] {$m*x+$b};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$ansSI" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="slope-intercept-from-graph-pos-int-copy">
          <webwork copy="webwork-slope-intercept-from-graph-pos-int"/>
        </exercise>
        <exercise label="slope-intercept-from-graph-pos-reciprocal">
          <webwork xml:id="webwork-slope-intercept-from-graph-pos-reciprocal">
            <pg-code>
              $b = non_zero_random(-4,4);
              Context("Fraction");
              $m = Fraction(1/random(2,9));
              $x1 = 0;
              $y1 = $b;
              $x2 = 1/$m;
              $y2 = $b+1;
              $rise = $y2-$y1;
              $run = $x2-$x1;
              Context()->variables->add(y=>'Real');
              Context()->noreduce('(-x)-y','(-x)+y');
              parser::Assignment->Allow;
              $ansSI = Formula("y = $m*x+$b")->reduce;
              $xmax = max(5, 1/$m + 1);
              $xmin = -$xmax;
              $ymin = -7;
              $ymax = 7;
              ($start,$stop) = (num_sort($xmin,$xmax,($ymin-$b)/$m,($ymax-$b)/$m))[1,2];
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin = $xmin,
                        xmax = $xmax,
                        ymin = $ymin,
                        ymax = $ymax,
                        xtick =,
                        ytick =,
                        minor xtick = {$xmin,...,$xmax},
                        minor ytick = {$ymin,...,$ymax},
                        grid = minor,
                        width=0.33\orccaprintwidth
                      ]
                      \addplot+[domain=$start:$stop] {$m*x+$b};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$ansSI" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
