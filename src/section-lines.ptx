        <exercise label="plot-slope-intercept-pos-frac">
          <webwork xml:id="webwork-plot-slope-intercept-pos-frac">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              Context("Fraction")->variables->add(y=>'Real');
              $m = Fraction(random_coprime([2..9],[2..9]));
              $b = non_zero_random(-5,5);
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $equation = Formula("y = $m x + $b")->reduce;
              ($n,$d) = $m->value;
              $gt = GraphTool("{line, solid, (0, $b), ($d, $b + $n)}")->with(
                bBox => [-11, 11, 11, -11],
                availableTools => [ "LineTool" ],
                showInStatic => 0,
              );
            </pg-code>
            <statement>
              <p>
                <m><var name="$equation"/></m>
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
          </webwork>
        </exercise>
