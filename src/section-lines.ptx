      <exercisegroup cols="3">
        <title>Writing a Slope-Intercept Equation Given Two Points</title>
        <introduction>
          <p>
            A line passes through the two given points. Find the line's equation in slope-intercept
            form.
          </p>
        </introduction>
        <exercise label="find-slope-intercept-from-points-pos-int">
          <webwork xml:id="webwork-find-slope-intercept-from-points-pos-int">
            <pg-code>
              $b = non_zero_random(-9,9);
              $n = random(2,9);
              $d = 1;
              Context("Fraction")->variables->add(y => 'Real');
              $m = Fraction($n/$d);
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $equation = Formula("y = $m x + $b")->reduce;
              @x = num_sort(random_subset(2,1..9));
              @y = map {$m*$_ + $b} (@x);
              @p = map {Point($x[$_],$y[$_])} (0,1);
            </pg-code>          
            <statement>
              <p>
                <m><var name="$p[0]"/></m> and <m><var name="$p[1]"/></m> 
              </p>
              <p>
                <var name="$equation" width="16"/>
              </p>
            </statement>
          </webwork>
