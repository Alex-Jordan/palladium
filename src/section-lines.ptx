      <exercisegroup cols="3">
        <title>Identify Point and Slope</title>
        <introduction>
          <p>
            A line's equation is given in point-slope form. Identify the slope and the point on the
            line that is being singled out.
          </p>
        </introduction>
        <exercise label="identify-slope-and-point-pos-int">
          <webwork xml:id="webwork-identify-slope-and-point-pos-int">
            <pg-code>
              ($m,$h,$k) = random_subset(3,2..9);
              Context()->noreduce('(-x)-y','(-x)+y');
              $f = Formula("$m(x-$h)+$k")->reduce;
              Context("Point");
              Context()->parens->set("[" => {type => "Interval", close => "]"});
              Context()->parens->set("{" => {type => "Set", close => "}"});
              Context()->parens->set("&lt;" => {type => "Vector", close => ">"});
              $p = Point("($h,$k)");
            </pg-code>
            <statement>
              <p>
                <m>y=<var name="$f"/></m>
              </p>
              <instruction>Enter the slope here.</instruction>
              <p>
                <var name="$m" width="5"/>
              </p>
              <instruction>Enter the point here.</instruction>
              <p>
                <var name="$p" width="5"/>
              </p>
            </statement>
            <solution>
              <p>
                This line is in point-slope form, so we can just recognize that the slope is
                <m><var name="$m"/></m> and the line passes through the point
                <m><var name="$p"/></m>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="identify-slope-and-point-pos-int-copy">
          <webwork copy="webwork-identify-slope-and-point-pos-int"/>
        </exercise>
