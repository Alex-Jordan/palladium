        <exercise label="find-point-slope-two-points-neg-frac">
          <webwork xml:id="webwork-find-point-slope-two-points-neg-frac">
            <pg-code>
              package my::OneOf;
              our @ISA = ('parser::OneOf');
              sub cmp_compare {
                my ($self,$other,$ans) = @_;
                foreach $answer (@{$self->{data}}) {
                  if ($answer->typeMatch($other)) {
                    my $result = $answer->cmp->evaluate($other);
                    if ($result->{score}) {
                      $ans->score($result->{score});
                      $ans->{ans_message} = $result->{ans_message};
                      return $ans->{score};
                    }
                    if ($result->{ans_message}) {
                      $ans->{ans_message} = $result->{ans_message}
                        if !$ans->{ans_message} || length($ans->{ans_message}) > length($result->{ans_message});
                    }
                  }
                }
                return 0;
              }
              package main;
              sub OneOfForm {my::OneOf->new(@_)}

              Context("Fraction");
              Context()->noreduce('(-x)+y','(-x)-y');
              do {
                ($h,$k) = random_subset(2, -9..-1, 1..9);
                ($n,$d) = random_coprime([-9..-1],[2..9]);
                $m = Fraction($n/$d);
                $f = Formula("$m*(x - $h) + $k")->reduce;
                $x1 = $h + non_zero_random(-9,9)*$d;
                $y1 = $f->eval(x => $x1);
              } until ($y1 != 0);
              $g = Formula("$m*(x - $x1) + $y1")->reduce;
              $p0 = Point($h,$k);
              $p1 = Point($x1,$y1);

              Context("Form")->variables->add(y=>'Real');
              Context()->noreduce('(-x)+y','(-x)-y');
              parser::Assignment->Allow;
              $eq=OneOfForm(Formula("y=$f"), Formula("y=$g"));
              Context()->flags->set(reduceConstants => 0);
              $top = Formula("x - $k");
              $top = $top->substitute(x => $y1);
              $bottom = Formula("x - $h");
              $bottom = $bottom->substitute(x => $x1);
            </pg-code>
            <statement>
              <p>
                <m><var name="$p0"/></m> and <m><var name="$p1"/></m>
              </p>
              <p>
                <var name="$eq" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                First we must find this line's slope using the slope formula:
                <md>
                  <mrow>\amp\frac{y_2-y_1}{x_2-x_1}</mrow>
                  <mrow>\amp= \frac{<var name="$top"/>}{<var name="$bottom"/>}</mrow>
                  <mrow>\amp= \frac{<var name="$top->reduce"/>}{<var name="$bottom->reduce"/>}</mrow>
                </md>
                So the slope is <m><var name="$m"/></m>. Using the point <m><var name="$p0"/></m>
                and point-slope form, an equation for the line is <m>y=<var name="$f"/></m>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="find-point-slope-two-points-neg-frac-copy">
          <webwork copy="webwork-find-point-slope-two-points-neg-frac"/>
        </exercise>
