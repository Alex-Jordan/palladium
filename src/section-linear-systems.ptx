              Context("LinearRelation")->variables->are($X => 'Real', $Y => 'Real');
              Context()->noreduce('(-x)-y', '(-x)+y');
              $right[0] = Formula("-$A[0] ($X - $h[0]) + $k[0]")->reduce;
              $f[0] = Formula("$Y = $right[0]")->reduce;
              $left[1] = Formula("$A[1] $X + $B[1] $Y")->reduce;
              $f[1] = Formula("$left[1] = $C[1]")->reduce;
            </pg-code>
            <statement>
