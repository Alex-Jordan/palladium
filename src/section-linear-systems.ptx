                @A = (-9..-2, 2..9)[NchooseK(18,2)];
                @B = (-9..-2, 2..9)[NchooseK(18,2)];
              } until (abs($A[0]*$B[1] - $A[1]*$B[0]) > 1 &amp;&amp; abs($A[0]*$B[1] - $A[1]*$B[0]) &lt; 10);
