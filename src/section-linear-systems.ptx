        <exercise label="substitution-no-solution-integer-coefficients-point-slope-standard">
          <webwork xml:id="webwork-substitution-no-solution-integer-coefficients-point-slope-standard">
            <pg-macros>
              <macro-file>parserLinearRelation.pl</macro-file>
            </pg-macros>
            <pg-code>
              ($X, $Y) = random_subset(2, 'a'..'n','p'..'z','A'..'D', 'F'..'N','P'..'T','V'..'Z');
              Context("LinearRelation")->variables->are($X => 'Real', $Y => 'Real');
              Context()->noreduce('(-x)-y', '(-x)+y');
              $A[0] = list_random(-5..-2, 2..5);
              $A[1] = $A[0];
              @B = (1,1);
              @C = (-9..9)[NchooseK(19,2)];
              $left[0] = Formula("$A[0] $X + $B[0] $Y")->reduce;
              $f[0] = Formula("$left[0] = $C[0]")->reduce;
              $h[1] = non_zero_random(-5, 5);
              $k[1] = $C[1] - $A[1]*$h[1];
              $right[1] = Formula("-$A[1] ($X - $h[1]) + $k[1]")->reduce;
              $f[1] = Formula("$Y = $right[1]");
              Context()->strings->remove("NONE");
              Context()->strings->add(
                "no solutions" => {},
              );
              for (
                "no solution",
                "none",
                "there are no solutions",
                "the solution set is empty",
                "solution set is empty",
                "empty set",
                "∅",
                "{}",
                "{ }",
                "{  }",
                "{   }"
              ) {
                Context()->strings->add($_ => {alias => "no solutions"});
              }
              Context()->strings->add(
                "infinitely many solutions" => {},
              );
              for (
                "infinitely many",
                "infinite solution set",
                "infinite",
                "the solution set is infinite",
                "solution set is infinite"
              ) {
                Context()->strings->add($_ => {alias => "infinitely many solutions"});
              }
              $solution = Compute("no solutions");
              $answer = $solution->cmp(
                typeMatch => List("$X = 0, $Y = 0"),
                mathQuillOpts => 'disabled'
              );
              # Note $B[0] is 1
              $sol[0] = $left[0]->substitute($Y => $right[1]);
              $sol[1] = Formula("$A[0] $X - $A[1] $X + ($A[1]*$h[1]) + $k[1]")->reduce;
              $sol[2] = Formula("$B[0]*($A[1]*$h[1] + $k[1])")->reduce;
            </pg-code>
            <statement>
              <p>
                <m>\left\{
                  \begin{alignedat}{4}
                  \amp <var name="$f[0]"/> \\
                  \amp <var name="$f[1]"/>
                  \end{alignedat}
                  \right.
                </m>
              </p>
              <instruction>
                Write the solution in the format
                <m><var name="$X"/> = \text{number}, <var name="$Y"/> = \text{number}</m>.
                If there is no solution, enter <c>no solutions</c>.
                If there are infinitely many solutions, enter <c>infinitely many solutions</c>.
              </instruction>
              <p>
                <var name="$answer" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                Since <m><var name="$Y"/></m> is already isolated in the second equation line, we
                will use that and substitute <m><var name="$right[1]"/></m> in for
                <m><var name="$Y"/></m> in the first equation:
                <md>
                  <mrow><var name="$sol[0]"/>\amp=<var name="$C[0]"/></mrow>
                  <mrow><var name="$sol[1]"/>\amp=<var name="$C[0]"/></mrow>
                  <mrow><var name="$sol[2]"/>\amp=<var name="$C[0]"/></mrow>
                </md>
                This is an outright false equation, so there is no solution.
              </p>
            </solution>
          </webwork>
        </exercise>
