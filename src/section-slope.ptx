        <exercise label="determine-if-table-data-is-linear-5">
          <webwork xml:id="webwork-determine-if-table-data-is-linear-5">
            <pg-macros>
              <macro-file>parserPopUp.pl</macro-file>
            </pg-macros>
            <pg-code>
              $m = non_zero_random(-5,5,0.01);
              $absm = abs($m);
              $incdec = ($m>0) ? 'increases' : 'decreases';
              $b = random(30,100,0.01);
              $f = Formula("$m*x + $b");
              $start = random(-10,10,1);
              @x = map{$_+$start}(0..5);
              @y = map{$f->eval(x=>$_)}(@x);
              $yes = DropDown(['yes','no'], 0, showInStatic => 0);
              $no = DropDown(['yes','no'], 1, showInStatic => 0);
            </pg-code>
            <statement>
              <tabular halign="right">
                <row bottom="medium">
                  <cell><m>x</m></cell>
                  <cell><m>y</m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[0]"/></m></cell>
                  <cell><m><var name="$y[0]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[1]"/></m></cell>
                  <cell><m><var name="$y[1]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[2]"/></m></cell>
                  <cell><m><var name="$y[2]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[3]"/></m></cell>
                  <cell><m><var name="$y[3]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[4]"/></m></cell>
                  <cell><m><var name="$y[4]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[5]"/></m></cell>
                  <cell><m><var name="$y[5]"/></m></cell>
                </row>
              </tabular>
              <p>
                <var name="$yes" form="popup"/>
              </p>
            </statement>
            <solution>
              <p>
                As each <m>x</m>-value increases by <m>1</m>, the <m>y</m>-value <var name="$incdec"/>
                by <m><var name="$absm"/></m>. So this table does show that <m>x</m> and <m>y</m> have
                a linear relationship.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="determine-if-table-data-is-linear-5-copy">
          <webwork copy="webwork-determine-if-table-data-is-linear-5"/>
        </exercise>
        <exercise label="determine-if-table-data-is-linear-6">
          <webwork xml:id="webwork-determine-if-table-data-is-linear-6">
            <pg-macros>
              <macro-file>parserPopUp.pl</macro-file>
            </pg-macros>
            <pg-code>
              $m = non_zero_random(2,9,1);
              $b = random(1,100,1);
              $f = Formula("$m*x + $b");
              @x = num_sort(NchooseK(20,6));
              @y = map{$f->eval(x=>$_)}(@x);
              $yes = DropDown(['yes','no'], 0, showInStatic => 0);
              $no = DropDown(['yes','no'], 1, showInStatic => 0);
              $ydiff = $y[1]-$y[0];
              $xdiff = $x[1]-$x[0];
            </pg-code>
            <statement>
              <tabular halign="right">
                <row bottom="medium">
                  <cell><m>x</m></cell>
                  <cell><m>y</m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[0]"/></m></cell>
                  <cell><m><var name="$y[0]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[1]"/></m></cell>
                  <cell><m><var name="$y[1]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[2]"/></m></cell>
                  <cell><m><var name="$y[2]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[3]"/></m></cell>
                  <cell><m><var name="$y[3]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[4]"/></m></cell>
                  <cell><m><var name="$y[4]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[5]"/></m></cell>
                  <cell><m><var name="$y[5]"/></m></cell>
                </row>
              </tabular>
              <p>
                <var name="$yes" form="popup"/>
              </p>
            </statement>
            <solution>
              <p>
                The <m>x</m>-values in this table jump erratically. However, if we compute the rate of
                change between consecutive rows in the table, the result is always <var name="$m"/>.
                For example, the rate of change between the first and second rows is
                <md>
                  \frac{<var name="$y[1]"/>-<var name="$y[0]"/>}{<var name="$x[1]"/>-<var name="$x[0]"/>}=\frac{<var name="$ydiff"/>}{<var name="$xdiff"/>}=<var name="$m"/>
                </md>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="determine-if-table-data-is-linear-6-copy">
          <webwork copy="webwork-determine-if-table-data-is-linear-6"/>
        </exercise>
      </exercisegroup>
      <exercisegroup cols="3">
        <title>Slope from Coordinates</title>
        <introduction>
          <p>
            Find the slope of the line passing through the two given points.
          </p>
        </introduction>
        <exercise label="slope-from-coordinates-integer">
          <webwork xml:id="webwork-slope-from-coordinates-integer">
            <pg-code>
              Context("LimitedFraction")->flags->set(allowMixedNumbers => 0, showMixedNumbers => 0);
              $m = Fraction(random(1, 9));
              $b = non_zero_random(-9, 9);
              @x = random_subset(2, 1 .. 9);
              @y = map {$m*$_ + $b} (@x);
              Context("Point");
              @p = map {Point($x[$_], $y[$_])} (0,1);
              Context()->flags->set(reduceConstants => 0);
              $top = Formula("x - $y[0]");
              $top = $top->substitute(x => $y[1]);
              $bottom = Formula("x - $x[0]");
              $bottom = $bottom->substitute(x => $x[1]);
            </pg-code>
            <statement>
              <p>
                <m><var name="$p[0]"/></m> and <m><var name="$p[1]"/></m>
              </p>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
            <solution>
              <p>
                <md>
                  <mrow>m \amp= \frac{y_2 - y_1}{x_2 - x_1}</mrow>
                  <mrow>\amp= \frac{<var name="$top"/>}{<var name="$bottom"/>}</mrow>
                  <mrow>\amp= \frac{<var name="$top->reduce"/>}{<var name="$bottom->reduce"/>}= <var name="$m"/></mrow>
                </md>
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="slope-from-coordinates-integer-copy">
          <webwork copy="webwork-slope-from-coordinates-integer"/>
        </exercise>
