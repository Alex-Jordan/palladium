        <exercise label="slope-from-coordinates-decimal">
          <webwork xml:id="webwork-slope-from-coordinates-decimal">
            <pg-code>
              do {
                $x[0] = random(-9,9) + random(0.1,0.9,0.1);
                $x[1] = random(-9,9) + random(0.1,0.9,0.1);
              } until ($x[0] != $x[1]);
              $y[0] = random(-9,9) + random(0.1,0.9,0.1);
              $y[1] = random(-9,9) + random(0.1,0.9,0.1);
              Context("Numeric")->operators->undefine("+","-");
              $m = Real(($y[1] - $y[0])/($x[1] - $x[0]));
              Context("Point");
              @p = map {Point($x[$_], $y[$_])} (0,1);
            </pg-code>
            <statement>
              <p>
                <m><var name="$p[0]"/></m> and <m><var name="$p[1]"/></m>
              </p>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
          </webwork>
        </exercise>
