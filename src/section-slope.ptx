      <exercisegroup cols="3">
        <title>Slope from a Graph</title>
        <introduction>
          <p>
            Find the slope of the line given its graph.
          </p>
        </introduction>
        <exercise label="slope-from-graph-integer">
          <webwork xml:id="webwork-slope-from-graph-integer">
            <pg-code>
              $m = random(1, 9);
              $x[0] = random(1, 9);
              $x[1] = $x[0] + 1;
              $y[0] = random(1, 9);
              $y[1] = $y[0] + $m;
              $f = Formula("$m (x - $x[0]) + $y[0]");
              $ymax = max(10, max(@y) + 1);
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin=-1,
                        xmax=10,
                        ymin=-1,
                        ymax=$ymax,
                        xtick={2,4,...,8},
                        minor xtick={1,...,9},
                        ytick={5,10,...,$ymax},
                        minor ytick={1,...,$ymax},
                        width=0.33\orccaprintwidth
                      ]
                      \addplot+[-,domain=-1:10,samples=2] {$f};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="slope-from-graph-integer-copy">
          <webwork copy="webwork-slope-from-graph-integer"/>
        </exercise>
        <exercise label="slope-from-graph-fraction">
          <webwork xml:id="webwork-slope-from-graph-fraction">
            <pg-code>
              Context("LimitedFraction")->flags->set(requirePureFractions => 1, showMixedNumbers => 0);
              @x = random_subset(2, 1 .. 9);
              @y = random_subset(2, 1 .. 9);
              $m = Fraction($y[1] - $y[0], $x[1] - $x[0]);
              Context("Numeric");
              Context()->noreduce('(-x)-y', '(-x)+y');
              $f = Formula("$m (x - $x[0]) + $y[0]");
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin=-1,
                        xmax=10,
                        ymin=-1,
                        ymax=10,
                        xtick={2,4,...,8},
                        minor xtick={1,...,9},
                        ytick={5,10},
                        minor ytick={1,...,9},
                        width=0.33\orccaprintwidth
                      ]
                      \addplot+[-,domain=-1:10,samples=2] {$f};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="slope-from-graph-fraction-copy">
          <webwork copy="webwork-slope-from-graph-fraction"/>
        </exercise>
        <exercise label="slope-from-graph-fraction-neg-input">
          <webwork xml:id="webwork-slope-from-graph-fraction-neg-input">
            <pg-code>
              Context("LimitedFraction")->flags->set(requirePureFractions => 1, showMixedNumbers => 0);
              @x = random_subset(2, 1 .. 4, -4 .. -1);
              @y = random_subset(2, -4 .. -1, 1 .. 4);
              $m = Fraction(($y[1] - $y[0])/($x[1] - $x[0]));
              Context("Numeric");
              Context()->noreduce('(-x)-y', '(-x)+y');
              $f = Formula("$m (x - $x[0]) + $y[0]")->reduce;
