        <exercise label="slope-from-graph-zero">
          <webwork xml:id="webwork-slope-from-graph-zero">
            <pg-code>
              Context("LimitedFraction")->flags->set(requirePureFractions => 1, showMixedNumbers => 0);
              $y[0] = non_zero_random(-6, 6);
              $y[1] = $y[0];
              $m = Fraction(0, 1);
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        width=0.33\orccaprintwidth
                      ]
