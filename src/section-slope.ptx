                  <cell><m><var name="$x[0]"/></m></cell><cell><m><var name="$y[0]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[1]"/></m></cell><cell><m><var name="$y[1]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[2]"/></m></cell><cell><m><var name="$y[2]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[3]"/></m></cell><cell><m><var name="$y[3]"/></m></cell>
                </row>
                <row>
                  <cell><m><var name="$x[4]"/></m></cell><cell><m><var name="$y[4]"/></m></cell>
                </row>
              </tabular>
              <p>
                From <m>x=<var name="$x[$a]"/></m> to <m>x=<var name="$x[$b]"/></m>.
              </p>
              <p>
                <var name="$m" width="5"/>
              </p>
