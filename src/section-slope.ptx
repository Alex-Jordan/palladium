              $k = random(2,7);
              $x[0] = non_zero_random(-9, 9);
              $x[1] = $x[0] + $k*$run;
              $y[0] = non_zero_random(-9, 9);
              $y[1] = $y[0] + $k*$rise;
              Context("Point");
              @p = map {Point($x[$_], $y[$_])} (0,1);
            </pg-code>
            <statement>
              <p>
                <m><var name="$p[0]"/></m> and <m><var name="$p[1]"/></m>
