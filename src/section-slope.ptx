    </subexercises>
  

    <subexercises>
      <title>Applications</title>
      <exercise label="portland-population">
        <webwork xml:id="webwork-portland-population">
          <pg-code>
            @x=(2002..2025);
            @y=(540400,546000,551700,557300,562900,568600,574200,579800,585500,595600,604500,610300,621000,631900,643100,648200,651200,654400,653200,642800,636100,634300,635700,631400);
            %f=map{$x[$_] => $y[$_]}(0..23);
            @yr=num_sort(random_subset(4,@x));
            $n=[
            {name => 'people'},
            {name => 'person',conversion => {factor => 1,people => 1}},
            {name => 'ppl',conversion => {factor => 1,people => 1}},
            {name => 'year',conversion => {factor => 365*24*60*60,s => 1}},
            {name => 'years',conversion => {factor => 365*24*60*60,s => 1}},
            {name => 'yr',conversion => {factor => 365*24*60*60,s => 1}},
            {name => 'yrs',conversion => {factor => 365*24*60*60,s => 1}},
            {name => 'y',conversion => {factor => 365*24*60*60,s => 1}}
            ];
            @r=map{Real(($f{$yr[2*$_+1]}-$f{$yr[2*$_]})/($yr[2*$_+1]-$yr[2*$_]))}(0,1);
            @r=map{NumberWithUnits("$_ people/yr",{newUnit => $n})}(@r);
            Context("Interval");
            $d=List('[2019,2020],[2020,2021],[2021,2022],[2022,2023],[2024,2025]');
            $p=join(' ',(map{"($x[$_],$y[$_])"}(0..23)));
            $s=Interval('[2006,2016]');
            $t=NumberWithUnits(($y[14]-$y[4])/10,"people/yr",{newUnit => $n});
          </pg-code>
          <introduction>
            <p>
              This table gives population estimates for Portland, Oregon from 2002 through 2025,
              gathered from
              <url href="https://worldpopulationreview.com/us-cities/oregon/portland" visual="worldpopulationreview.com"/>.
            </p>
            <tabular>
              <col halign="right"/>
              <col right="medium" halign="left"/>
              <col halign="right"/>
              <col right="medium" halign="left"/>
              <col halign="right"/>
              <col halign="left"/>
              <row bottom="medium">
                <cell>Year</cell>
                <cell>Population</cell>
                <cell>Year</cell>
                <cell>Population</cell>
                <cell>Year</cell>
                <cell>Population</cell>
              </row>
              <row>
                <cell>2002</cell>
                <cell>540400</cell>
                <cell>2010</cell>
                <cell>585500</cell>
                <cell>2018</cell>
                <cell>651200</cell>
              </row>
              <row>
                <cell>2003</cell>
                <cell>546000</cell>
                <cell>2011</cell>
                <cell>595600</cell>
                <cell>2019</cell>
                <cell>654400</cell>
              </row>
              <row>
                <cell>2004</cell>
                <cell>551700</cell>
                <cell>2012</cell>
                <cell>604500</cell>
                <cell>2020</cell>
                <cell>653200</cell>
              </row>
              <row>
                <cell>2005</cell>
                <cell>557300</cell>
                <cell>2013</cell>
                <cell>610300</cell>
                <cell>2021</cell>
                <cell>642800</cell>
              </row>
              <row>
                <cell>2006</cell>
                <cell>562900</cell>
                <cell>2014</cell>
                <cell>621000</cell>
                <cell>2022</cell>
                <cell>636100</cell>
              </row>
              <row>
                <cell>2007</cell>
                <cell>568600</cell>
                <cell>2015</cell>
                <cell>631900</cell>
                <cell>2023</cell>
                <cell>634300</cell>
              </row>
              <row>
                <cell>2008</cell>
                <cell>574200</cell>
                <cell>2016</cell>
                <cell>643100</cell>
                <cell>2024</cell>
                <cell>635700</cell>
              </row>
              <row>
                <cell>2009</cell>
                <cell>579800</cell>
                <cell>2017</cell>
                <cell>648200</cell>
                <cell>2025</cell>
                <cell>631400</cell>
              </row>
            </tabular>
            <image width="75%">
              <latex-image>
                \begin{tikzpicture}
                  \begin{axis}[
                      xmin=2000,
                      xmax=2025,
                      xtick={2000,2005,...,2025},
                      xlabel={year},
                      ymin=500000,
                      ymax=700000,
                      ytick={500000,550000,...,700000},
                      ylabel={population},
                      /pgf/number format/.cd,
                      use comma,
                      1000 sep={},
                      axis y discontinuity=crunch,
                      width=\orccaprintwidth,
                      height=0.33\orccaprintwidth,
                      axis line style={->},
                    ]
                    \addplot[soliddot]coordinates{$p};
                  \end{axis}
                \end{tikzpicture}
              </latex-image>
            </image>
          </introduction>
          <task>
            <statement>
              <p>
                Find the rate of change in Portland population between <var name="$yr[0]"/> and
                <var name="$yr[1]"/>.
              </p>
              <instruction>
                You can type the unit as <c>people/yr</c>.
              </instruction>
              <p>
                <var name="$r[0]" width="10"/>
              </p>
            </statement>
            <solution>
              <p>
                To find the rate of change between <var name="$yr[0]"/> and <var name="$yr[1]"/>,
                calculate
                <md>
                  \frac{<var name="$f{$yr[1]}"/>-<var name="$f{$yr[0]}"/>}{<var name="$yr[1]"/>-<var name="$yr[0]"/>}=<var name="$r[0]"/>
                </md>.
              </p>
            </solution>
          </task>
          <task>
            <statement>
              <p>
                And what was the rate of change between <var name="$yr[2]"/> and
                <var name="$yr[3]"/>?
              </p>
              <p>
                <var name="$r[1]" width="10"/>
              </p>
            </statement>
            <solution>
              <p>
                To find the rate of change between <var name="$yr[2]"/> and <var name="$yr[3]"/>,
                calculate
                <md>
                  \frac{<var name="$f{$yr[3]}"/>-<var name="$f{$yr[2]}"/>}{<var name="$yr[3]"/>-<var name="$yr[2]"/>}=<var name="$r[1]"/>
                </md>.
              </p>
            </solution>
          </task>
          <task>
            <statement>
              <p>
                List all the year-long intervals where there is a negative rate of change.
              </p>
              <instruction>
                (For example, you might answer with <c>[2000,2001], [2001,2002]</c> if you think
                those are the year-long intervals where there is a negative rate of change.)
              </instruction>
              <p>
                <var name="$d" width="20"/>
              </p>
            </statement>
            <solution>
              <p>
                The rate of change is negative for the years starting in 2003, 2019, and 2020, and
                no other years. These are the only years in the data table where the population goes
                down the next year. So the intervals are <var name="$d"/>.
              </p>
            </solution>
          </task>
          <task>
            <statement>
              <p>
                Over which decade was the rate of change highest?
              </p>
              <instruction>
                (For example, you might answer with <c>[2000,2010]</c> if you think that is the
                decade with the highest rate of change.)
              </instruction>
              <p>
                <var name="$s" width="20"/>
              </p>
            </statement>
            <solution>
              <p>
                The steepest rate of change over a ten-year period was from 2006 to 2016. To find
                this, calculate each of the rates of change from 2000 to 2010, from 2001 to 2011,
                and so on. Although looking at the graph, you can see that some rates of change are
                not as steep as others and narrow down the search. 
              </p>
              <image width="75%">
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin=2000,
                        xmax=2025,
                        xtick={2000,2005,...,2025},
                        xlabel={year},
                        ymin=500000,
                        ymax=700000,
                        ytick={500000,550000,...,700000},
                        ylabel={population},
                        /pgf/number format/.cd,
                        use comma,
                        1000 sep={},
                        axis y discontinuity=crunch,
                        width=\orccaprintwidth,
                        height=0.33\orccaprintwidth,
                        axis line style={->},
                      ]
                      \addplot[soliddot]coordinates{$p};
                      \addplot[firstcurve,-]coordinates{(2006,541026)(2016,643065)};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
            </solution>
          </task>
          <task>
            <statement>
              <p>
                What was that rate of change?
              </p>
              <instruction>
                You can type the unit as <c>people/yr</c>.
              </instruction>
              <p>
                <var name="$t" width="10"/>
              </p>
            </statement>
            <solution>
              <p>
                Between 2006 and 2016:
                <md>
                  \frac{<var name="$y[16]"/> - <var name="$y[6]"/>}{2016 - 2006} = <var name="$t"/>
                </md>
              </p>
            </solution>
          </task>
        </webwork>
      </exercise>
      <exercise label="tide-levels">
        <webwork xml:id="webwork-tide-levels">
          <pg-code>
            @x=(0..23);
            @y=(5.87,5.54,4.66,3.45,2.23,1.34,1.02,1.37,2.33,3.65,4.96,5.92,6.27,5.83,4.64,3.00,1.37,0.18,-0.26,0.19,1.41,3.07,4.74,5.95);
            %f=map{$x[$_] => $y[$_]}(0..23);
            @hr=num_sort(random_subset(4,@x));
            @r=map{Real(($f{$hr[2*$_+1]}-$f{$hr[2*$_]})/($hr[2*$_+1]-$hr[2*$_]))}(0,1);
            @r=map{NumberWithUnits("$_ ft/hr")}(@r);
            Context("Interval");
            $d=List('[0,6],[12,18]');
            $p=join(' ',(map{"($x[$_],$y[$_])"}(0..23)));
            $s=Interval('[21,22]');
            $t=NumberWithUnits($y[22]-$y[21],"ft/hr");
          </pg-code>
          <introduction>
            <p>
              This table gives the tide level in Lincoln City, Oregon, over one particular 24-hour
              period, measured in feet above average sea level.
            </p>
            <tabular>
              <col halign="right"/>
              <col right="medium" halign="left"/>
              <col halign="right"/>
              <col right="medium" halign="left"/>
              <col halign="right"/>
              <col halign="left"/>
              <row bottom="medium">
                <cell>Hour</cell>
                <cell>Tide Level</cell>
                <cell>Hour</cell>
                <cell>Tide Level</cell>
                <cell>Hour</cell>
                <cell>Tide Level</cell>
              </row>
              <row>
                <cell><m>0</m></cell>
                <cell><m>5.87</m></cell>
                <cell><m>8</m></cell>
                <cell><m>2.33</m></cell>
                <cell><m>16</m></cell>
                <cell><m>1.37</m></cell>
              </row>
              <row>
                <cell><m>1</m></cell>
                <cell><m>5.54</m></cell>
                <cell><m>9</m></cell>
                <cell><m>3.65</m></cell>
                <cell><m>17</m></cell>
                <cell><m>0.18</m></cell>
              </row>
              <row>
                <cell><m>2</m></cell>
                <cell><m>4.66</m></cell>
                <cell><m>10</m></cell>
                <cell><m>4.96</m></cell>
                <cell><m>18</m></cell>
                <cell><m>-0.26</m></cell>
              </row>
              <row>
                <cell><m>3</m></cell>
                <cell><m>3.45</m></cell>
                <cell><m>11</m></cell>
                <cell><m>5.92</m></cell>
                <cell><m>19</m></cell>
                <cell><m>0.19</m></cell>
              </row>
              <row>
                <cell><m>4</m></cell>
                <cell><m>2.23</m></cell>
                <cell><m>12</m></cell>
                <cell><m>6.27</m></cell>
                <cell><m>20</m></cell>
                <cell><m>1.41</m></cell>
              </row>
              <row>
                <cell><m>5</m></cell>
                <cell><m>1.34</m></cell>
                <cell><m>13</m></cell>
                <cell><m>5.83</m></cell>
                <cell><m>21</m></cell>
                <cell><m>3.07</m></cell>
              </row>
              <row>
                <cell><m>6</m></cell>
                <cell><m>1.02</m></cell>
                <cell><m>14</m></cell>
                <cell><m>4.64</m></cell>
                <cell><m>22</m></cell>
                <cell><m>4.74</m></cell>
              </row>
              <row>
                <cell><m>7</m></cell>
                <cell><m>1.37</m></cell>
                <cell><m>15</m></cell>
                <cell><m>3.00</m></cell>
                <cell><m>23</m></cell>
                <cell><m>5.95</m></cell>
              </row>
            </tabular>
            <image width="75%">
              <latex-image>
                \begin{tikzpicture}
                  \begin{axis}[
                      xmin=0,
                      xmax=24,
                      xlabel={hour},
                      xtick=,
                      minor xtick=,
                      ymin=-2,
                      ymax=8,
                      ylabel={tide level (ft)},
                      ytick=,
                      minor ytick=,
                      width=\orccaprintwidth,
                      height=0.33\orccaprintwidth,
                      x axis line style={->},
                    ]
                    \addplot[soliddot]coordinates{$p};
                  \end{axis}
                \end{tikzpicture}
              </latex-image>
            </image>
          </introduction>
          <task>
            <statement>
              <p>
                Find the rate of change in the tide level between hours <var name="$hr[0]"/> and
                <var name="$hr[1]"/>.
              </p>
              <p>
                <var name="$r[0]" width="10"/>
              </p>
            </statement>
            <solution>
              <p>
                To find the rate of change between hours <var name="$hr[0]"/> and
                <var name="$hr[1]"/>, calculate
                <md>
                  \frac{<var name="$f{$hr[1]}"/>-<var name="$f{$hr[0]}"/>}{<var name="$hr[1]"/>-<var name="$hr[0]"/>}=<var name="$r[0]"/>
                </md>.
              </p>
            </solution>
          </task>
          <task>
            <statement>
              <p>
                And what was the rate of change between hours <var name="$hr[2]"/> and
                <var name="$hr[3]"/>?
              </p>
              <p>
                <var name="$r[1]" width="10"/>
              </p>
            </statement>
            <solution>
              <p>
                To find the rate of change between hours <var name="$hr[2]"/> and
                <var name="$hr[3]"/>, calculate
                <md>
                  \frac{<var name="$f{$hr[3]}"/>-<var name="$f{$hr[2]}"/>}{<var name="$hr[3]"/>-<var name="$hr[2]"/>}=<var name="$r[1]"/>
                </md>.
              </p>
            </solution>
          </task>
          <task>
            <statement>
              <p>
                List the longest intervals where there is a negative rate of change without any
                times in between that have positive rates of change.
              </p>
              <p>
                <var name="$d" width="20"/>
              </p>
            </statement>
            <solution>
              <p>
                The rate of change is negative from hour 0 to hour 6, and again from hour 12 to
                hour 18. So the intervals are <var name="$d"/>.
              </p>
            </solution>
          </task>
          <task>
            <statement>
              <p>
                Over which hour-long interval was the rate of change highest?
              </p>
              <p>
                <var name="$s" width="20"/>
              </p>
            </statement>
            <solution>
              <p>
                The steepest rate of change happens from hour 21 to hour 22. To find this, we can
                calculate each of the rates of change from one hour to the next, and the largest
                result happens from hour 21 to hour 22.
              </p>
            </solution>
          </task>
          <task>
            <statement>
              <p>
                What was that rate of change?
              </p>
              <p>
                <var name="$t" width="10"/>
              </p>
            </statement>
            <solution>
              <p>
                Between hour 21 and 22:
                <md>
                  \frac{<var name="$y[22]"/> - <var name="$y[21]"/>}{22 - 21} = <var name="$t"/>
                </md>
              </p>
            </solution>
          </task>
        </webwork>
      </exercise>
      <exercise label="hood-training">
        <webwork xml:id="webwork-hood-training">
          <pg-macros>
            <macro-file>randomPerson.pl</macro-file>
          </pg-macros>
          <pg-code>
            $p = randomPerson();
            $newUnits = [
              {name=>'feet',conversion=>{factor=>12*2.54/100,m=>1}},
              {name=>'foot',conversion=>{factor=>12*2.54/100,m=>1}},
              {name=>'ft',conversion=>{factor=>12*2.54/100,m=>1}},
              {name=>'hour',conversion=>{factor=>60*60,s=>1}},
              {name=>'hours',conversion=>{factor=>60*60,s=>1}},
              {name=>'hr',conversion=>{factor=>60*60,s=>1}},
              {name=>'hrs',conversion=>{factor=>60*60,s=>1}},
              {name=>'h',conversion=>{factor=>60*60,s=>1}},
            ];
            @s=(
              NumberWithUnits("375 ft/h",{newUnit=>$newUnits}),
              NumberWithUnits("125 ft/h",{newUnit=>$newUnits}),
              NumberWithUnits("0 ft/h",{newUnit=>$newUnits}),
              NumberWithUnits("-500 ft/h",{newUnit=>$newUnits})
            );
          </pg-code>
          <statement>
            <p>
              <var name="$p"/> is training for a race up the slope of Mt.<nbsp/>Hood, from Sandy to
              Government Camp, and then back. The graph below models <var name="$p->their"/>
              elevation from their starting point as time passes. Find the slopes of the four line
              segments, and interpret their meanings in this context.
            </p>
            <image width="75%">
              <latex-image>
                \begin{tikzpicture}
                  \begin{axis}[
                        xlabel={time (h)},
                        ylabel={elevation (ft)},
                        xmin=0,
                        xmax=30,
                        ymin=0,
                        ymax=4000,
                        minor xtick={0,...,30},
                        xtick=,
                        ytick={0,500,...,3500},
                        minor ytick=,
                        width=\orccaprintwidth,
                        height=0.33\orccaprintwidth,
                        axis line style={->},
                      ]
                    \addplot[firstcurve,-] coordinates {(0,0) (8,3000) (12,3500) (21, 3500) (28,0)};
                  \end{axis}
                \end{tikzpicture}
              </latex-image>
            </image>
            <instruction>
              Enter the first segment's slope here.
            </instruction>
            <p>
              <var name="$s[0]" width="5" />
            </p>
            <instruction>
              Enter the second segment's slope here.
            </instruction>
            <p>
              <var name="$s[1]" width="5" />
            </p>
            <instruction>
              Enter the third segment's slope here.
            </instruction>
            <p>
              <var name="$s[2]" width="5" />
            </p>
            <instruction>
              Enter the fourth segment's slope here.
            </instruction>
            <p>
              <var name="$s[3]" width="5" />
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="skiing">
        <webwork xml:id="webwork-skiing">
          <pg-macros>
            <macro-file>randomPerson.pl</macro-file>
          </pg-macros>
          <pg-code>
            $p = randomPerson();
            $newUnits = [
              {name=>'feet',conversion=>{factor=>12*2.54/100,m=>1}},
              {name=>'foot',conversion=>{factor=>12*2.54/100,m=>1}},
              {name=>'ft',conversion=>{factor=>12*2.54/100,m=>1}},
            ];
            @s=(
              NumberWithUnits("0 ft/s",{newUnit=>$newUnits}),
              NumberWithUnits("-20/3 ft/s",{newUnit=>$newUnits}),
              NumberWithUnits("0 ft/s",{newUnit=>$newUnits}),
              NumberWithUnits("1 ft/s",{newUnit=>$newUnits})
            );
          </pg-code>
          <statement>
            <p>
              <var name="$p"/> is learning to ski on the slopes of Mt.<nbsp/>Hood. The graph below
              models <var name="$p->their"/> elevation from the ski park's base as time passes
              during one ski run on a small hill. Find the slopes of the four line segments, and
              interpret their meanings in this context.
            </p>
            <image width="75%">
              <latex-image>
                \begin{tikzpicture}
                  \begin{axis}[
                      xlabel={time (s)},
                      ylabel={elevation (ft)},
                      xmin=0,
                      xmax=300,
                      ymin=0,
                      ymax=250,
                      xtick={0,60,...,260},
                      minor xtick={10,20,...,360},
                      ytick={0,50,...,250},
                      minor ytick=,
                      width=\orccaprintwidth,
                      height=0.33\orccaprintwidth,
                      axis line style={->},
                      clip=false,
                    ]
                    \addplot[firstcurve,-] coordinates {(0,200) (30,200) (60,0) (100,0) (300,200)};
                  \end{axis}
                \end{tikzpicture}
              </latex-image>
            </image>
            <instruction>
              Enter the first segment's slope here.
            </instruction>
            <p>
              <var name="$s[0]" width="5" />
            </p>
            <instruction>
              Enter the second segment's slope here.
            </instruction>
            <p>
              <var name="$s[1]" width="5" />
            </p>
            <instruction>
              Enter the third segment's slope here.
            </instruction>
            <p>
              <var name="$s[2]" width="5" />
            </p>
            <instruction>
              Enter the fourth segment's slope here.
            </instruction>
            <p>
              <var name="$s[3]" width="5" />
            </p>
          </statement>
          <solution>
            <p>
              The first and third segments clearly have slope <m>0</m>. For the others, we need to
              indentify the coordinates of the points that begin and end each line segment:
              <m>(0,200)</m>, <m>(30,200)</m>, <m>(60,0)</m>, <m>(100,0)</m>, and <m>(300,200)</m>.
              For the second and fourth slopes:
            </p>
            <sidebyside>
              <p>
                <md>
                  <mrow>\amp\frac{0-200}{60-30}</mrow>
                  <mrow>\amp=\frac{-200}{30}</mrow>
                  <mrow>\amp=-6.66\ldots</mrow>
                </md>
              </p>
              <p>
                <md>
                  <mrow>\amp\frac{200-0}{300-100}</mrow>
                  <mrow>\amp=\frac{200}{200}</mrow>
                  <mrow>\amp=1</mrow>
                </md>
              </p>
            </sidebyside>
          </solution>
        </webwork>
      </exercise>
      <exercise label="liquid-leaking">
        <webwork xml:id="webwork-liquid-leaking">
          <pg-code>
            $b = random(800,1000,100);
            $h = random(10,30,5);
            $k = $b - random(100,200,100);
            $ans = NumberWithUnits(($k - $b)/$h, 'ml/min');
            $m = ($k - $b)/$h;
            $f = Formula("$m x + $b");
          </pg-code>
          <statement>
            <p>
              A liquid solution is slowly leaking from a container. This graph shows how many
              milliliters <m>y</m> of solution remains in the container after <m>x</m> minutes.
            </p>
            <image width="75%">
              <latex-image>
                \begin{tikzpicture}
                  \begin{axis}[
                      xlabel={\(x\) (min)},
                      ylabel={\(y\) (mL)},
                      xmin=0,
                      xmax=35,
                      ymin=0,
                      ymax=1100,
                      xtick={0,5,...,30},
                      minor xtick=,
                      ytick={0,100,...,1000},
                      minor ytick=,
                      width=\orccaprintwidth,
                      height=0.33\orccaprintwidth,
                      axis line style={->},
                    ]
                    \addplot+[-{Kite},domain=0:35] {$f};
                  \end{axis}
                \end{tikzpicture}
              </latex-image>
            </image>
            <p>
              What is the slope of this line, including units?
            </p>
            <p>
              <var name="$ans" width="16"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="cancer-slope">
        <webwork xml:id="webwork-cancer-slope">
          <pg-code>
            $newUnits = [
              {name=>'diagnoses'},
              {name=>'year',conversion=>{factor=>365*24*60*60,s=>1}},
              {name=>'years',conversion=>{factor=>365*24*60*60,s=>1}},
              {name=>'yr',conversion=>{factor=>365*24*60*60,s=>1}},
              {name=>'yrs',conversion=>{factor=>365*24*60*60,s=>1}},
              {name=>'y',conversion=>{factor=>365*24*60*60,s=>1}},
            ];
            $m=Real(248.719);
            Context()->flags->set(tolType=>'absolute',tolerance=>20);
            $rate = NumberWithUnits("$m diagnoses/yr",{newUnit=>$newUnits});
          </pg-code>
          <statement>
            <p>
              The graph plots the number of cancer diagnoses in Oregon over time, and a trend-line
              has been drawn.
            </p>
            <image width="75%">
              <latex-image>
                \begin{tikzpicture}
                  \begin{axis}[
                      xlabel={year},
                      ylabel={count},
                      ytick=,
                      xmin=2005,
                      xmax=2025,
                      ymin=15000,
                      ymax=26000,
                      axis line style={->},
                      xtick={2005,2010,...,2025},
                      xticklabels={2005,2010,...,2025},
                      xticklabel style={rotate=-45},
                      axis y discontinuity=crunch,
                      width=\orccaprintwidth,
                      height=0.33\orccaprintwidth,
                    ]
                    \addplot[only marks] coordinates {
                      (2007,19417)
                      (2008,20426)
                      (2009,19979)
                      (2010,19861)
                      (2011,20851)
                      (2012,20426)
                      (2013,21346)
                      (2014,21683)
                      (2015,22158)
                      (2016,22135)
                      (2017,23052)
                      (2018,22769)
                      (2019,24389)
                      (2020,21766)
                      (2021,22750)
                      (2022,22691)
                    };
                    \addplot+[domain=2005:2025] {248.719*(x - 2014.5) + 21606.1875};
                  \end{axis}
                \end{tikzpicture}
              </latex-image>
            </image>
            <p>
              Estimate the slope of the trend-line.
            </p>
            <instruction>
              You can type the unit as <c>diagnoses/yr</c>.
            </instruction>
            <p>
              <var name="$rate" width="10" />
            </p>
          </statement>
          <solution>
            <p>
              Do your best to identify two points on the line (which are not necessarily the plotted
              data points). With this line, it seems <m>(2008,20000)</m> and <m>(2020,23000)</m> are
              two such points.
            </p>
            <p>
              <md>
                \frac{\Delta y}{\Delta x}=\frac{(23000-20000)\,\text{diagnoses}}{(2020-2008)\,\text{yr}}=250\,\frac{\text{diagnoses}}{\text{yr}}
              </md>
            </p>
            <p>
              So the slope is about <m>250</m> diagnoses per year. This is only an estimate since we
              are not certain the two points we chose are actually on the line.
            </p>
          </solution>
        </webwork>
      </exercise>
    </subexercises>

    <subexercises>
      <title>Challenge</title>
      <exercise>
        <webwork seed="3">
          <pg-macros>
            <macro-file>parserPopUp.pl</macro-file>
          </pg-macros>
          <pg-code>
            Context("Fraction");
            $den = list_random(3,7,9,11);
            do {$num = random(1,$den-1,1)} until (gcd($num,$den) == 1);
            $slope[0] = Fraction($num,$den);
            Context("Numeric");
            $slope[1] = Real(Round($slope[0],1));
            $true = DropDownTF(1, showInStatic => 0);
            $false = DropDownTF(0, showInStatic => 0);
            $popup = ($slope[0] > $slope[1]) ? $true : $false;
          </pg-code>
          <statement>
            <p>
              True or False: A slope of <m><var name="$slope[0]"/></m> is steeper than a slope of
              <m><var name="$slope[1]"/></m>.
            </p>
            <p>
              <var name="$popup" form="popup"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise>
        <webwork seed="4">
          <pg-macros>
            <macro-file>parserPopUp.pl</macro-file>
          </pg-macros>
          <pg-code>
            Context("Fraction");
            $den = list_random(3,7,9,11);
            do {$num = random(1,$den-1,1)} until (gcd($num,$den) == 1);
            $slope[0] = Fraction($num,$den);
            Context("Numeric");
            $slope[1] = Real(Round($slope[0],1));
            $true = DropDownTF(1, showInStatic => 0);
            $false = DropDownTF(0, showInStatic => 0);
            $popup = ($slope[0] > $slope[1]) ? $true : $false;
          </pg-code>
          <statement>
            <p>
              True or False: A slope of <m><var name="$slope[0]"/></m> is steeper than a slope of
              <m><var name="$slope[1]"/></m>.
            </p>
            <p>
              <var name="$popup" form="popup"/>
            </p>
          </statement>
        </webwork>
      </exercise>
    </subexercises>
  </exercises>
</section>

