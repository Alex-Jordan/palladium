        <exercise label="slope-from-graph-zero-copy">
          <webwork copy="webwork-slope-from-graph-zero"/>
        </exercise>
        <exercise label="slope-from-graph-labeled-points">
          <webwork xml:id="webwork-slope-from-graph-labeled-points">
            <pg-code>
              Context("LimitedFraction")->flags->set(requirePureFractions => 1, showMixedNumbers => 0);
              do {
                @x = random_subset(2, 10 .. 80);
                @y = random_subset(2, 10 .. 80);
              } until (($x[0] - $x[1])**2 + ($y[0] - $y[1])**2 > 100);
              $m = Fraction($y[1] - $y[0], $x[1] - $x[0]);
              @dir;
              for (0,1) {
                if ($m > 0) {
                  $dir[$_] = ($x[$_] &lt; $x[($_ + 1) % 2]) ? 'below right' : 'above left';
                } else {
                  $dir[$_] = ($x[$_] &lt; $x[($_ + 1) % 2]) ? 'above right' : 'below left';
                }
              }
              Context("Numeric");
              Context()->noreduce('(-x)-y', '(-x)+y');
              $f = Formula("$m (x - $x[0]) + $y[0]");
              Context("Fraction");
              @p = map {Point($x[$_], $y[$_])} (0,1);
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin=-10,
                        xmax=100,
                        ymin=-10,
                        ymax=100,
                        xtick=,
                        minor xtick=,
                        ytick=,
                        minor ytick=,
                        width=0.33\orccaprintwidth
                      ]
                      \addplot+[-,domain=-10:100,samples=2] {$f};
                      \addplot[soliddot] coordinates {$p[0]} node[$dir[0]] {\($p[0]\)};
                      \addplot[soliddot] coordinates {$p[1]} node[$dir[1]] {\($p[1]\)};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="slope-from-graph-labeled-points-copy">
          <webwork copy="webwork-slope-from-graph-labeled-points"/>
        </exercise>
        <exercise label="slope-from-graph-labeled-points-decimal">
          <webwork xml:id="webwork-slope-from-graph-labeled-points-decimal">
            <pg-code>
              do {
                @x = map {$_ + random(0.1,0.9,0.1)} (random_subset(2, 10 .. 80));
                @y = map {$_ + random(0.1,0.9,0.1)} (random_subset(2, 10 .. 80));
              } until (($x[0] - $x[1])**2 + ($y[0] - $y[1])**2 > 100);
              $m = ($y[1] - $y[0]) / ($x[1] - $x[0]);
              @dir;
              for (0,1) {
                if ($m > 0) {
                  $dir[$_] = ($x[$_] &lt; $x[($_ + 1) % 2]) ? 'below right' : 'above left';
                } else {
                  $dir[$_] = ($x[$_] &lt; $x[($_ + 1) % 2]) ? 'above right' : 'below left';
                }
              }
              Context("Numeric");
              $f = Formula("$m (x - $x[0]) + $y[0]");
              Context("Fraction");
              @p = map {Point($x[$_], $y[$_])} (0,1);
              @domain = num_sort(-10, 100, (-10 - $y[0])/$m + $x[0], (100 - $y[0])/$m + $x[0]);
              ($l,$r) = (@domain)[1,2];
            </pg-code>
            <statement>
              <image>
                <latex-image>
                  \begin{tikzpicture}
                    \begin{axis}[
                        xmin=-10,
                        xmax=100,
                        ymin=-10,
                        ymax=100,
                        xtick=,
                        minor xtick=,
                        ytick=,
                        minor ytick=,
                        width=0.33\orccaprintwidth,
                        clip=false
                      ]
                      \addplot+[-,domain=$l:$r,samples=2] {$f};
                      \addplot[soliddot] coordinates {$p[0]} node[$dir[0]] {\($p[0]\)};
                      \addplot[soliddot] coordinates {$p[1]} node[$dir[1]] {\($p[1]\)};
                    \end{axis}
                  \end{tikzpicture}
                </latex-image>
              </image>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="slope-from-graph-labeled-points-decimal-copy">
          <webwork copy="webwork-slope-from-graph-labeled-points-decimal"/>
        </exercise>
      </exercisegroup>

      <exercisegroup cols="2">
        <title>Find the Steepest</title>
        <introduction>
          <p>
            Determine the steepest slope for a line connecting two points from the list.
          </p>
        </introduction>
        <exercise label="find-the-steepest">
          <webwork xml:id="webwork-find-the-steepest">
            <pg-code>
              @x = num_sort(random_subset(3, 1..9));
              @y = num_sort(random_subset(3, 1..19));
              Context("LimitedFraction")->flags->set(requirePureFractions => 1, showMixedNumbers => 0);
              $m[0] = Fraction($y[1] - $y[0], $x[1] - $x[0]);
              $m[1] = Fraction($y[2] - $y[0], $x[2] - $x[0]);
              $m[2] = Fraction($y[2] - $y[1], $x[2] - $x[1]);
              $m = max(@m);
              Context("Point");
              @p = map {Point($x[$_], $y[$_])} (0..2);
              @p = random_subset(3, @p);
            </pg-code>
            <statement>
              <p>
                <m><var name="$p[0]"/></m>, <m><var name="$p[1]"/></m>, <m><var name="$p[2]"/></m>
              </p>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="find-the-steepest-copy">
          <webwork copy="webwork-find-the-steepest"/>
        </exercise>
        <exercise label="find-the-steepest-large">
          <webwork xml:id="webwork-find-the-steepest-large">
            <pg-code>
              @x = num_sort(random_subset(3, -90..90));
              @y = num_sort(random_subset(3, -90..90));
              Context("LimitedFraction")->flags->set(requirePureFractions => 1, showMixedNumbers => 0);
              $m[0] = Fraction($y[1] - $y[0], $x[1] - $x[0]);
              $m[1] = Fraction($y[2] - $y[0], $x[2] - $x[0]);
              $m[2] = Fraction($y[2] - $y[1], $x[2] - $x[1]);
              $m = max(@m);
              Context("Point");
              @p = map {Point($x[$_], $y[$_])} (0..2);
              @p = random_subset(3, @p);
            </pg-code>
            <statement>
              <p>
                <m><var name="$p[0]"/></m>, <m><var name="$p[1]"/></m>, <m><var name="$p[2]"/></m>
              </p>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="find-the-steepest-large-copy">
          <webwork copy="webwork-find-the-steepest-large"/>
        </exercise>
        <exercise label="find-the-steepest-decimal">
          <webwork xml:id="webwork-find-the-steepest-decimal">
            <pg-code>
              @x = map {$_/10} (num_sort(random_subset(3, -90..90)));
              @y = map {$_/10} (num_sort(random_subset(3, -90..90)));
              $m[0] = ($y[1] - $y[0])/($x[1] - $x[0]);
              $m[1] = ($y[2] - $y[0])/($x[2] - $x[0]);
              $m[2] = ($y[2] - $y[1])/($x[2] - $x[1]);
              $m = max(@m);
              Context("Point");
              @p = map {Point($x[$_], $y[$_])} (0..2);
              @p = random_subset(3, @p);
            </pg-code>
            <statement>
              <p>
                <m><var name="$p[0]"/></m>, <m><var name="$p[1]"/></m>, <m><var name="$p[2]"/></m>
              </p>
              <p>
                <var name="$m" width="10"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="find-the-steepest-decimal-copy">
          <webwork copy="webwork-find-the-steepest-decimal"/>
        </exercise>
      </exercisegroup>

      <exercisegroup cols="2">
        <title>Plot Slope Through a Point</title>
        <introduction>
          <p>
            Plot a line through the given point that has the given slope.
          </p>
        </introduction>
        <exercise label="plot-slope">
          <webwork xml:id="webwork-plot-slope">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
            <pg-code>
              ($rise, $run) = random_coprime([1..5],[2..5]);
              ($h,$k) = random_subset(2, -5..-1,1..3);
              ($u,$v) = ($h+$run,$k+$rise);
              Context("Numeric");
              $A = Point($h,$k);
              $B = Point($u,$v);
              Context("Fraction");
              $m = Fraction($rise,$run);              
              $gt = GraphTool("{line,solid,$A,$B}")->with(
              showInStatic => 0,
              availableTools => ["LineTool"],
              showCoordinateHints => 0,
              bBox => [-8, 8, 8, -8],
              cmpOptions => {
              list_checker => sub {
              my ($correct, $student, $ans, $value) = @_;
              return 0 if $ans->{isPreview};
              my @errors;
              my $count = 0;
              my $distinct = 0;
              my $extra = 0;
              STUDENTS:
              for my $j (@$student) {
              my $nth = Value::List->NameForNumber(++$count);
              my ($p1x, $p1y) = $j->extract(3)->value;
              my ($p2x, $p2y) = $j->extract(4)->value;
              if ($p1x == $p2x) {
              push(@errors, "The $nth plotted line is a vertical line, and therefore does not have slope $m.");
              $extra++;
              next STUDENTS;
              }
              my $context = Context();
              Context("Fraction");
              my $slope = Fraction($p2y - $p1y, $p2x - $p1x);
              Context($context);
              if ($slope != $m) {
              push(@errors, "The $nth plotted line has slope $slope, not slope $m.");
              $extra++;
              next STUDENTS;
              }
              if ($k != $slope*($h - $p1x) + $p1y) {
              push(@errors, "The $nth plotted line does not pass through $A.");
              $extra++;
              next STUDENTS;
              }
              for my $i (0..($count-2)) {
              my ($x,$y) = $student->[$i]->extract(3)->value;
              next STUDENTS if ($y == $m*($x - $p1x) + $p1y);
              }
              $distinct++;
              }
              return (max(scalar(@{$correct}),scalar(@{$student}))*min($distinct,1)/1/(($extra)?2:1), @errors);
              }
              }
              );  
            </pg-code>
            <statement>
              <p>
                Through <m><var name="$A"/></m> with slope <m><var name="$m"/></m>.
              </p>
              <p>
                <var name="$gt" width="1"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="plot-slope-copy">
          <webwork copy="webwork-plot-slope"/>
        </exercise>
        <exercise label="plot-slope-negative">
          <webwork xml:id="webwork-plot-slope-negative">
            <pg-macros>
              <macro-file>parserGraphTool.pl</macro-file>
            </pg-macros>
