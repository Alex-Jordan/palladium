      <exercise label="median-rent-solve-equation">
        <webwork xml:id="webwork-median-rent-solve-equation">
          <pg-code>
            $decimal = random(0.01,0.03,0.001);
            Context("Currency")->flags->set(trimTrailingZeros => 1, tolerance => 0.5);
            $final = 1400 + random(-300, 300, 10);
