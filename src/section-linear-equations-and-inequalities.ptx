            <pg-code>
              $x = list_random('a'..'n', 'p'..'z', 'A'..'D', 'F'..'N', 'P'..'T', 'V'..'Z');
              Context('Fraction')->variables->are($x => 'Real');
              do {
                ($m, $n) = random_subset(2, -9..-1, 1..9);
                $b = list_random(-9..-2, 2..9);
                $sol = Fraction($b, $m - $n);
              } until (($sol->value)[1] != 1);
              Context()->noreduce('(-x)-y', '(-x)+y');
              $left = Formula("$m $x")->reduce;
              $right = Formula("$n $x + $b")->reduce;
