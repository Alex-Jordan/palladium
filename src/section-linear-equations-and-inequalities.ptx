        <exercise label="more-step-fraction-mgroupxplusbminusgroupnxpluscequalsd">
          <webwork xml:id="webwork-more-step-fraction-mgroupxplusbminusgroupnxpluscequalsd">
            <pg-code>
              $x = list_random('a'..'n', 'p'..'z', 'A'..'D', 'F'..'N', 'P'..'T', 'V'..'Z');
              Context("Fraction")->variables->are($x => 'Real');
              do {
                ($m, $n) = random_subset(2, -9..-2, 2..9);
                ($b, $c, $d) = random_subset(3, -9..-1, 1..9);
              } until (($d + $c - $m*$b) % ($m - $n) != 0);
              $sol = Fraction($d + $c - $m*$b, $m - $n);
              Context()->noreduce('(-x)-y', '(-x)+y');
              $left = Formula("$m ($x + $b) - ($n $x + $c)")->reduce;
              $right = Formula("$d")->reduce;
              Context("FiniteSolutionSets");
              Context()->variables->are($x => 'Real');
              $solset = Formula("{$sol}");
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solset" width="16"/>
