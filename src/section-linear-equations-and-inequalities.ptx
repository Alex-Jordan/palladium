      <exercisegroup cols="2">
        <title>Triangle Area</title>
        <introduction>
          <p>
            The area of a triangle is given by <m>A=\frac12bh</m>, where <m>b</m> is the base width,
            and <m>h</m> is the height.
          </p>
          <image width="33%">
            <latex-image>
              \begin{tikzpicture}
                \draw[fill=firstcolor!20!white,thick] (0,0) -| (3,2) -- cycle;
                \node at (1.5,0) [below] {base \(b\)};
                \draw [rightangle] (3,0.2) -| (2.8,0);
                \node at (3,1) [right] {height \(h\)};
                \node at (2,1) [below] {area \(A\)};
              \end{tikzpicture}
            </latex-image>
          </image>
        </introduction>
        <exercise label="isolate-triangleareaforbase">
          <webwork xml:id="webwork-isolate-triangleareaforbase">
            <pg-code>
              Context("Fraction")->variables->are(A => 'Real', b => 'Real', h => 'Real');
              parser::Assignment->Allow;
              $ans = Assignment("b = (2A)/h");
            </pg-code>
            <statement>
              <p>
                Solve the equation <m>A=\frac12bh</m> for <m>b</m>.
              </p>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                We need to keep our focus on <m>b</m> and take algebra steps that bring us closer to
                isolating <m>b</m>.
                <md>
                  <mrow>A \amp= \frac12bh</mrow>
                  <mrow>2A \amp= bh</mrow>
                  <mrow>\frac{2A}{h} \amp= b</mrow>
                  <mrow>b \amp= \frac{2A}{h}</mrow>
                </md>
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="isolate-triangleareaforheight">
          <webwork xml:id="webwork-isolate-triangleareaforheight">
            <pg-code>
              Context("Fraction")->variables->are(A => 'Real', b => 'Real', h => 'Real');
              parser::Assignment->Allow;
              $ans = Assignment("h = (2A)/b");
            </pg-code>
            <statement>
              <p>
                Solve the equation <m>A=\frac12bh</m> for <m>h</m>.
              </p>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
      </exercisegroup>
      <exercisegroup cols="2">
        <title>Slope-Intercept Form</title>
        <introduction>
          <p>
            The equation for a line in <q>slope-intercept form</q> is <m>y=mx+b</m>.
          </p>
          <image width="47%">
            <latex-image>
              \begin{tikzpicture}
                \begin{axis}[
                    xtick={0},
                    ytick={0},
                    minor xtick=,
                    minor ytick=,
                    ymin=-1,
                    ymax=5,
                    width=0.47\orccaprintwidth,
                    height=0.2\orccaprintwidth,
                  ]
                  \addplot+ {1/3*x + 2};
                  \draw[guideline] (axis cs:0,0) -- (axis cs:0.2,0) -- node[pos=0.5, right]{\(b\)} (axis cs:0.2,2) -- (axis cs:0,2);
                  \draw[guideline] (axis cs:0,2) -- node[pos=0.5, below]{\(1\)} (axis cs:3,2) -- node[pos=0.5, right]{\(m\)} (axis cs:3,3);
                \end{axis}
              \end{tikzpicture}
            </latex-image>
          </image>
        </introduction>
        <exercise label="isolate-slopeinterceptform">
          <webwork xml:id="webwork-isolate-slopeinterceptform">
            <pg-code>
              @x = qw(y m x b);
              Context("Fraction")->variables->are(map {$_ => 'Real'} (@x));
              parser::Assignment->Allow;
              $ans = Assignment("m = (y - b)/x");
            </pg-code>
            <statement>
              <p>
                Solve the equation for <m>m</m>.
              </p>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="isolate-slopeinterceptforb">
          <webwork xml:id="webwork-isolate-slopeinterceptforb">
            <pg-code>
              @x = qw(y m x b);
              Context("Fraction")->variables->are(map {$_ => 'Real'} (@x));
              parser::Assignment->Allow;
              $ans = Assignment("b = y - mx");
            </pg-code>
            <statement>
              <p>
                Solve the equation for <m>b</m>.
              </p>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
      </exercisegroup>
      <exercisegroup cols="2">
        <title>Circle Circumference</title>
        <introduction>
          <p>
            The circumference of a circle can be found with the equation <m>c=2\pi r</m>, where
            <m>r</m> is the radius, or with the equation <m>c=\pi d</m>, where <m>d</m> is the
            diameter.
          </p>
          <image width="40%">
            <latex-image>
              \begin{tikzpicture}[x=1.8cm,y=1.8cm]
              \draw[
                  thick,
                  fill=secondcolor!20!white,
              ] (1,0) arc (270:-90:1);
              \path[
                  postaction={
                      decorate,
                      decoration={
                          text along path,
                          text align=center,
                          transform={yshift=1ex},
                          text={circumference ~~$c~~$}
                      }
                  }
              ] (1,0) arc (270:-90:1);
              \draw[thick] (1,1) -- node[pos=0.5, above] {radius \(r\)} (2,1);
              \draw[
                  thick,
                  fill=secondcolor!20!white,
              ] (3.5,0) arc (270:-90:1);
              \path[
                  postaction={
                      decorate,
                      decoration={
                          text along path,
                          text align=center,
                          transform={yshift=1ex},
                          text={circumference ~~$c~~$}
                      }
                  }
              ] (3.5,0) arc (270:-90:1);
              \draw[thick] (2.5,1) -- node[pos=0.5, above] {diameter \(d\)} (4.5,1);
              \node at (0,2.2) {};
              \end{tikzpicture}
            </latex-image>
          </image>
        </introduction>
        <exercise label="isolate-circumferenceforr">
          <webwork xml:id="webwork-isolate-circumferenceforr">
            <pg-code>
              @x = qw(c r);
              Context("Fraction")->variables->are(map {$_ => 'Real'} (@x));
              parser::Assignment->Allow;
              $ans = Assignment("r = c/(2 pi)");
            </pg-code>
            <statement>
              <p>
                Solve the equation <m>c=2\pi r</m> for <m>r</m>.
              </p>
              <instruction>
                You may type <m>\pi</m> as <c>pi</c> or <c>π</c>.
              </instruction>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="isolate-circumferenceford">
          <webwork xml:id="webwork-isolate-circumferenceford">
            <pg-code>
              @x = qw(c d);
              Context("Fraction")->variables->are(map {$_ => 'Real'} (@x));
              parser::Assignment->Allow;
              $ans = Assignment("d = c/pi");
            </pg-code>
            <statement>
              <p>
                Solve the equation <m>c=\pi d</m> for <m>d</m>.
              </p>
              <instruction>
                You may type <m>\pi</m> as <c>pi</c> or <c>π</c>.
              </instruction>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
      </exercisegroup>
      <exercisegroup cols="2">
        <title>Cylinders</title>
        <introduction>
          <p>
            The volume of a cylinder can be found with the equation <m>V=\pi r^2h</m>, where
            <m>r</m> is the radius and <m>h</m> is the height. Its surface area can be found with
            the equation <m>A=2\pi r^2+2\pi rh</m>.
          </p>
          <image width="50%">
            <latex-image>
              \begin{tikzpicture}
                \draw[fill=firstcolor!20] (0,0) ellipse (3 and 0.45);
                \draw[fill=firstcolor!10] (3,0) arc (0:180:3 and -0.45) -- (-3,-2) arc (180:360:3 and 0.5) -- cycle;
                \draw [dashed] (-3,-2) arc (180:360:3 and -0.5);
                \draw [dashed] (0,0) -- (3,0) node[pos=0.5,above] {radius \(r\)};
                \node at (-3,-1) [left] {height \(h\)};
              \end{tikzpicture}
            </latex-image>
          </image>
        </introduction>
        <exercise label="isolate-cylindervolumeforh">
          <webwork xml:id="webwork-isolate-cylindervolumeforh">
            <pg-code>
              @x = qw(V r h);
              Context("Fraction")->variables->are(map {$_ => 'Real'} (@x));
              $left = Formula("V")->reduce;
              $right = Formula("pi r^2 h")->reduce;
              parser::Assignment->Allow;
              $ans = Assignment("h = V/(pi r^2)");
            </pg-code>
            <statement>
              <p>
                Solve <m><var name="$left"/>=<var name="$right"/></m> for <m>h</m>.
              </p>
              <instruction>
                You may type <m>\pi</m> as <c>pi</c> or <c>π</c>.
              </instruction>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="isolate-cylinderareaforh">
          <webwork xml:id="webwork-isolate-cylinderareaforh">
            <pg-code>
              @x = qw(A r h);
              Context("Fraction")->variables->are(map {$_ => 'Real'} (@x));
              $left = Formula("A")->reduce;
              $right = Formula("2 pi r^2 + 2 pi r h")->reduce;
              parser::Assignment->Allow;
              $ans = Assignment("h = (A - 2 pi r^2)/(2 pi r)");
            </pg-code>
            <statement>
              <p>
                Solve <m><var name="$left"/>=<var name="$right"/></m> for <m>h</m>.
              </p>
              <instruction>
                You may type <m>\pi</m> as <c>pi</c> or <c>π</c>.
              </instruction>
              <p>
                <var name="$ans" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
      </exercisegroup>
      <exercise label="running-with-fractions">
        <webwork>
          <pg-macros>
            <macro-file>randomPerson.pl</macro-file>
          </pg-macros>
          <pg-code>
            $p = randomPerson();
            $b = random(10,20);
            do {
              $m = random(5,5.7,0.01);
              $d = random(3,6);
              $n = int($m*$d);
              $m = $n/$d;
              $c = random(60,100,5);
              $sol = ($c - $b)/$m;
              ($n,$d) = map{$_/gcd($n,$d)} ($n,$d);
            } until ($d >= 3 &amp;&amp; $m > 4.5 &amp;&amp; $sol != int($sol));
            $num = NumberWithUnits("$n m");
            $den = NumberWithUnits("$d s");
            $initial = NumberWithUnits("$b m");
            $final = NumberWithUnits("$c m");
            Context()->flags->set(reduceConstants => 0);
            $answer = FormulaWithUnits("$sol s");
          </pg-code>
          <statement>
            <p>
              <var name="$p"/> is running on a track. We start the clock as <var name="$p->they"/>
              <var name="$p->verb('pass')"/> the <var name="$initial"/> mark, and
              <var name="$p->they"/> <var name="$p->are"/> running
              <var name="$num"/> every <var name="$den"/>. How long does it take for
              <var name="$p"/> to reach the <var name="$final"/> mark?
            </p>
            <p>
              <var name="$answer" width="5"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="gas-mileage-with-fractions">
        <webwork>
          <pg-macros>
            <macro-file>randomPerson.pl</macro-file>
          </pg-macros>
          <pg-code>
            $name = randomPerson();
            $initial = random(12, 18);
            $start = NumberWithUnits("$initial gal");
            Context("Fraction");
            @rates = map {Fraction(2/(2*$_-1))} (20..25);
            push @rates, map {Fraction(3/(3*$_-1))} (20..25);
            push @rates, map {Fraction(3/(3*$_+1))} (20..25);
            push @rates, map {Fraction(4/(4*$_-1))} (20..25);
            push @rates, map {Fraction(4/(4*$_+1))} (20..25);
            $rate = list_random(@rates);
            $speed = FormulaWithUnits("$rate gal");
            $final = 1;
            $end = NumberWithUnits("$final gal");
            $solution = ($initial - $final)/$rate;
            Context("Numeric")->flags->set(reduceConstants => 0);
            $distance = FormulaWithUnits("$solution mi");
          </pg-code>
          <statement>
            <p>
              <var name="$name"/> filled the gas tank in <var name="$name->possessive"/> car to
              <m><var name="$start"/></m>. When the tank reaches <m><var name="$end"/></m>, the low
              gas light will come on. On average, <var name="$name"/>'s car uses
              <m><var name="$speed"/></m> per mile driven. How many miles will <var name="$name"/>'s
              car be able to drive before the low gas light comes on?
            </p>
            <p>
              <var name="$distance" width="20"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="tree-height-solve-equation-copy3">
        <webwork copy="webwork-tree-height-solve-equation"/>
      </exercise>
      <exercise label="tire-pressure-with-fractions">
        <webwork>
          <pg-code>
            $initial = random(20,25);
            $start = NumberWithUnits("$initial psi");
            Context("Fraction");
            $rate = list_random(
              [3,2], [5,2], [4,3],  [5,3],  [7,3],  [8,3],  [5,4], [7,4],  [9,4], [11,4],  [6,5],
              [7,5], [8,5], [9,5], [11,5], [12,5], [13,5], [14,5], [7,6], [11,6], [13,6], [17,6]
            );
            $rate = Fraction(($rate->[0])/($rate->[1]));
            $speed = FormulaWithUnits("$rate psi/min");
            $final = random(30,34);
            $end = NumberWithUnits("$final psi");
            $solution = ($final - $initial)/$rate;
            Context("Numeric")->flags->set(reduceConstants => 0);
            $time = FormulaWithUnits("$solution min");
          </pg-code>
          <statement>
            <p>
              One of the tires on your car looks a little flat. You measure its air pressure
              and are alarmed to see it so low at <m><var name="$start"/></m>. You have a
              portable device that can pump air into the tire increasing the pressure at a rate of
              <m><var name="$speed"/></m>. How long will it take to fill the tire to the
              manual's recommended pressure of <m><var name="$end"/></m>?
            </p>
            <p>
              <var name="$time" width="20"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="grade-average">
        <webwork xml:id="webwork-grade-average">
          <pg-macros>
            <macro-file>randomPerson.pl</macro-file>
          </pg-macros>
          <pg-code>
            $p = randomPerson();
            do {
              $homework = random(80,100);
              $midterm = random(70,90);
              $goal = list_random(70,80,90);
              $sol = 3*($goal - ($homework/2 + $midterm/6));
            } until ($goal > 0 &amp;&amp; $goal &lt; 100);
          </pg-code>
          <statement>
            <p>
              In one college math course, the final grade (out of <m>100</m> points) is calculated
              by adding one-half of the homework average, one-sixth of the midterm score, and
              one-third of the final exam score.
            </p>
            <p>
              <var name="$p"/> has <var name="$homework"/> for <var name="$p->their"/> homework
              average and <var name="$midterm"/> for <var name="$p->their"/> midterm score.
              <var name="$p->Their"/> goal is to finish the course with a final grade of
              <var name="$goal"/>. What must <var name="$p->they"/> score on the final exam?
            </p>
            <p>
              <var name="$sol" width="5"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="grade-average2">
        <webwork>
          <pg-macros>
            <macro-file>randomPerson.pl</macro-file>
          </pg-macros>
          <pg-code>
            $p = randomPerson();
            do {
              $homework = random(60,90);
              $project = random(80,100);
              $midterm = random(70,90);
              $goal = list_random(70,80,90);
              $sol = 4*($goal - ($homework/3 + $project/6 + $midterm/4));
            } until ($goal > 0 &amp;&amp; $goal &lt; 100);
          </pg-code>
          <statement>
            <p>
              In one college math course, the final grade (out of <m>100</m> points) is calculated
              by adding one-third of the homework average, one-sixth of the class project score,
              one-fourth of the midterm score, and one-fourth of the final exam score.
            </p>
            <p>
              <var name="$p"/> has <var name="$homework"/> for <var name="$p->their"/> homework
              average, <var name="$project"/> for <var name="$p->their"/> class project score, and
              <var name="$midterm"/> for <var name="$p->their"/> midterm score.
              <var name="$p->Their"/> goal is to finish the course with a final grade of
              <var name="$goal"/>. What must <var name="$p->they"/> score on the final exam?
            </p>
            <p>
              <var name="$sol" width="16"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="soup-recipe">
        <webwork xml:id="webwork-soup-recipe">
          <pg-code>
            $recipe = random(10,20,5);
            ($volA, $volB) = random_subset(2, 1, 1.25, 1.5, 1.75, 2.25, 2.5, 2.75);
            $ans = $volB*$recipe/$volA;
            $answer = NumberWithUnits("$ans g");
          </pg-code>
          <statement>
            <p>
              An old cookbook has a recipe for soup that uses <m><var name="$recipe"/></m> g of
              flour for thickener. The recipe makes <m><var name="$volA"/></m> gal of soup, but you
              are adjusting it to make <m><var name="$volB"/></m> gal. How much flour should you
              use?
            </p>
            <p>
              <var name="$answer" width="16"/>
            </p>
          </statement>
          <solution>
            <p>
              Let <m>x</m> be how many grams of flour we should use. The amount of flour is
              proportional to the amount of soup, so we can compare the ratios of flour to soup for
              our batch with the original recipe:
              <md>\frac{x}{<var name="$volB"/>} = \frac{<var name="$recipe"/>}{<var name="$volA"/>}</md>
              These denominators are not whole numbers, and we decide not to try using the least
              common multiple. Instead, we just multiply on each side by both denominators:
              <md>
                <mrow><var name="$volA"/>\cdot <var name="$volB"/>\cdot \frac{x}{<var name="$volB"/>} \amp= <var name="$volA"/>\cdot <var name="$volB"/>\cdot \frac{<var name="$recipe"/>}{<var name="$volA"/>} </mrow>
                <mrow><var name="$volA"/> x \amp= <var name="$recipe*$volB"/></mrow>
                <mrow>x \amp= \frac{<var name="$recipe*$volB"/>}{<var name="$volA"/> }</mrow>
                <mrow>x \amp= <var name="$ans"/></mrow>
              </md>
              So we should use <m><var name="$answer"/></m> of flour.
            </p>
          </solution>
        </webwork>
      </exercise>
      <exercise label="garam-masala-recipe-solved">
        <webwork>
          <pg-code>
            ($recipeA, $recipeB) = random_subset(2, 1, 1.25, 1.33, 1.5, 1.67, 1.75, 2, 2.25, 2.33, 2.5, 2.67, 2.75);
            $volA = random(3,4);
            $ans = $recipeB*$volA/$recipeA;
            $tbsp = {name => 'tbsp', conversion => {factor =>1.4787*10**-5, m=>3}};
            $answer = NumberWithUnits("$ans tbsp", {newUnit=>$tbsp});
            $spice = list_random("cumin", "coriander", "cardamom", "black pepper", "cinnamon", "cloves", "nutmeg");
          </pg-code>
          <statement>
            <p>
              An internet recipe for <m><var name="$volA"/></m> tbsp of garam masala calls for 
              <m><var name="$recipeA"/></m> tbsp of ground <var name="$spice"/>. You want to use up
              the last of your ground <var name="$spice"/> supply, which is
              <m><var name="$recipeB"/></m> tbsp. Assuming you have enough of all of the other
              ingredients, how much garam masala will you make?
            </p>
            <p>
              <var name="$answer" width="16"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="apples-cost-solved">
        <webwork xml:id="webwork-apples-cost-solved">
          <pg-macros>
            <macro-file>randomPerson.pl</macro-file>
          </pg-macros>
          <pg-code>
            @p = randomPerson(n => 2);
            @w = (random(50,70), random(80,90));
            do {
              $price = random(0.7,1.2,0.01);
            } until ($price != 1);
            Context("Currency");
            @c = map {Currency($_*$price)} (@w);
          </pg-code>
          <statement>
            <p>
              <var name="$p[0]"/> and <var name="$p[1]"/> went to the weekend market to buy apples
              in bulk for a school event, canning lots of applesauce. <var name="$p[0]"/> bought
              <var name="$w[0]"/> lb of apples and paid <var name="$c[0]"/>. <var name="$p[1]"/>
              has bagged <var name="$p[1]->their"/> apples and has <var name="$w[1]"/> lb of apples
              ready. How much will it <var name="$p[1]"/>'s bag of apples cost?
            </p>
            <p>
              <var name="$c[1]" width="16"/>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="architect-model-solved">
        <webwork>
          <pg-macros>
            <macro-file>randomPerson.pl</macro-file>
          </pg-macros>
          <pg-code>
            $p = randomPerson();
            $building = random(30,80,2);
            $model = random(2,10);
            Context("Fraction");
            $ans = $model/($building)*5.5;
            $answer = FormulaWithUnits("$ans in");
            @aux[0] = 5.5*$model;
          </pg-code>
          <statement>
            <p>
              <var name="$p"/> is an architect and <var name="$p->they"/> <var name="$p->are"/>
              making a scale model of a building. The actual building will be
              <m><var name="$building"/></m> ft tall. In the model, the height of the building will
              be <m><var name="$model"/></m> in tall and there will be a little model person
              standing next to the building. How tall should <var name="$p"/> make the model of that
              person who is meant to represent a <m>5</m> ft <m>6</m> in tall person?
            </p>
            <p>
              <var name="$answer" width="16"/>
            </p>
          </statement>
          <solution>
            <p>
              Let <m>h</m> be the height of the person in <var name="$p"/>'s model, which we'll
              measure in inches. We'll create a proportional equation that compares the building and
              person's heights in the model to their heights in real life:
              <md>
                <mrow>\frac{\text{height of model building in inches}}{\text{height of actual building in feet}}\amp=\frac{\text{height of model person in inches}}{\text{height of actual person in feet}}</mrow>
                <mrow>\frac{<var name="$model"/>\,\text{in}}{<var name="$building"/>\,\text{ft}}\amp=\frac{h\,\text{in}}{5\,\text{ft}\,6\text{in}}</mrow>
              </md>
              Before we can just eliminate the units, we'll need to convert
              <quantity>
                <mag>5</mag><unit base="foot"/>
              </quantity><nbsp/><quantity>
                <mag>6</mag><unit base="inch"/>
              </quantity>
              to feet:
              <md>
                \frac{2\,\text{in}}{30\,\text{ft}}=\frac{h\,\text{in}}{5.5\,\text{ft}}
              </md>
              Now we can remove the units and continue solving:
              <md>
                <mrow>\frac{<var name="$model"/>}{<var name="$building"/>}\amp=\frac{h}{5.5}</mrow>
                <mrow>\multiplyleft{<var name="$building"/>\cdot5.5}\frac{<var name="$model"/>}{<var name="$building"/>}\amp=\frac{h}{5.5}\multiplyright{<var name="$building"/>\cdot5.5}</mrow>
                <mrow>5.5\cdot <var name="$model"/> \amp= <var name="$building"/>h</mrow>
                <mrow><var name="$aux[0]"/> \amp= <var name="$building"/>h</mrow>
                <mrow>h\amp\approx <var name="$ans"/></mrow>
              </md>
              <var name="$p"/> should make the model be <m><var name="$answer"/></m> tall.
            </p>
          </solution>
        </webwork>
      </exercise>
      <exercise label="rocky-mountain-elk-solved">
        <webwork>
          <pg-code>
            $tt = random(30,40);
            $sp = $tt + random(5,12);
            $st = random(8,15);
            $ans = Round($tt*$sp/$st);
          </pg-code>
          <statement>
            <p>
              To estimate the health of the Rocky Mountain elk population in the Wenaha Wildlife
              Area, the Oregon Department of Fish and Wildlife caught, tagged, and released
              <m><var name="$tt" /></m> Rocky Mountain elk. A month later, they returned and
              observed <m><var name="$sp" /></m> Rocky Mountain elk, <m><var name="$st" /></m> of
              which had tags. Approximately how many Rocky Mountain elk are in the Wenaha Wildlife
              Area?
            </p>
            <p>
              <var name="$ans" width="16"/>
            </p>
          </statement>
          <solution>
            <p>
              Let <m>x</m> represent how many elk are in the Wenaha Wildlife Area. We set up a
              proportional equation:
              <md>
                <mrow>\frac{\text{tagged elk}}{\text{total elk}} \amp= \frac{\text{tagged elk}}{\text{total elk}}</mrow>
                <mrow>\frac{<var name="$st" />}{<var name="$sp"/>} \amp= \frac{<var name="$tt"/>}{x}</mrow>
                <mrow>\frac{<var name="$st" />}{<var name="$sp"/>} \multiplyright{<var name="$sp"/>\cdot x} \amp= \frac{<var name="$tt"/>}{x}\multiplyright{<var name="$sp"/>\cdot x}</mrow>
                <mrow><var name="$st" /> \cdot x \amp= <var name="$tt"/>\cdot <var name="$sp"/></mrow>
                <mrow>\divideunder{<var name="$st" /> \cdot x}{<var name="$st" />} \amp= \divideunder{<var name="$tt"/>\cdot <var name="$sp"/>}{<var name="$st" />}</mrow>
                <mrow>x \amp= <var name="$ans"/></mrow>
              </md>
              There are approximately <m><var name="$ans"/></m> elk in the Wenaha Wildlife Area.
            </p>
          </solution>
        </webwork>
      </exercise>
      <exercise label="black-tailed-deer-solved">
        <webwork xml:id="webwork-black-tailed-deer-solved">
          <pg-code>
            $tt = random(80,100);
            $sp = $tt - random(10,18);
            $st = random(6,12);
            $ans = Round($tt*$sp/$st);
          </pg-code>
          <statement>
            <p>
              To estimate the health of the black-tailed deer population in the Jewell Meadow
              Wildlife Area, the Oregon Department of Fish and Wildlife caught, tagged, and released
              <m><var name="$tt" /></m> black-tailed deer. A month later, they returned and observed
              <m><var name="$sp" /></m> black-tailed deer, <m><var name="$st" /></m> of which had
              tags. Approximately how many black-tailed deer are in the Jewell Meadow Wildlife
              Area?
            </p>
            <p>
              <var name="$ans" width="16"/>
            </p>
          </statement>
          <solution>
            <p>
              Let <m>x</m> represent how many deer are in the Jewell Meadow Area. We set up a
              proportional equation:
              <md>
                <mrow>\frac{\text{tagged deer}}{\text{total deer}} \amp= \frac{\text{tagged deer}}{\text{total deer}}</mrow>
                <mrow>\frac{<var name="$st" />}{<var name="$sp"/>} \amp= \frac{<var name="$tt"/>}{x}</mrow>
                <mrow>\frac{<var name="$st" />}{<var name="$sp"/>} \multiplyright{<var name="$sp"/>\cdot x} \amp= \frac{<var name="$tt"/>}{x}\multiplyright{<var name="$sp"/>\cdot x}</mrow>
                <mrow><var name="$st" /> \cdot x \amp= <var name="$tt"/>\cdot <var name="$sp"/></mrow>
                <mrow>\divideunder{<var name="$st" /> \cdot x}{<var name="$st" />} \amp= \divideunder{<var name="$tt"/>\cdot <var name="$sp"/>}{<var name="$st" />}</mrow>
                <mrow>x \amp= <var name="$ans"/></mrow>
              </md>
              There are approximately <m><var name="$ans"/></m> deer in the Jewell Meadow Area.
            </p>
          </solution>
        </webwork>
      </exercise>
    </subexercises>

    <subexercises>
      <title>Challenge</title>
      <exercise label="write-your-own-linear-equation">
        <!-- Kara's challenge problem -->
        <webwork>
          <pg-code>
            Context("ImplicitPlane");
            Context()->variables->are(x=>'Real');
            $solstring = "x-1=-10";
            $solution = ImplicitPlane($solstring);
            $evaluator = $solution->cmp(
              cmp_class=>'a linear equation',
              correct_ans=>$solstring,
              correct_ans_latex_string=>$solstring,
              checker => sub {
                my ($correct,$student,$ansHash) = @_;
                ($left, $right) = split('=',$ansHash->{original_student_ans});
                $left = Formula($left);
                $right= Formula($right);
                $ansHash->{preview_latex_string} = $ansHash->{original_student_ans};
                $ansHash->{preview_text_string} = $ansHash->{original_student_ans};
                $ansHash->{student_ans} = $ansHash->{original_student_ans};
                Value::Error('Your left side is just x') if ($left == Formula('x'));
                Value::Error('Your right side is just x') if ($right == Formula('x'));
                return ($correct == $student);
              }
            );
          </pg-code>
          <statement>
            <p>
              Write a linear equation whose solution is <m>x = -9</m>. Neither side of your equation
              may be just <q><m>x</m></q>.
            </p>
            <p>
              There are infinitely many correct answers to this exercise. After finding an equation
              that works, see if you can come up with a different one that also works.
            </p>
            <p>
              <var name="$solution" evaluator="$evaluator" width="20" />
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="find-equation-with-special-solution-set">
        <!-- Kara's challenge problem -->
        <webwork>
          <pg-code>
            $a = random(2,20,2);
            $b = $a-1;
            $answer = Formula("$a*(x+4)");
            $answer2 = Formula("$b*x+($a*4+2)");
            $evaluator2 = $answer2->cmp(
              checker => sub {
                my ($correct,$student,$ansHash) = @_;
                Value::Error('This is not a linear equation.') unless ($student->D('x')->D('x') == 0 );
                Value::Error('x=2 is not a solution to this equation.') unless ($student->eval(x=>2) == $a*6);
                Value::Error('This equation has infinitely many solutions, not just 2.') unless ($student != $answer);
                return 1;
              }
            );
          </pg-code>
          <statement>
            <p>
              Fill in the right side of the equation to create a linear equation that meets the description.
              <ol marker="a.">
                <li>
                  <p>
                    Create a linear equation with solution set <m>\{2\}</m>.
                  </p>
                  <p>
                    <m> <var name = "$a"/>(x + 4) = </m> <var name="$answer2" evaluator="$evaluator2" width="20"/>
                  </p>
                </li>
                <li>
                  <p>
                    Create a linear equation with <em>infinitely many solutions</em>.
                  </p>
                  <p>
                    <m> <var name = "$a"/>(x + 4) = </m> <var name="$answer" width="20"/>
                  </p>
                </li>
              </ol>
            </p>
          </statement>
        </webwork>
      </exercise>
      <exercise label="preschool-ratio">
      <!-- Kara's challenge problem -->
        <webwork>
          <pg-code>
            $girl = random(2,6,2);
            $boy = random(3,7,2);
            $factor = random(5,9,1);
            $totalgirls = Real($girl*$factor);
            $total = Real(($girl+$boy)*$factor);
          </pg-code>
          <statement>
            <p>
              The ratio of girls to boys in a preschool is <var name="$girl"/> to
              <var name="$boy"/>. If there are <var name="$total"/> kids in the school, how many
              girls are there in the preschool?
            </p>
            <p>
              <var name="$totalgirls" width="10"/>
            </p>
          </statement>
          <solution>
            <p>
              Let <m>x</m> be the number of girls in the preschool. We can represent this situation
              with the following proportion:
            </p>
            <p>
              <m>\frac{<var name="$girl"/>}{<var name="$girl"/>+<var name="$boy"/>} = \frac{x}{<var name="$total"/>}</m>.
              Solve this equation for <m>x</m>.
            </p>
          </solution>
        </webwork>
      </exercise>
    </subexercises>
  </exercises>
</section>

