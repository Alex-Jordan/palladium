        <exercise label="two-step-integer-coefficients-fraction-solution-mxplusbequalsc">
          <webwork xml:id="webwork-two-step-integer-coefficients-fraction-solution-mxplusbequalsc">
            <pg-code>
              $x = list_random('a'..'n', 'p'..'z', 'A'..'D', 'F'..'N', 'P'..'T', 'V'..'Z');
              Context('Fraction')->variables->are($x => 'Real');
              do {
                $m = list_random(-9..-2, 2..9);
                ($b, $c) = random_subset(2, -9..-1, 1..9);
                $sol = Fraction($c - $b, $m);
              } until (($sol->value)[1] != 1);
              Context()->noreduce('(-x)-y', '(-x)+y');
              $left = Formula("$m $x + $b")->reduce;
              $right = Formula("$c")->reduce;
              Context("FiniteSolutionSets");
              Context()->variables->are($x => 'Real');
              $solset = Formula("{$sol}");
