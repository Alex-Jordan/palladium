              Context("Fraction")->variables->are($x => 'Real');
              do {
                do {
                  ($m, $n) = random_subset(2, -9..-2, 2..9);
                  $k = random(2,4);
                } until ($m*$k != $n);
                ($b, $c) = random_subset(2, -9..-1, 1..9);
                $sol = Fraction($c - $m*$b, $m*$k - $n);
              } until (($sol->value)[1] != 1);
              Context()->noreduce('(-x)-y', '(-x)+y');
              $left = Formula("$m($k $x + $b)")->reduce;
              $right = Formula("$n $x + $c")->reduce;
              Context("FiniteSolutionSets");
              Context()->variables->are($x => 'Real');
              $solset = Formula("{$sol}");
            </pg-code>
            <statement>
