        <exercise label="two-step-decimal-mxplusbequalsc">
          <webwork xml:id="webwork-two-step-decimal-mxplusbequalsc">
            <pg-code>
              $x = list_random('a'..'n', 'p'..'z', 'A'..'D', 'F'..'N', 'P'..'T', 'V'..'Z');
              Context()->variables->are($x => 'Real');
              do {
                $m = list_random(-9..9) + random(0.1,0.9,0.1);
                $b = list_random(-9..9) + random(0.1,0.9,0.1);
                $c = list_random(-9..9) + random(0.1,0.9,0.1);
                $sol = ($c - $b)/$m;
              } until ($b != $c);
              Context()->noreduce('(-x)-y', '(-x)+y');
              $left = Formula("$m $x + $b")->reduce;
              $right = Formula("$c")->reduce;
              Context("FiniteSolutionSets")->flags->set(useBizarro => 0);
              Context()->flags->remove("NumberCheck");
              Context()->variables->are($x => 'Real');
              $solset = Formula("{$sol}");
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solset" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
