            <pg-code>
              $x = list_random('a'..'n', 'p'..'z', 'A'..'D', 'F'..'N', 'P'..'T', 'V'..'Z');
              Context()->variables->are($x => 'Real');
              $sol = non_zero_random(-9, 9);
              ($m, $n) = random_subset(2, -9..-1, 1..9);
              ($b, $c) = random_subset(2, -9..-1, 1..9);
              $d = ($m - $n)*$sol + $b + $c;
              Context()->noreduce('(-x)-y', '(-x)+y');
              $left = Formula("$d - ($m $x + $b)")->reduce;
              $right = Formula("-$n $x + $c")->reduce;
              Context("FiniteSolutionSets");
              Context()->variables->are($x => 'Real');
              $solset = Formula("{$sol}");
            </pg-code>
            <statement>
              <p>
