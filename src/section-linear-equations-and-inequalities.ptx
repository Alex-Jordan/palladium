            <pg-code>
              $x = list_random('a'..'n', 'p'..'z', 'A'..'D', 'F'..'N', 'P'..'T', 'V'..'Z');
              Context("Fraction")->variables->are($x => 'Real');
              do {
                do {
                  ($m, $n, $p) = random_subset(3, -9..-1, 1..9);
                } until ($m + $n != $p);
                ($b, $c, $d) = random_subset(3, -9..-1, 1..9);
                $sol = Fraction($c + $d - $b, $m + $n - $p);
              } until (($sol->value)[1] != 1);
              Context()->noreduce('(-x)-y', '(-x)+y');
              $left = Formula("$m $x + $b + $n $x")->reduce;
              $right = Formula("$c + $p $x + $d")->reduce;
              Context("FiniteSolutionSets");
              Context()->variables->are($x => 'Real');
              $solset = Formula("{$sol}");
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solset" width="16"/>
              </p>
            </statement>
          </webwork>
        </exercise>
        <exercise label="more-step-fraction-mxplusbplusnxequalscpluspxplusd-copy">
          <webwork copy="webwork-more-step-fraction-mxplusbplusnxequalscpluspxplusd"/>
        </exercise>
