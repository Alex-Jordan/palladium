    </subexercises> -->

    <subexercises>
      <title>Skills Practice</title>
      <exercisegroup cols="3">
        <title>Two-Step Equations</title>
        <introduction>
          <p>
            Solve the equation.
          </p>
        </introduction>
        <exercise label="two-step-integer-mxplusbequalsc">
          <webwork xml:id="webwork-two-step-integer-mxplusbequalsc">
            <pg-code>
              $x = list_random('a'..'n', 'p'..'z', 'A'..'D', 'F'..'N', 'P'..'T', 'V'..'Z');
              Context()->variables->are($x => 'Real');
              $sol = non_zero_random(-9, 9);
              $m = list_random(-9..-2, 2..9);
              $b = non_zero_random(-9, 9);
              $c = $m*$sol + $b;
              Context()->noreduce('(-x)-y', '(-x)+y');
              $left = Formula("$m $x + $b")->reduce;
              $right = Formula("$c")->reduce;
              Context("FiniteSolutionSets");
              Context()->variables->are($x => 'Real');
              $solset = Formula("{$sol}");
              $solleft[0]  = Formula("$m $x + $b - $b")->reduce;
              $solright[0] = Formula("$x - $b")->reduce;
              $solright[0] = $solright[0]->substitute($x => $c);
              $solleft[1]  = Formula("$m $x")->reduce;
              $solright[1] = Formula("$c - $b")->reduce;
              Context("Fraction")->flags->set(reduceFractions => 0);
              Context()->variables->are($x => 'Real');
              Context()->noreduce('x/(-y)', '(-x)/y');
              $solleft[2]  = Formula("($m $x)/$m")->reduce;
              $solright[2] = $solright[1]/Formula("$m");
              $solleft[3]  = Formula("$x");
              $solright[3] = Formula("$sol");
            </pg-code>
            <statement>
              <p>
                <m><var name="$left"/>=<var name="$right"/></m>
              </p>
              <p>
                <var name="$solset" width="16"/>
              </p>
            </statement>
            <solution>
              <p>
                <md>
                  <mrow> <var name="$left"/> \amp= <var name="$right"/> </mrow>
                  <mrow> <var name="$solleft[0]"/> \amp= <var name="$solright[0]"/> </mrow>
                  <mrow> <var name="$solleft[1]"/> \amp= <var name="$solright[1]"/> </mrow>
                  <mrow> <var name="$solleft[2]"/> \amp= <var name="$solright[2]"/> </mrow>
                  <mrow> <var name="$solleft[3]"/> \amp= <var name="$solright[3]"/> </mrow>
                </md>
                The solution set is <m><var name="$solset"/></m>.
              </p>
            </solution>
          </webwork>
        </exercise>
        <exercise label="two-step-integer-mxplusbequalsc-copy">
          <webwork copy="webwork-two-step-integer-mxplusbequalsc"/>
        </exercise>
