            <pg-code>
              $x = list_random('a'..'n', 'p'..'z', 'A'..'D', 'F'..'N', 'P'..'T', 'V'..'Z');
              Context("Fraction")->variables->are($x => 'Real');
              do {
                do {
                  ($m, $n, $p) = random_subset(3, -9..-2, 2..9);
                  $k = random(2,4);
                } until ($m + $n != $k*$p);
                ($b, $d, $e) = random_subset(3, -9..-1, 1..9);
