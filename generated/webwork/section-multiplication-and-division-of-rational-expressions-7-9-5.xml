  <static seed="1343" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/multiplyRationalExpressions40.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{5r^{4}x^{2}}{6r}} \cdot {\frac{18r^{2}x}{25x^{5}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{3r^{5}}{5x^{2}}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{5r^{4}x^{2}}{6r}} \cdot {\frac{18r^{2}x}{25x^{5}}} \amp = \frac{{5r^{4}x^{2}} \cdot {18r^{2}x}}{{6r} \cdot {25x^{5}}} \\
                                      \amp = \frac{5 \cdot 18 \cdot r^{6} \cdot x^{3}}{6 \cdot 25 \cdot r \cdot x^5} \\
                                      \amp = {\frac{3r^{5}}{5x^{2}}}
\end{aligned}
    }</m></p>
</solution>
