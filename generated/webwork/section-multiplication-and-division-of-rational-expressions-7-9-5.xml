  <static seed="1207" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/multiplyRationalExpressions40.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{3r^{2}y}{5r^{4}}} \cdot {\frac{25r^{3}y^{2}}{6y^{5}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{5r}{2y^{2}}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{3r^{2}y}{5r^{4}}} \cdot {\frac{25r^{3}y^{2}}{6y^{5}}} \amp = \frac{{3r^{2}y} \cdot {25r^{3}y^{2}}}{{5r^{4}} \cdot {6y^{5}}} \\
                                      \amp = \frac{3 \cdot 25 \cdot r^{5} \cdot y^{3}}{5 \cdot 6 \cdot r^4 \cdot y^5} \\
                                      \amp = {\frac{5r}{2y^{2}}}
\end{aligned}
    }</m></p>
</solution>
