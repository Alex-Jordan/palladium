    <solution><p><me>\begin{aligned}
{\sqrt[3]{\frac{24}{125}}}\amp = \frac{\sqrt[3]{24}}{\sqrt[3]{125}}\\
\amp = \frac{\sqrt[3]{8\cdot 3}}{5}\\
\amp = \frac{\sqrt[3]{8}\sqrt[3]{3}}{5}\\
\amp = \frac{2\sqrt[3]{3}}{5}\\
\amp = \frac{2}{5}\sqrt[3]{3}
\end{aligned}</me></p>
