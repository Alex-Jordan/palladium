    <statement><p>Simplify this expression, and if applicable, write the restricted domain.</p>
<p><m>\displaystyle{{\frac{r}{r+8}} \div {4r^{2}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{1}{4r\mathopen{}\left(r+8\right)}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{r}{r+8}} \div {4r^{2}} 
      \amp = {\frac{r}{r+8}} \cdot {\frac{1}{4r^{2}}} \\
      \amp = {\frac{1}{4r\mathopen{}\left(r+8\right)}, \left(-\infty ,\infty \right)}
\end{aligned}
    }</m></p>
</solution>
