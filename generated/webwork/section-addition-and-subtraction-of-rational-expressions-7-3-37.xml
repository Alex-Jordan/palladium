    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify. If applicable, state the restricted domain.</p>
<p><m>\displaystyle{{-\frac{1}{y+5}+4} =}</m> <fillin characters="40" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{4y+19}{y+5}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {-\frac{1}{y+5}+4} 
      \amp = {-\frac{1}{y+5}} +\frac{4}{1} \\
      \amp = {-\frac{1}{y+5}} +\frac{4}{1} \cdot \frac{(y+5)}{(y+5)} \\
      \amp = {-\frac{1}{y+5}+\frac{4\mathopen{}\left(y+5\right)}{y+5}} \\
      \amp = {\frac{-1+4\mathopen{}\left(y+5\right)}{y+5}} \\
      \amp = {\frac{-1+4y+20}{y+5}} \\
      \amp = {\frac{4y+19}{y+5}, \left(-\infty ,\infty \right)}
\end{aligned}
    }</m></p>
</solution>
