    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify. If applicable, state the restricted domain.</p>
<p><m>\displaystyle{{\frac{1}{y-3}+3} =}</m> <fillin characters="40" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{3y-8}{y-3}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{1}{y-3}+3} 
      \amp = {\frac{1}{y-3}} +\frac{3}{1} \\
      \amp = {\frac{1}{y-3}} +\frac{3}{1} \cdot \frac{(y - 3)}{(y - 3)} \\
      \amp = {\frac{1}{y-3}+\frac{3\mathopen{}\left(y-3\right)}{y-3}} \\
      \amp = {\frac{1+3\mathopen{}\left(y-3\right)}{y-3}} \\
      \amp = {\frac{1+3y-9}{y-3}} \\
      \amp = {\frac{3y-8}{y-3}, \left(-\infty ,\infty \right)}
\end{aligned}
    }</m></p>
</solution>
