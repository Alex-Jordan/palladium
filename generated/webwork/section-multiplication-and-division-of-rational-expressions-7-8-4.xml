    <statement><p>Simplify this expression, and if applicable, write the restricted domain.</p>
<p><m>\displaystyle{{\frac{x^{2}-16x}{x^{2}-16}} \cdot {\frac{x^{2}-4x}{x^{2}-13x-48}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{x^{2}}{\left(x+4\right)\mathopen{}\left(x+3\right)}, x\ne 4\hbox{ and }x\ne 16</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{x^{2}-16x}{x^{2}-16}} \cdot {\frac{x^{2}-4x}{x^{2}-13x-48}} 
      \amp = \frac{{x\mathopen{}\left(x-16\right)}}{{\left(x+4\right)\mathopen{}\left(x-4\right)}} \cdot \frac{{x\mathopen{}\left(x-4\right)}}{{\left(x-16\right)\mathopen{}\left(x+3\right)}} \\
      \amp = {\frac{x^{2}}{\left(x+4\right)\mathopen{}\left(x+3\right)}, x\ne 4\hbox{ and }x\ne 16}
\end{aligned}
    }</m></p>
</solution>
