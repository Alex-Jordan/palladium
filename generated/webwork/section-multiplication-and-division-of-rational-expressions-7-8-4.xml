    <statement><p>Simplify this expression, and if applicable, write the restricted domain.</p>
<p><m>\displaystyle{{\frac{t^{2}-4t}{t^{2}-4}} \cdot {\frac{t^{2}-2t}{t^{2}-12t+32}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{t^{2}}{\left(t+2\right)\mathopen{}\left(t-8\right)}, t\ne 2\hbox{ and }t\ne 4</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{t^{2}-4t}{t^{2}-4}} \cdot {\frac{t^{2}-2t}{t^{2}-12t+32}} 
      \amp = \frac{{t\mathopen{}\left(t-4\right)}}{{\left(t+2\right)\mathopen{}\left(t-2\right)}} \cdot \frac{{t\mathopen{}\left(t-2\right)}}{{\left(t-4\right)\mathopen{}\left(t-8\right)}} \\
      \amp = {\frac{t^{2}}{\left(t+2\right)\mathopen{}\left(t-8\right)}, t\ne 2\hbox{ and }t\ne 4}
\end{aligned}
    }</m></p>
</solution>
