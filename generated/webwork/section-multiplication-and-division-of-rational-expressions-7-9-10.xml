  <static seed="1348" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions45.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{({y^{3}+4y^{2}r+4yr^{2}}) \div ({y^{5}+2y^{4}r}) =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{y+2r}{y^{3}}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   ({y^{3}+4y^{2}r+4yr^{2}}) \div ({y^{5}+2y^{4}r}) 
      \amp = \frac{{y^{3}+4y^{2}r+4yr^{2}}}{1} \div \frac{{y^{5}+2y^{4}r}}{1} \\
      \amp = \frac{{y^{3}+4y^{2}r+4yr^{2}}}{1} \cdot {\frac{1}{y^{5}+2y^{4}r}} \\
      \amp = \frac{{y\mathopen{}\left(y^{2}+4yr+4r^{2}\right)}}{1} \cdot \frac{1}{{y^{4}\mathopen{}\left(y+2r\right)}} \\
      \amp = \frac{{y\mathopen{}\left(y+2r\right)^{2}}}{1} \cdot \frac{1}{{y^{4}\mathopen{}\left(y+2r\right)}} \\
      \amp = {\frac{y+2r}{y^{3}}}
\end{aligned}
    }</m></p>
</solution>
