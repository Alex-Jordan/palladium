    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{({x^{4}-12x^{3}r+36x^{2}r^{2}}) \div ({x^{5}-6x^{4}r}) =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{x-6r}{x^{2}}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   ({x^{4}-12x^{3}r+36x^{2}r^{2}}) \div ({x^{5}-6x^{4}r}) 
      \amp = \frac{{x^{4}-12x^{3}r+36x^{2}r^{2}}}{1} \div \frac{{x^{5}-6x^{4}r}}{1} \\
      \amp = \frac{{x^{4}-12x^{3}r+36x^{2}r^{2}}}{1} \cdot {\frac{1}{x^{5}-6x^{4}r}} \\
      \amp = \frac{{x^{2}\mathopen{}\left(x^{2}-12xr+36r^{2}\right)}}{1} \cdot \frac{1}{{x^{4}\mathopen{}\left(x-6r\right)}} \\
      \amp = \frac{{x^{2}\mathopen{}\left(x-6r\right)^{2}}}{1} \cdot \frac{1}{{x^{4}\mathopen{}\left(x-6r\right)}} \\
      \amp = {\frac{x-6r}{x^{2}}}
\end{aligned}
    }</m></p>
</solution>
