  <static seed="1214" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions55.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{1}{y^{2}+9yx+20x^{2}}} \div {\frac{y^{2}}{y^{2}+5yx}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{1}{y\mathopen{}\left(y+4x\right)}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{1}{y^{2}+9yx+20x^{2}}} \div {\frac{y^{2}}{y^{2}+5yx}} 
      \amp = {\frac{1}{y^{2}+9yx+20x^{2}}} \cdot {\frac{y^{2}+5yx}{y^{2}}} \\
      \amp = \frac{{1}}{{\left(y+5x\right)\mathopen{}\left(y+4x\right)}} \cdot \frac{{y\mathopen{}\left(y+5x\right)}}{{y^{2}}} \\
      \amp = {\frac{1}{y\mathopen{}\left(y+4x\right)}}
\end{aligned}
    }</m></p>
</solution>
