  <static seed="1208" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/multiplyRationalExpressions55.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{t^{2}-2tx-15x^{2}}{t-2x}} \cdot {\frac{2t-4x}{t+3x}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>2\mathopen{}\left(t-5x\right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{t^{2}-2tx-15x^{2}}{t-2x}} \cdot {\frac{2t-4x}{t+3x}} 
      \amp = \frac{{\left(t+3x\right)\mathopen{}\left(t-5x\right)}}{{t-2x}} \cdot \frac{{2\mathopen{}\left(t-2x\right)}}{{t+3x}} \\
      \amp = {2\mathopen{}\left(t-5x\right)}
\end{aligned}
    }</m></p>
</solution>
