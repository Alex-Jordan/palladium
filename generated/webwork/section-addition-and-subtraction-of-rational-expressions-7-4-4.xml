  <static seed="1281" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/addSubtractRationalExpressions50.pg">
    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{\frac{t}{15x}-\frac{2t}{5x}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>-\frac{t}{3x}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{t}{15x}-\frac{2t}{5x}} 
      \amp = {\frac{t}{15x}} -\frac{2 t \cdot 3}{5 x \cdot 3} \\
      \amp = {\frac{t}{15x}} -\frac{6 t}{15 x} \\
      \amp = \frac{{t-6t}}{15x} \\
      \amp = \frac{{-5t}}{15x} \\
      \amp = {-\frac{t}{3x}}
\end{aligned}
    }</m></p>
</solution>
