  <static seed="1417" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/addSubtractRationalExpressions50.pg">
    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{\frac{t}{6y}+\frac{t}{3y}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{t}{2y}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{t}{6y}+\frac{t}{3y}} 
      \amp = {\frac{t}{6y}} +\frac{t \cdot 2}{3 y \cdot 2} \\
      \amp = {\frac{t}{6y}} +\frac{2 t}{6 y} \\
      \amp = \frac{{t+2t}}{6y} \\
      \amp = \frac{{3t}}{6y} \\
      \amp = {\frac{t}{2y}}
\end{aligned}
    }</m></p>
</solution>
