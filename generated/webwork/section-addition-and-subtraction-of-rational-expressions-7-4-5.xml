  <static seed="1282" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/addSubtractRationalExpressions50.pg">
    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{\frac{4t}{15y}+\frac{4t}{3y}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{8t}{5y}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{4t}{15y}+\frac{4t}{3y}} 
      \amp = {\frac{4t}{15y}} +\frac{4 t \cdot 5}{3 y \cdot 5} \\
      \amp = {\frac{4t}{15y}} +\frac{20 t}{15 y} \\
      \amp = \frac{{4t+20t}}{15y} \\
      \amp = \frac{{24t}}{15y} \\
      \amp = {\frac{8t}{5y}}
\end{aligned}
    }</m></p>
</solution>
