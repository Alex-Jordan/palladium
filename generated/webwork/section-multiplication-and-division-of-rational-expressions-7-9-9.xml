    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{x^{2}t^{4}}{3}} \div {\frac{x^{2}t^{3}}{18}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>6t</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{x^{2}t^{4}}{3}} \div {\frac{x^{2}t^{3}}{18}} 
      \amp = {\frac{x^{2}t^{4}}{3}} \cdot {\frac{18}{x^{2}t^{3}}} \\
      \amp = {6t}
\end{aligned}
    }</m></p>
</solution>
