[```\newcommand{\amp}{&}
\begin{aligned}
[$expression]\amp = \frac{\sqrt[[$n]]{[$y]}}{\sqrt[[$n]]{[$x]}}\\
\amp = \frac{\sqrt[[$n]]{[$y]}}{[$r]}\\
\amp = \frac{1}{[$r]}\sqrt[[$n]]{[$y]}
