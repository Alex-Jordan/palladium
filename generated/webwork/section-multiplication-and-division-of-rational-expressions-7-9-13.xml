  <static seed="1351" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions55.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{1}{r^{2}+10ry+24y^{2}}} \div {\frac{r^{3}}{r^{2}+6ry}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{1}{r^{2}\mathopen{}\left(r+4y\right)}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{1}{r^{2}+10ry+24y^{2}}} \div {\frac{r^{3}}{r^{2}+6ry}} 
      \amp = {\frac{1}{r^{2}+10ry+24y^{2}}} \cdot {\frac{r^{2}+6ry}{r^{3}}} \\
      \amp = \frac{{1}}{{\left(r+6y\right)\mathopen{}\left(r+4y\right)}} \cdot \frac{{r\mathopen{}\left(r+6y\right)}}{{r^{3}}} \\
      \amp = {\frac{1}{r^{2}\mathopen{}\left(r+4y\right)}}
\end{aligned}
    }</m></p>
</solution>
