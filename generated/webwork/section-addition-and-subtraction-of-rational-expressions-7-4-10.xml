    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{-\frac{10ry}{r^{2}-7ry+6y^{2}}-\frac{2r}{r-y}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>-\frac{2r}{r-6y}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {-\frac{10ry}{r^{2}-7ry+6y^{2}}-\frac{2r}{r-y}} 
      \amp = {-\frac{10ry}{\left(r-y\right)\mathopen{}\left(r-6y\right)}-\frac{2r}{r-y}} \\
      \amp = {-\frac{10ry}{\left(r-y\right)\mathopen{}\left(r-6y\right)}-\frac{2r}{r-y}} \cdot \frac{(r - 6y)}{(r - 6y)} \\
      \amp = {-\frac{10ry}{\left(r-y\right)\mathopen{}\left(r-6y\right)}-\frac{2r\mathopen{}\left(r-6y\right)}{\left(r-y\right)\mathopen{}\left(r-6y\right)}} \\
      \amp = {\frac{-10ry-2r\mathopen{}\left(r-6y\right)}{\left(r-y\right)\mathopen{}\left(r-6y\right)}} \\
      \amp = {\frac{-10ry-2r^{2}+12ry}{\left(r-y\right)\mathopen{}\left(r-6y\right)}} \\
      \amp = {\frac{-2r^{2}+2ry}{\left(r-y\right)\mathopen{}\left(r-6y\right)}} \\
      \amp = \frac{{-2r\mathopen{}\left(r-y\right)}}{{\left(r-y\right)\mathopen{}\left(r-6y\right)}} \\
      \amp = {-\frac{2r}{r-6y}}
\end{aligned}
    }</m></p>
</solution>
