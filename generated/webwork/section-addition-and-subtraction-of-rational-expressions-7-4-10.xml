    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{-\frac{15ry}{r^{2}-3ry-4y^{2}}+\frac{3r}{r-4y}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{3r}{r+y}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {-\frac{15ry}{r^{2}-3ry-4y^{2}}+\frac{3r}{r-4y}} 
      \amp = {-\frac{15ry}{\left(r-4y\right)\mathopen{}\left(r+y\right)}+\frac{3r}{r-4y}} \\
      \amp = {-\frac{15ry}{\left(r-4y\right)\mathopen{}\left(r+y\right)}+\frac{3r}{r-4y}} \cdot \frac{(r+1y)}{(r+1y)} \\
      \amp = {-\frac{15ry}{\left(r-4y\right)\mathopen{}\left(r+y\right)}+\frac{3r\mathopen{}\left(r+y\right)}{\left(r-4y\right)\mathopen{}\left(r+y\right)}} \\
      \amp = {\frac{-15ry+3r\mathopen{}\left(r+y\right)}{\left(r-4y\right)\mathopen{}\left(r+y\right)}} \\
      \amp = {\frac{-15ry+3r^{2}+3ry}{\left(r-4y\right)\mathopen{}\left(r+y\right)}} \\
      \amp = {\frac{3r^{2}-12ry}{\left(r-4y\right)\mathopen{}\left(r+y\right)}} \\
      \amp = \frac{{3r\mathopen{}\left(r-4y\right)}}{{\left(r-4y\right)\mathopen{}\left(r+y\right)}} \\
      \amp = {\frac{3r}{r+y}}
\end{aligned}
    }</m></p>
</solution>
