  <static seed="1346" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions30.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{xt^{3}}{3}} \div {\frac{xt}{9}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>3t^{2}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{xt^{3}}{3}} \div {\frac{xt}{9}} 
      \amp = {\frac{xt^{3}}{3}} \cdot {\frac{9}{xt}} \\
      \amp = {3t^{2}}
\end{aligned}
    }</m></p>
</solution>
