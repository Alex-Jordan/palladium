    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify. If applicable, state the restricted domain.</p>
<p><m>\displaystyle{{\frac{6}{t-6}-\frac{1}{t+2}} =}</m> <fillin characters="40" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{5t+18}{\left(t-6\right)\mathopen{}\left(t+2\right)}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{6}{t-6}-\frac{1}{t+2}} 
      \amp = {\frac{6}{t-6}} \cdot \frac{(t+2)}{(t+2)} -\frac{1}{t+2} \cdot \frac{(t - 6)}{(t - 6)}  \\
      \amp = {\frac{6\mathopen{}\left(t+2\right)-\left(t-6\right)}{\left(t-6\right)\mathopen{}\left(t+2\right)}} \\
      \amp = {\frac{6t+12-t+6}{\left(t-6\right)\mathopen{}\left(t+2\right)}} \\
      \amp = {\frac{5t+18}{\left(t-6\right)\mathopen{}\left(t+2\right)}}
\end{aligned}
    }</m></p>
</solution>
