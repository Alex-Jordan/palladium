    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify. If applicable, state the restricted domain.</p>
<p><m>\displaystyle{{\frac{6}{t-4}+\frac{5}{t+5}} =}</m> <fillin characters="40" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{11t+10}{\left(t-4\right)\mathopen{}\left(t+5\right)}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{6}{t-4}+\frac{5}{t+5}} 
      \amp = {\frac{6}{t-4}} \cdot \frac{(t+5)}{(t+5)} +\frac{5}{t+5} \cdot \frac{(t - 4)}{(t - 4)}  \\
      \amp = {\frac{6\mathopen{}\left(t+5\right)+5\mathopen{}\left(t-4\right)}{\left(t-4\right)\mathopen{}\left(t+5\right)}} \\
      \amp = {\frac{6t+30+5t-20}{\left(t-4\right)\mathopen{}\left(t+5\right)}} \\
      \amp = {\frac{11t+10}{\left(t-4\right)\mathopen{}\left(t+5\right)}}
\end{aligned}
    }</m></p>
</solution>
