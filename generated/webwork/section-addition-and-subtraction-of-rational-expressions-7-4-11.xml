    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{\frac{15ry}{r^{2}+ry-6y^{2}}-\frac{3r}{r-2y}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>-\frac{3r}{r+3y}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{15ry}{r^{2}+ry-6y^{2}}-\frac{3r}{r-2y}} 
      \amp = {\frac{15ry}{\left(r-2y\right)\mathopen{}\left(r+3y\right)}-\frac{3r}{r-2y}} \\
      \amp = {\frac{15ry}{\left(r-2y\right)\mathopen{}\left(r+3y\right)}-\frac{3r}{r-2y}} \cdot \frac{(r+3y)}{(r+3y)} \\
      \amp = {\frac{15ry}{\left(r-2y\right)\mathopen{}\left(r+3y\right)}-\frac{3r\mathopen{}\left(r+3y\right)}{\left(r-2y\right)\mathopen{}\left(r+3y\right)}} \\
      \amp = {\frac{15ry-3r\mathopen{}\left(r+3y\right)}{\left(r-2y\right)\mathopen{}\left(r+3y\right)}} \\
      \amp = {\frac{15ry-3r^{2}-9ry}{\left(r-2y\right)\mathopen{}\left(r+3y\right)}} \\
      \amp = {\frac{-3r^{2}+6ry}{\left(r-2y\right)\mathopen{}\left(r+3y\right)}} \\
      \amp = \frac{{-3r\mathopen{}\left(r-2y\right)}}{{\left(r-2y\right)\mathopen{}\left(r+3y\right)}} \\
      \amp = {-\frac{3r}{r+3y}}
\end{aligned}
    }</m></p>
</solution>
