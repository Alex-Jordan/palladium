  <static seed="1342" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/multiplyRationalExpressions40.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{4r^{5}x^{2}}{5r^{4}}} \cdot {\frac{25r^{4}x}{24x^{4}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{5r^{5}}{6x}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{4r^{5}x^{2}}{5r^{4}}} \cdot {\frac{25r^{4}x}{24x^{4}}} \amp = \frac{{4r^{5}x^{2}} \cdot {25r^{4}x}}{{5r^{4}} \cdot {24x^{4}}} \\
                                      \amp = \frac{4 \cdot 25 \cdot r^{9} \cdot x^{3}}{5 \cdot 24 \cdot r^4 \cdot x^4} \\
                                      \amp = {\frac{5r^{5}}{6x}}
\end{aligned}
    }</m></p>
</solution>
