  <static seed="1206" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/multiplyRationalExpressions40.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{6r^{5}t}{5r^{3}}} \cdot {\frac{25rt^{2}}{12t^{4}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{5r^{3}}{2t}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{6r^{5}t}{5r^{3}}} \cdot {\frac{25rt^{2}}{12t^{4}}} \amp = \frac{{6r^{5}t} \cdot {25rt^{2}}}{{5r^{3}} \cdot {12t^{4}}} \\
                                      \amp = \frac{6 \cdot 25 \cdot r^{6} \cdot t^{3}}{5 \cdot 12 \cdot r^3 \cdot t^4} \\
                                      \amp = {\frac{5r^{3}}{2t}}
\end{aligned}
    }</m></p>
</solution>
