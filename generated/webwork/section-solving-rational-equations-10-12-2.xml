  <static seed="1473" source="Contrib/PCC/BasicAlgebra/RationalLiteralEquations/LiteralEquation260.pg">
    <statement><p>Solve this equation for <m>n</m>:</p>
<p><m>\displaystyle{ y = \frac{x}{n} }</m></p>
<p><fillin characters="7" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>n = \frac{x}{y}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   y \amp = \frac{x}{n} \\
   y \cdot n \amp = \frac{x}{n} \cdot n \\
   y \cdot n \amp = x \\
   \frac{y \cdot n}{y} \amp = \frac{x}{y} \\
   n \amp = \frac{x}{y} 
\end{aligned}
}</m></p>
</solution>
