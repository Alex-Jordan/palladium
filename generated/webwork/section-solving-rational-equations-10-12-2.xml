  <static seed="1609" source="Contrib/PCC/BasicAlgebra/RationalLiteralEquations/LiteralEquation260.pg">
    <statement><p>Solve this equation for <m>A</m>:</p>
<p><m>\displaystyle{ r = \frac{m}{A} }</m></p>
<p><fillin characters="7" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>A = \frac{m}{r}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   r \amp = \frac{m}{A} \\
   r \cdot A \amp = \frac{m}{A} \cdot A \\
   r \cdot A \amp = m \\
   \frac{r \cdot A}{r} \amp = \frac{m}{r} \\
   A \amp = \frac{m}{r} 
\end{aligned}
}</m></p>
</solution>
