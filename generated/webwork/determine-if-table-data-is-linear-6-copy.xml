BEGIN_PGML
Does the table show that [`x`] and [`y`] have a linear relationship?

>> [@DataTable(
  [
    [[PGML('[`x`]'),
      rowbottom => '2',
      midrule => '1',],
     PGML('[`y`]'),
    ],
    [PGML('[`[$x[0]]`]'),
     PGML('[`[$y[0]]`]'),
    ],
    [PGML('[`[$x[1]]`]'),
     PGML('[`[$y[1]]`]'),
    ],
    [PGML('[`[$x[2]]`]'),
     PGML('[`[$y[2]]`]'),
    ],
    [PGML('[`[$x[3]]`]'),
     PGML('[`[$y[3]]`]'),
    ],
    [PGML('[`[$x[4]]`]'),
     PGML('[`[$y[4]]`]'),
    ],
    [PGML('[`[$x[5]]`]'),
     PGML('[`[$y[5]]`]'),
    ],
  ],
      align => '*{2}{r}',
      valign => 'middle',);@]* <<

[_]{$yes}{5}

END_PGML

