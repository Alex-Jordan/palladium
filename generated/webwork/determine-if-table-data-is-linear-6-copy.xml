Context('Numeric');
$m = non_zero_random(2,9,1);
$b = random(1,100,1);
$f = Formula("$m*x + $b");
@x = num_sort(NchooseK(20,6));
@y = map{$f->eval(x=>$_)}(@x);
$yes = DropDown(['yes','no'], 0, showInStatic => 0);
$no = DropDown(['yes','no'], 1, showInStatic => 0);
$ydiff = $y[1]-$y[0];
$xdiff = $x[1]-$x[0];

############################################################
