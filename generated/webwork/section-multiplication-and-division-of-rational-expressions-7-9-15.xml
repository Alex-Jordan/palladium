  <static seed="1217" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions56.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{t^{2}}{t^{2}x-5t}} \div {\frac{1}{t^{2}x^{2}+tx-30}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>t\mathopen{}\left(tx+6\right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{t^{2}}{t^{2}x-5t}} \div {\frac{1}{t^{2}x^{2}+tx-30}} 
      \amp = {\frac{t^{2}}{t^{2}x-5t}} \cdot {\frac{t^{2}x^{2}+tx-30}{1}} \\
      \amp = \frac{{t^{2}}}{{t\mathopen{}\left(tx-5\right)}} \cdot \frac{{\left(tx-5\right)\mathopen{}\left(tx+6\right)}}{{1}} \\
      \amp = {t\mathopen{}\left(tx+6\right)}
\end{aligned}
    }</m></p>
</solution>
