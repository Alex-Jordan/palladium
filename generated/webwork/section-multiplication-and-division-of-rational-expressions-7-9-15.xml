    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{t^{3}}{t^{2}r+4t}} \div {\frac{1}{t^{2}r^{2}+tr-12}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>t^{2}\mathopen{}\left(tr-3\right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{t^{3}}{t^{2}r+4t}} \div {\frac{1}{t^{2}r^{2}+tr-12}} 
      \amp = {\frac{t^{3}}{t^{2}r+4t}} \cdot {\frac{t^{2}r^{2}+tr-12}{1}} \\
      \amp = \frac{{t^{3}}}{{t\mathopen{}\left(tr+4\right)}} \cdot \frac{{\left(tr+4\right)\mathopen{}\left(tr-3\right)}}{{1}} \\
      \amp = {t^{2}\mathopen{}\left(tr-3\right)}
\end{aligned}
    }</m></p>
</solution>
