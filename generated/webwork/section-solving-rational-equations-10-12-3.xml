  <static seed="1610" source="Contrib/PCC/BasicAlgebra/RationalLiteralEquations/LiteralEquation260.pg">
    <statement><p>Solve this equation for <m>q</m>:</p>
<p><m>\displaystyle{ t = \frac{b}{q} }</m></p>
<p><fillin characters="7" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>q = \frac{b}{t}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   t \amp = \frac{b}{q} \\
   t \cdot q \amp = \frac{b}{q} \cdot q \\
   t \cdot q \amp = b \\
   \frac{t \cdot q}{t} \amp = \frac{b}{t} \\
   q \amp = \frac{b}{t} 
\end{aligned}
}</m></p>
</solution>
