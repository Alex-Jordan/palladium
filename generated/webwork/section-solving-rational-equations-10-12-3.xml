  <static seed="1474" source="Contrib/PCC/BasicAlgebra/RationalLiteralEquations/LiteralEquation260.pg">
    <statement><p>Solve this equation for <m>t</m>:</p>
<p><m>\displaystyle{ r = \frac{C}{t} }</m></p>
<p><fillin characters="7" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>t = \frac{C}{r}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   r \amp = \frac{C}{t} \\
   r \cdot t \amp = \frac{C}{t} \cdot t \\
   r \cdot t \amp = C \\
   \frac{r \cdot t}{r} \amp = \frac{C}{r} \\
   t \amp = \frac{C}{r} 
\end{aligned}
}</m></p>
</solution>
