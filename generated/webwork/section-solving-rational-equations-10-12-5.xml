    <statement><p>Solve this equation for <m>q</m>:</p>
<p><m>\displaystyle{ c = \frac{q}{y} }</m></p>
<p><fillin characters="7" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>q = cy</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   c \amp = \frac{q}{y} \\
   c \cdot y \amp = \frac{q}{y} \cdot y \\
   c \cdot y \amp = q \\
   q \amp = c \cdot y
\end{aligned}
}</m></p>
</solution>
