  <static seed="1354" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions60.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{18ty^{4}}{t-5y}} \div {\frac{3t^{8}y}{t^{2}-25y^{2}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{6y^{3}\mathopen{}\left(t+5y\right)}{t^{7}}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{18ty^{4}}{t-5y}} \div {\frac{3t^{8}y}{t^{2}-25y^{2}}} 
      \amp = {\frac{18ty^{4}}{t-5y}} \cdot {\frac{t^{2}-25y^{2}}{3t^{8}y}} \\
      \amp = {\frac{18ty^{4}}{t-5y}} \cdot \frac{{\left(t-5y\right)\mathopen{}\left(t+5y\right)}}{{3t^{8}y}} \\
      \amp = {\frac{6y^{3}\mathopen{}\left(t+5y\right)}{t^{7}}}
\end{aligned}
    }</m></p>
</solution>
