  <static seed="1218" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions60.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{20t^{3}r^{3}}{t-10r}} \div {\frac{4t^{8}r}{t^{2}-100r^{2}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{5r^{2}\mathopen{}\left(t+10r\right)}{t^{5}}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{20t^{3}r^{3}}{t-10r}} \div {\frac{4t^{8}r}{t^{2}-100r^{2}}} 
      \amp = {\frac{20t^{3}r^{3}}{t-10r}} \cdot {\frac{t^{2}-100r^{2}}{4t^{8}r}} \\
      \amp = {\frac{20t^{3}r^{3}}{t-10r}} \cdot \frac{{\left(t-10r\right)\mathopen{}\left(t+10r\right)}}{{4t^{8}r}} \\
      \amp = {\frac{5r^{2}\mathopen{}\left(t+10r\right)}{t^{5}}}
\end{aligned}
    }</m></p>
</solution>
