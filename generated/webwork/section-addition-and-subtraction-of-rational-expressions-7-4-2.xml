  <static seed="1279" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/addSubtractRationalExpressions20.pg">
    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{\frac{100r^{2}}{10r-3y}-\frac{9y^{2}}{10r-3y}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>10r+3y</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{100r^{2}}{10r-3y}-\frac{9y^{2}}{10r-3y}} 
      \amp = \frac{{100r^{2}-9y^{2}}}{{10r-3y}} \\
      \amp = \frac{{\left(10r-3y\right)\mathopen{}\left(10r+3y\right)}}{{10r-3y}} \\
      \amp = {10r+3y}
\end{aligned}
    }</m></p>
</solution>
