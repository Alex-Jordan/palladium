  <static seed="1345" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/multiplyRationalExpressions55.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{t^{2}+5tr+6r^{2}}{t-4r}} \cdot {\frac{2t-8r}{t+2r}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>2\mathopen{}\left(t+3r\right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{t^{2}+5tr+6r^{2}}{t-4r}} \cdot {\frac{2t-8r}{t+2r}} 
      \amp = \frac{{\left(t+2r\right)\mathopen{}\left(t+3r\right)}}{{t-4r}} \cdot \frac{{2\mathopen{}\left(t-4r\right)}}{{t+2r}} \\
      \amp = {2\mathopen{}\left(t+3r\right)}
\end{aligned}
    }</m></p>
</solution>
