  <static seed="1209" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/multiplyRationalExpressions55.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{t^{2}+4tx-5x^{2}}{t+4x}} \cdot {\frac{3t+12x}{t+5x}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>3\mathopen{}\left(t-x\right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{t^{2}+4tx-5x^{2}}{t+4x}} \cdot {\frac{3t+12x}{t+5x}} 
      \amp = \frac{{\left(t+5x\right)\mathopen{}\left(t-x\right)}}{{t+4x}} \cdot \frac{{3\mathopen{}\left(t+4x\right)}}{{t+5x}} \\
      \amp = {3\mathopen{}\left(t-x\right)}
\end{aligned}
    }</m></p>
</solution>
