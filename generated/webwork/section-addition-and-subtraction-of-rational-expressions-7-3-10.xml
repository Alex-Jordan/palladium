    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify. If applicable, state the restricted domain.</p>
<p><m>\displaystyle{{\frac{4y}{3}+\frac{y}{15}} =}</m> <fillin characters="40" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{7y}{5}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{4y}{3}+\frac{y}{15}} 
      \amp = \frac{4y\cdot5}{{3}\cdot5} +{\frac{y}{15}} \\
      \amp = \frac{20y}{15} +{\frac{y}{15}} \\
      \amp = \frac{20y+{y}}{15} \\
      \amp = \frac{21y}{15} \\
      \amp = {\frac{7y}{5}, \left(-\infty ,\infty \right)}
\end{aligned}
    }</m></p>
</solution>
