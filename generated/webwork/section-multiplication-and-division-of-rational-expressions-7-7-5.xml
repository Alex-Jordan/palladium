  <static seed="39" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/multiplyRationalExpressions30.pg">
    <statement><p>Simplify the following expressions, and if applicable, write the restricted domain.</p>
<p><m>\displaystyle{ -{\frac{y^{4}}{y+4}} \cdot {y^{2}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
<p><m>\displaystyle{ -{\frac{y^{4}}{y+4}} \cdot {\frac{1}{y^{2}}} =}</m> <fillin characters="19" name="AnSwEr0002"/></p>
</statement>
    <answer>
      <p>
        <m>-\frac{y^{6}}{y+4}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <answer>
      <p>
        <m>-\frac{y^{2}}{y+4}, y\ne 0</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   -{\frac{y^{4}}{y+4}} \cdot {y^{2}} \amp = -{\frac{y^{4}}{y+4}} \cdot \frac{{y^{2}}}{{1}} \\
                                      \amp = {-\frac{y^{6}}{y+4}, \left(-\infty ,\infty \right)}
\end{aligned}
    }</m></p>
<p><m>\displaystyle{\begin{aligned}
   -{\frac{y^{4}}{y+4}} \cdot {\frac{1}{y^{2}}} \amp = -\frac{y^{2}}{{y+4}} \cdot \frac{1}{1} \\
                                      \amp = {-\frac{y^{2}}{y+4}, y\ne 0}
\end{aligned}
    }</m></p>
</solution>
