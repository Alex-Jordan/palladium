    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify. If applicable, state the restricted domain.</p>
<p><m>\displaystyle{{\frac{5y}{2}+\frac{y}{6}} =}</m> <fillin characters="40" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{8y}{3}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{5y}{2}+\frac{y}{6}} 
      \amp = \frac{5y\cdot3}{{2}\cdot3} +{\frac{y}{6}} \\
      \amp = \frac{15y}{6} +{\frac{y}{6}} \\
      \amp = \frac{15y+{y}}{6} \\
      \amp = \frac{16y}{6} \\
      \amp = {\frac{8y}{3}, \left(-\infty ,\infty \right)}
\end{aligned}
    }</m></p>
</solution>
