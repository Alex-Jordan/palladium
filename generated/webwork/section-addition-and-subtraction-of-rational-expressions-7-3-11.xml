  <static seed="1250" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/addSubtractRationalExpressions40.pg">
    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify. If applicable, state the restricted domain.</p>
<p><m>\displaystyle{{\frac{2y}{5}+\frac{y}{10}} =}</m> <fillin characters="40" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{y}{2}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{2y}{5}+\frac{y}{10}} 
      \amp = \frac{2y\cdot2}{{5}\cdot2} +{\frac{y}{10}} \\
      \amp = \frac{4y}{10} +{\frac{y}{10}} \\
      \amp = \frac{4y+{y}}{10} \\
      \amp = \frac{5y}{10} \\
      \amp = {\frac{y}{2}, \left(-\infty ,\infty \right)}
\end{aligned}
    }</m></p>
</solution>
