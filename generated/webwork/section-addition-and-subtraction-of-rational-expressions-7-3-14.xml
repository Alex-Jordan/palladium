    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify. If applicable, state the restricted domain.</p>
<p><m>\displaystyle{{\frac{5}{t+4}-\frac{1}{t-3}} =}</m> <fillin characters="40" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{4t-19}{\left(t+4\right)\mathopen{}\left(t-3\right)}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{5}{t+4}-\frac{1}{t-3}} 
      \amp = {\frac{5}{t+4}} \cdot \frac{(t - 3)}{(t - 3)} -\frac{1}{t - 3} \cdot \frac{(t+4)}{(t+4)}  \\
      \amp = {\frac{5\mathopen{}\left(t-3\right)-\left(t+4\right)}{\left(t+4\right)\mathopen{}\left(t-3\right)}} \\
      \amp = {\frac{5t-15-t-4}{\left(t+4\right)\mathopen{}\left(t-3\right)}} \\
      \amp = {\frac{4t-19}{\left(t+4\right)\mathopen{}\left(t-3\right)}}
\end{aligned}
    }</m></p>
</solution>
