    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{r^{2}}{r^{2}y+3r}} \div {\frac{1}{r^{2}y^{2}-ry-12}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>r\mathopen{}\left(ry-4\right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{r^{2}}{r^{2}y+3r}} \div {\frac{1}{r^{2}y^{2}-ry-12}} 
      \amp = {\frac{r^{2}}{r^{2}y+3r}} \cdot {\frac{r^{2}y^{2}-ry-12}{1}} \\
      \amp = \frac{{r^{2}}}{{r\mathopen{}\left(ry+3\right)}} \cdot \frac{{\left(ry+3\right)\mathopen{}\left(ry-4\right)}}{{1}} \\
      \amp = {r\mathopen{}\left(ry-4\right)}
\end{aligned}
    }</m></p>
</solution>
