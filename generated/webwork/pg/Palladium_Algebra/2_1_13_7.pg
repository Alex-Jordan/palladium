DOCUMENT();

############################################################
# Load Macros
############################################################
loadMacros(
  "PGstandard.pl",
  "PGML.pl",
  "AnswerFormatHelp.pl",
  "parserOneOf.pl",
  "PGcourse.pl",
);
COMMENT('Authored in PreTeXt');

############################################################
# Header
############################################################
TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
@ORCCA_variables = grep {!/[eoEOU]/} ('a' .. 'z', 'A' .. 'Z');
$var = list_random(@ORCCA_variables);
Context()->variables->are($var=>'Real');
($a, $b) = random_coprime([2 .. 9], [2 .. 9]);
$g = list_random(2 .. 9);
$answer = OneOf(Compute("$g"), Compute("-$g"));
@terms = random_subset(2, Compute("$a*$g $var"), Compute("$b*$g"));

############################################################
# Body
############################################################

BEGIN_PGML
Find the greatest common factor (GCF) of the given terms.

[`[$terms[0]], [$terms[1]]`]

[_]{$answer}{6}

END_PGML

############################################################
# End Problem
############################################################

ENDDOCUMENT();
