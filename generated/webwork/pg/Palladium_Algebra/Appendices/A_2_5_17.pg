TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
($a, $answer, $c) = random_subset(3, 2 .. 9);
($answer,$a) = num_sort($a, $answer);
$b = ($a - $answer)*$c;
Context("LimitedNumeric");
$answer = Real($a - $b/$c);

############################################################
# Body
############################################################

BEGIN_PGML
Use the order of operations to simplify the expression.

[`[$a] - [$b]/[$c]`]

[_]{$answer}{5}

END_PGML

