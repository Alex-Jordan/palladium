loadMacros(
  "PGstandard.pl",
  "PGML.pl",
  "AnswerFormatHelp.pl",
  "contextFraction.pl",
  "PGcourse.pl",
);
COMMENT('Authored in PreTeXt');

############################################################
# Header
############################################################
TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
Context("Fraction");
Parser::Number::NoDecimals;
$f = Fraction(random_coprime([6 .. 20], [11 .. 19]));
$k = random(3 .. 5);
$n = $k*$f->num;
$d = $k*$f->den;
$f = $f->cmp(studentsMustReduceFractions => 1);

############################################################
# Body
############################################################

BEGIN_PGML
Reduce the fraction.

[`\dfrac{[$n]}{[$d]}`]

[_]{$f}{6}

END_PGML

############################################################
# End Problem
############################################################

ENDDOCUMENT();
