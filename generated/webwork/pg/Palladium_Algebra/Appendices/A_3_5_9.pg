loadMacros(
  "PGstandard.pl",
  "PGML.pl",
  "AnswerFormatHelp.pl",
  "contextFraction.pl",
  "PGcourse.pl",
);
COMMENT('Authored in PreTeXt');

############################################################
# Header
############################################################
TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
Context("LimitedFraction")->flags->set(allowMixedNumbers => 0, showMixedNumbers => 0);
$range = [2..15];
($a,$b) = random_pairwise_coprime($range, $range);
$c = random(1,int(100/$b));
$A = Fraction($a,$b);
$ans = $A + $c;

############################################################
# Body
############################################################

BEGIN_PGML
Add or subtract the fractions.

[`[$A]+[$c]`]

[_]{$ans}{5}

END_PGML

############################################################
# End Problem
############################################################

ENDDOCUMENT();
