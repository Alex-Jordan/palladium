loadMacros(
  "PGstandard.pl",
  "PGML.pl",
  "AnswerFormatHelp.pl",
  "contextForm.pl",
  "contextFraction.pl",
  "PGcourse.pl",
);
COMMENT('Authored in PreTeXt');

############################################################
# Header
############################################################
TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
Context("Fraction");
($a,$r,$s) = random_subset(3,1..9);
$f = Formula("$a (x - $r)(x - $s)")->reduce;
$x = Fraction(random_coprime([1..9],[2..9]));
Context("LimitedFraction")->flags->set(allowMixedNumbers => 0, showMixedNumbers => 0);
$ans = Compute($f->eval(x => $x));

############################################################
# Body
############################################################

BEGIN_PGML
Evaluate the given function at the given value.

If [`f(x)=[$f]\text{,}`] find [`f([$x])\text{.}`]

[_]{$ans}{6}

END_PGML

############################################################
# End Problem
############################################################

ENDDOCUMENT();
