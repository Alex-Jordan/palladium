BEGIN_PGML_SOLUTION
[`\newcommand{\substitute}[1]{{\color{blue}{{#1}}}}\newcommand{\amp}{&}\begin{aligned}
                  f(\substitute{-1})\amp=4(\substitute{-1})^2-3(\substitute{-1})-2\\
                  \amp=4+3-2=5
                \end{aligned}`]

END_PGML_SOLUTION

Section::End();

############################################################
# Section
############################################################
