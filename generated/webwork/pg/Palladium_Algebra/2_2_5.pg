Find [`f(2)\text{.}`]

 [_]{$ans[0]}{5}

END_PGML

############################################################
# Solution
############################################################

BEGIN_PGML_SOLUTION
[`\newcommand{\substitute}[1]{{\color{blue}{{#1}}}}\newcommand{\amp}{&}\begin{aligned}
                  f(\substitute{2})\amp=4(\substitute{2})^2-3(\substitute{2})-2\\
                  \amp=16-6-2=8
                \end{aligned}`]

END_PGML_SOLUTION

Section::End();

