BEGIN_PGML
Find [`f\mathopen{}\left(\frac{1}{2}\right)\mathclose{}\text{.}`]

 [_]{$ans[2]}{5}

END_PGML

############################################################
# Solution
############################################################

BEGIN_PGML_SOLUTION
[`\newcommand{\substitute}[1]{{\color{blue}{{#1}}}}\newcommand{\amp}{&}\begin{aligned}
                  f\mathopen{}\left(\substitute{\frac{1}{2}}\right)\mathclose{}
                    \amp=4\left(\substitute{\frac{1}{2}}\right)^2-3\left(\substitute{\frac{1}{2}}\right)-2\\
                  \amp=4\left(\frac{1}{4}\right)-\frac{3}{2}-2\\
                  \amp=1-\frac{3}{2}-2=-\frac{5}{2}
                \end{aligned}`]

END_PGML_SOLUTION

