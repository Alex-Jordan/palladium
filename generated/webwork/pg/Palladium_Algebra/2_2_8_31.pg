TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
($a,$b,$c) = random_subset(3,1..9);
$f = Formula("$a x^2 + $b x + $c")->reduce;
$x = list_random(2 .. 5);
Context("LimitedNumeric");
$ans = Compute($f->eval(x => $x));

############################################################
# Body
############################################################

BEGIN_PGML
Evaluate the given function at the given value.

If [`f(x)=[$f]\text{,}`] find [`f([$x])\text{.}`]

[_]{$ans}{6}

END_PGML

############################################################
# End Problem
############################################################

ENDDOCUMENT();
