DOCUMENT();

############################################################
# Load Macros
############################################################
loadMacros(
  "PGstandard.pl",
  "PGML.pl",
  "AnswerFormatHelp.pl",
  "PCCmacros.pl",
  "parserAssignment.pl",
  "contextForm.pl",
  "PGcourse.pl",
);
COMMENT('Authored in PreTeXt');

############################################################
# Header
############################################################
TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
Context()->noreduce('(-x)-y');
($a, $b, $c) = random_subset(3, 1 .. 9);
$f = Formula("$c + $b x + $a x^2")->reduce;
Context("Numeric")->variables->are(map {$_ =>'Real'} ('a'..'c'));
parser::Assignment->Allow;
$answer = List(Compute("a = $a"), Compute("b = $b"), Compute("c = $c"));

############################################################
# Body
############################################################

BEGIN_PGML
Identify [`a\text{,}`] [`b\text{,}`] and [`c`] from the quadratic function formula.

[`f(x)=[$f]`]

[@KeyboardInstructions('For example, enter [`a=1,b=2,c=3\text{.}`]')@]**

[_]{$answer}{16}

END_PGML

############################################################
# End Problem
############################################################

ENDDOCUMENT();
