    <statement><p>Solve this equation for <m>x</m>:</p>
<p><m>\displaystyle{ b = \frac{x}{m} }</m></p>
<p><fillin characters="7" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>x = bm</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   b \amp = \frac{x}{m} \\
   b \cdot m \amp = \frac{x}{m} \cdot m \\
   b \cdot m \amp = x \\
   x \amp = b \cdot m
\end{aligned}
}</m></p>
</solution>
