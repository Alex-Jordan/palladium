  <static seed="1475" source="Contrib/PCC/BasicAlgebra/RationalLiteralEquations/LiteralEquation270.pg">
    <statement><p>Solve this equation for <m>C</m>:</p>
<p><m>\displaystyle{ a = \frac{C}{c} }</m></p>
<p><fillin characters="7" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>C = ac</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   a \amp = \frac{C}{c} \\
   a \cdot c \amp = \frac{C}{c} \cdot c \\
   a \cdot c \amp = C \\
   C \amp = a \cdot c
\end{aligned}
}</m></p>
</solution>
