Context("Form");
do {
  $n = random(3,6,1);
  $r = random(2,5,1);
  $x = $r**($n);
  $y = ($n % 2 == 0) ? list_random(2,3,5..7,10,11) : list_random(2..7,9..12);
  $X = $x*$y;
} until ($x <= 125 and $X <= 200);
$expression = Formula("root($n,$X)");
$answer = Formula("$r root($n,$y)");

############################################################
# Body
############################################################

BEGIN_PGML
Simplify the higher index radical.

[`[$expression]\text{.}`]

[@KeyboardInstructions('To enter [`\sqrt[n]{x}\text{,}`] type [|root(n, x)|]*. If the value is not a real number, enter [|not a real number|]*.')@]**

