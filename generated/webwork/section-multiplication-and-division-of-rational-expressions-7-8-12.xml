    <statement><p>Simplify this expression, and if applicable, write the restricted domain.</p>
<p><m>\displaystyle{{16t} \div {\frac{4}{t^{3}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>4t^{4}, t\ne 0</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {16t} \div {\frac{4}{t^{3}}} 
      \amp = {16t} \cdot {\frac{t^{3}}{4}} \\
      \amp = {4t^{4}, t\ne 0}
\end{aligned}
    }</m></p>
</solution>
