    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{({y^{5}-10y^{4}x+25y^{3}x^{2}}) \div ({y^{5}-5y^{4}x}) =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{y-5x}{y}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   ({y^{5}-10y^{4}x+25y^{3}x^{2}}) \div ({y^{5}-5y^{4}x}) 
      \amp = \frac{{y^{5}-10y^{4}x+25y^{3}x^{2}}}{1} \div \frac{{y^{5}-5y^{4}x}}{1} \\
      \amp = \frac{{y^{5}-10y^{4}x+25y^{3}x^{2}}}{1} \cdot {\frac{1}{y^{5}-5y^{4}x}} \\
      \amp = \frac{{y^{3}\mathopen{}\left(y^{2}-10yx+25x^{2}\right)}}{1} \cdot \frac{1}{{y^{4}\mathopen{}\left(y-5x\right)}} \\
      \amp = \frac{{y^{3}\mathopen{}\left(y-5x\right)^{2}}}{1} \cdot \frac{1}{{y^{4}\mathopen{}\left(y-5x\right)}} \\
      \amp = {\frac{y-5x}{y}}
\end{aligned}
    }</m></p>
</solution>
