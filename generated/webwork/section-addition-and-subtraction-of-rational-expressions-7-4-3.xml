  <static seed="1280" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/addSubtractRationalExpressions20.pg">
    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{\frac{25r^{2}}{5r-6x}-\frac{36x^{2}}{5r-6x}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>5r+6x</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{25r^{2}}{5r-6x}-\frac{36x^{2}}{5r-6x}} 
      \amp = \frac{{25r^{2}-36x^{2}}}{{5r-6x}} \\
      \amp = \frac{{\left(5r-6x\right)\mathopen{}\left(5r+6x\right)}}{{5r-6x}} \\
      \amp = {5r+6x}
\end{aligned}
    }</m></p>
</solution>
