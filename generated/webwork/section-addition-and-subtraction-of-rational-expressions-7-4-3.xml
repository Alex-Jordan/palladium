  <static seed="1416" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/addSubtractRationalExpressions20.pg">
    <statement><p>Add or subtract the rational expressions to a single rational expression and then simplify.</p>
<p><m>\displaystyle{{\frac{81t^{2}}{9t+5x}-\frac{25x^{2}}{9t+5x}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>9t-5x</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{81t^{2}}{9t+5x}-\frac{25x^{2}}{9t+5x}} 
      \amp = \frac{{81t^{2}-25x^{2}}}{{9t+5x}} \\
      \amp = \frac{{\left(9t+5x\right)\mathopen{}\left(9t-5x\right)}}{{9t+5x}} \\
      \amp = {9t-5x}
\end{aligned}
    }</m></p>
</solution>
