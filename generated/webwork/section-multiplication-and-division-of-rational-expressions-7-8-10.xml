    <statement><p>Simplify this expression, and if applicable, write the restricted domain.</p>
<p><m>\displaystyle{{\frac{r}{r+2}} \div {2r^{4}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{1}{2r^{3}\mathopen{}\left(r+2\right)}, \left(-\infty ,\infty \right)</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{r}{r+2}} \div {2r^{4}} 
      \amp = {\frac{r}{r+2}} \cdot {\frac{1}{2r^{4}}} \\
      \amp = {\frac{1}{2r^{3}\mathopen{}\left(r+2\right)}, \left(-\infty ,\infty \right)}
\end{aligned}
    }</m></p>
</solution>
