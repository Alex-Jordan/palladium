  <static seed="1219" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions60.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{18t^{5}y^{5}}{t-10y}} \div {\frac{6t^{9}y}{t^{2}-100y^{2}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{3y^{4}\mathopen{}\left(t+10y\right)}{t^{4}}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{18t^{5}y^{5}}{t-10y}} \div {\frac{6t^{9}y}{t^{2}-100y^{2}}} 
      \amp = {\frac{18t^{5}y^{5}}{t-10y}} \cdot {\frac{t^{2}-100y^{2}}{6t^{9}y}} \\
      \amp = {\frac{18t^{5}y^{5}}{t-10y}} \cdot \frac{{\left(t-10y\right)\mathopen{}\left(t+10y\right)}}{{6t^{9}y}} \\
      \amp = {\frac{3y^{4}\mathopen{}\left(t+10y\right)}{t^{4}}}
\end{aligned}
    }</m></p>
</solution>
