  <static seed="1355" source="Contrib/PCC/BasicAlgebra/RationalExpressionAlgebraSkills/divideRationalExpressions60.pg">
    <statement><p>Simplify this expression.</p>
<p><m>\displaystyle{{\frac{15x^{5}r^{3}}{x+r}} \div {\frac{5x^{9}r}{x^{2}-r^{2}}} =}</m> <fillin characters="19" name="AnSwEr0001"/></p>
</statement>
    <answer>
      <p>
        <m>\frac{3r^{2}\mathopen{}\left(x-r\right)}{x^{4}}</m>
      </p>
    </answer>
    <solution><p><m>\displaystyle{\begin{aligned}
   {\frac{15x^{5}r^{3}}{x+r}} \div {\frac{5x^{9}r}{x^{2}-r^{2}}} 
      \amp = {\frac{15x^{5}r^{3}}{x+r}} \cdot {\frac{x^{2}-r^{2}}{5x^{9}r}} \\
      \amp = {\frac{15x^{5}r^{3}}{x+r}} \cdot \frac{{\left(x+r\right)\mathopen{}\left(x-r\right)}}{{5x^{9}r}} \\
      \amp = {\frac{3r^{2}\mathopen{}\left(x-r\right)}{x^{4}}}
\end{aligned}
    }</m></p>
</solution>
